*/
  // GENERIC 0-4
  "Core.Hector.Generic.EarlyHeart.1": "@! มีอะไรติดหน้าเธออยู่รึเปล่าน่ะ? อ้อ ดินนี่เอง ไม่มีอะไรจะหอมชื่นใจไปกว่ากลิ่นเหม็นตุๆ ของชาวไร่สินะ ฮึ?$8",
  "Core.Hector.Generic.EarlyHeart.2": "วันนี้ฉันทำแพตตี้เบอร์เกอร์จากแมลงแหละ เธออยากลองชิมไหม?$1#$b#ไม่เหรอ? โห่ เธอนี่มันตัวเหม็นจริงๆ โห่ๆๆๆ!$16",
  "Core.Hector.Generic.EarlyHeart.3": "วันนี้ฉันมีแผนใหญ่เลยล่ะ @ ซึ่งส่วนใหญ่ก็คือการเอาบั้นท้ายไปแปะไว้บนโซฟาตัวนั้นแหละ$6",
  "Core.Hector.Generic.EarlyHeart.4": "ต้องหาเสื้อยืดที่เขียนว่า 'โทษทีที่มาสาย พอดีเกลียดการออกจากหอคอยแล้วก็ไม่ได้อยากมาตั้งแต่แรกน่ะ' มาใส่ซะแล้ว$8#$b#อะไร? มันเจาะจงเกินไปงั้นเหรอ?$7",
  "Core.Hector.Generic.EarlyHeart.5": "ฉันก็นอนตั้งเยอะนะ แต่ทำไมถึงรู้สึกเหนื่อยอยู่ตลอดเวลาเลย ใครกันนะที่ออกแบบร่างกายมนุษย์มาแบบนี้? ฉันอยากจะยื่นเรื่องร้องเรียนชะมัด$16",
  "Core.Hector.Generic.EarlyHeart.6": "นี่นะ ถ้าเธอเห็นใครกำลังคุ้ยขยะอยู่ ก็ปล่อยเขาไปเถอะ อย่าทำตัวเป็นพวกชอบฟ้องเลยน่า$22",
  "Core.Hector.Generic.EarlyHeart.7": "ฉันคงจะดูลึกลับและเท่สุดๆ ไปเลยล่ะ ถ้าหากว่าฉันสามารถหุบปากลงได้บ้างในบางเวลาที่เหมาะสมน่ะนะ$1",
  "Core.Hector.Generic.EarlyHeart.8": "บุ๊ค (Book) ชอบเพลงเมทัลมากๆ เลยล่ะ พวกเราก็เลยเปิดกันเสียงดังลั่นตลอดทั้งวันเลย$0",
  "Core.Hector.Generic.EarlyHeart.9": "รู้สึกปวดตามข้อไปหมดเลย...$19",
  "Core.Hector.Generic.EarlyHeart.10": "ตัวเธอเต็มไปด้วยดินเลย ซึ่งนั่นแหละคือสิ่งที่ควรจะเป็น จงเป็นหนึ่งเดียวกับผืนดินซะ! สวมมันให้เหมือนเป็นผิวหนังชั้นที่สองของเธอเลย! กลิ่นดินเนี่ยคือกลิ่นชั้นดีเลยนะ!$1",
  "Core.Hector.Generic.EarlyHeart.11": "ผีน่ะมีจริงนะ พวกสัตว์ประหลาด มนุษย์ต่างดาว มีจริงหมดนั่นแหละ เธอไม่รู้หรอกว่าโลกที่เราอยู่นี้มีอะไรร่วมอาศัยอยู่บ้าง$22",
  "Core.Hector.Generic.EarlyHeart.12": "@ เธอพิสูจน์ตัวเองไปแล้วนี่ ทำไมถึงยังมาหาฉันอยู่เรื่อยเลยล่ะ? คงไม่ใช่ว่าเธอชอบที่ได้อยู่กับฉันหรอกนะ$16",
  "Core.Hector.Generic.EarlyHeart.13": "บุ๊คกับฉันออกมาจากหอคอยกันวันนี้ ตรงชะง่อนผาข้างนอกนั่นเป็นที่นั่งเล่นที่ดีเลยล่ะ$12",
  "Core.Hector.Generic.EarlyHeart.14": "ถอดรองเท้าออกสิ ลองฝังนิ้วเท้าของเธอลงไปในดินข้างนอกนั่นดู แล้วก็ แบบว่า หุบปากสักแป๊บแล้วลองดื่มด่ำไปกับการได้เชื่อมต่อกับผืนดินดูสิ$14",
  "Core.Hector.Generic.EarlyHeart.15": "บางทีบุ๊คก็จะลอยอยู่ริมหน้าต่างแล้วก็มองออกไปข้างนอก ฉันสงสัยจังว่าเธอกำลังคิดอะไรอยู่$16",
  "Core.Hector.Generic.EarlyHeart.16": "เธอเคยไปทำพวกเรื่องผจญภัยบ้างไหม? แบบ ลงไปในเหมืองน่ะ? ฟังดูอันตรายนะ แล้วก็ดูเหมือนต้องใช้แรงเยอะด้วย$2",
  "Core.Hector.Generic.EarlyHeart.17": "มาเทโอเกลียดปูน่ะ ฉันก็เลยปล่อยปูสักสามสิบตัวเข้าไปในกิลด์โง่ๆ ของพวกเขาซะเลย!$9",
  "Core.Hector.Generic.EarlyHeart.18": "เธอรู้ไหมว่าอะไรที่สมควรจะโดนไฟคลอกตายไปซะ? ก็ไอ้แนวคิดเรื่องทะเลทรายทั้งหมดนั่นแหละ มีแต่ ทรายงั้นเหรอ? เพื่ออะไร? ทรายกับความเศร้าชัดๆ ฉันเกลียดทรายชะมัด$24",
  "Core.Hector.Generic.EarlyHeart.19": "บางทีฉันก็ชอบไปนั่งริมขอบสระน้ำเล็กๆ ในเรือนกระจกแล้วก็เตะเท้าเล่นไปมา ความสุขง่ายๆ ในชีวิต ว่าไหมล่ะ?$8",
  "Core.Hector.Generic.EarlyHeart.20": "เธอเคยรู้สึกเกลียดการอยู่คนเดียว แต่ในขณะเดียวกันก็รู้สึกอึดอัดเวลาต้องอยู่กับคนอื่นบ้างไหม? ไม่งั้นเหรอ? ฉันเป็นอยู่คนเดียวเหรอเนี่ย?$24",
  "Core.Hector.Generic.EarlyHeart.21": "ฉันเคยลองอบพายดูครั้งนึงนะ! ตอนนั้นฉันแปลงร่างเป็นงูอยู่น่ะ การอบขนมโดยไม่มีนิ้วโป้งนี่มันท้าทายสุดๆ ไปเลยล่ะ$1",
  "Core.Hector.Generic.EarlyHeart.22": "บุ๊คพูดอะไรบางอย่างเกี่ยวกับฉัน ว่าการอยู่สันโดษกำลังทำให้ฉันเป็นบ้า แต่เธอก็เป็นแค่คัมภีร์เวทมนตร์ (Grimoire) นี่นะ เธอจะไปรู้อะไรล่ะ?$23",
  "Core.Hector.Generic.EarlyHeart.23": "เอ้า นี่ ฉันเจอเจ้านี่ติดอยู่ในซอกโซฟาน่ะ$16[491]",
  "Core.Hector.Generic.EarlyHeart.24": "คือแบบ ฟาร์มของเธอน่ะ มันสวยมากเลยใช่ไหม? พูดจริงๆ นะ ฉันพนันได้เลยว่ามันต้องสวยมากแน่ๆ ดูเธอจะเก่งเรื่องพวกนี้อยู่นะ$12",
  "Core.Hector.Generic.EarlyHeart.25": "งอกเขี้ยวที่แหลมคมที่สุดของเธอขึ้นมาใหม่สิ เธอรู้ความปรารถนาของฉันนี่ ฉันจะเดินทางข้ามผ่านเส้นทางแห่งเหตุผลไปให้ไกลแสนไกล - พาฉันกลับไปสู่อีเดน (Eden) ที$3",
  "Core.Hector.Generic.EarlyHeart.26": "เมืองเล็กแค่นี้จำเป็นต้องมีนายกเทศมนตรีจริงๆ เหรอ? บางทีฉันน่าจะเป็นนายกเทศมนตรีแทนนะ แล้วฉันจะตั้งกฎใหม่ทันทีเลยว่า: ห้ามมีนายกเทศมนตรี โหวตให้บิ- เฮกเตอร์!$9",
  "Core.Hector.Generic.EarlyHeart.27": "คนชอบถามฉันบ่อยๆ ว่า 'เฮกเตอร์ เวลาไม่สบายไปหาสัตว์แพทย์ หรือไปหาหมอเหรอ?' คำตอบก็คือ ไม่ไปหาใครทั้งนั้นแหละ อีกอย่าง ไม่เคยมีใครถามฉันแบบนั้นหรอก$16",
  "Core.Hector.Generic.EarlyHeart.28": "วันนี้ ฉันทำแล้วก็กินชีสเบอร์เกอร์ไปตั้งสามชิ้นแน่ะ สงสัยฉันจะยังมีกระเพาะแบบหมาป่าอยู่นะ$8",
  "Core.Hector.Generic.EarlyHeart.29": "การมาเยี่ยมฉันนี่คือวิธีทำตัวให้ยุ่งของเธอเหรอ หรือว่าเธอ แบบว่า... วิ่งพล่านไปทั่วเพื่อคุยกับทุกคนเลย? นั่นมันถือเป็นการเข้าสังคมที่ *เยอะ* มากเลยนะ ว้าวซ่าสุดๆ$16",
  "Core.Hector.Generic.EarlyHeart.30": "อ้าว ไง @ ดีใจที่ได้เจอนะ$0#$b#หน้าตาเธอไม่เห็นจะเชื่อฉันเลยแฮะ$16",
  "Core.Hector.Generic.EarlyHeart.31": "เอาจริงๆ ฉันเริ่มจะเบื่อที่ต้องอุดอู้อยู่แต่ในนี้ตลอดเวลาแล้วล่ะ...$18#$b#แต่ฉันก็ไม่อยากจะไปเจอผู้คนอยู่ดีนั่นแหละ$19",
  // GENERIC 5-10
  "Core.Hector.Generic.LateHeart.1": "ฉันเคยลองแปลงร่างเป็นนกแม็กพาย (Magpie) ดูด้วยความอยากรู้น่ะ แล้วก็แบบ... เพิ่งรู้ตัวว่าสัญชาตญาณฉันไม่ได้รู้ว่าต้องบินยังไง อุ๊ปส์$4",
  "Core.Hector.Generic.LateHeart.2": "พูดจริงๆ นะ ฉันไม่รู้เลยว่าตัวเองถูกสร้างขึ้นมา ถูกปลูกขึ้นมา หรือว่าเกิดมากันแน่ ฉันจำเรื่องราวตอนที่ตัวเองเกิดมาไม่ได้เลย แต่สิ่งที่ฉันรู้... คือฉันเป็นทั้งผู้ชาย ผู้หญิง และหมาป่า$13",
  "Core.Hector.Generic.LateHeart.3": "วันนี้เธอหาเวลามานั่งพักนิ่งๆ บ้างหรือยัง? การเชื่อมต่อกับธรรมชาตินั้นเป็นเรื่องสำคัญมากเลยนะที่เราควรจะสละเวลาให้มันน่ะ$12",
  "Core.Hector.Generic.LateHeart.4": "เธอรู้ไหม @... ฉันเคยคิดว่าความเห็นอกเห็นใจนั้นจงใจหลบซ่อนจากฉันไปแล้วซะอีก แต่เธอกลับมายืนอยู่ตรงนี้$8",
  "Core.Hector.Generic.LateHeart.5": "มายองเนส... เอาไว้สำหรับดื่มใช่ไหม? ใช่ไหมล่ะ?$24#$b#มัน *ไม่ใช่* เหรอ? นี่เธอจะบอกฉันว่าคนในเน็ตเอาแต่ *โกหก* เรื่องพวกนี้งั้นสิ?$20",
  "Core.Hector.Generic.LateHeart.6": "วันนี้ฉันออกไปเดินเล่นโง่ๆ เพื่อรักษาสุขภาพจิตมาน่ะ มันก็ดีนะ ที่ได้เอาเท้าเปล่าย่ำลงบนหญ้า พยายามที่จะสนุกกับความร้อนแล้วล่ะแต่มันก็ไม่เวิร์ค เอาเถอะ อย่างน้อยก็ถือว่าได้พยายามแล้วล่ะนะ$0",
  "Core.Hector.Generic.LateHeart.7": "ฉันก็มีหลายเลเยอร์ (layers) เหมือนกับเค้กก้อนนี้นี่แหละ ใช่ ฉันอบมันเอง แล้วก็ไม่ มันไม่มีตะไบซ่อนอยู่ข้างในหรอกนะ[220 221]",
  "Core.Hector.Generic.LateHeart.8": "มาเทโอแวะมาแล้วถามว่าฉันอยากได้กาแฟปรุงรสไร้สาระอะไรนั่นไหม ฉันตอบไปว่าไม่ แต่พวกเขาก็ยังซื้อมาฝากฉันอยู่ดีแหละ$16#$b#มันอร่อยมากเลยนะ$8",
  "Core.Hector.Generic.LateHeart.8.Filtered": "มาเทโอแวะมาแล้วถามว่าฉันอยากได้กาแฟปรุงรสไร้สาระอะไรนั่นไหม ฉันตอบไปว่าไม่ แต่พวกเขาก็ยังซื้อมาฝากฉันอยู่ดีแหละ$16#$b#มันอร่อยมากเลยนะ$8",
  "Core.Hector.Generic.LateHeart.9": "บุ๊คบอกว่าเธอจะแวะมา แล้วก็ *สั่ง* ใช่ *สั่ง* ให้ฉันทำมื้อเช้าเผื่อเธอด้วย ฉันต้องทำตามใจเธอน่ะ ปฏิเสธไม่ได้หรอก เดี๋ยวเธอจะงอนเอา$7[201]",
  "Core.Hector.Generic.LateHeart.10": "เธอคิดว่าวิธีทำการเกษตรของเธอมันมีจริยธรรมไหม? นั่นใช่สิ่งที่เธอเคยคิดหรือเปล่า? การที่เธอค้ำจุนชุมชนเล็กๆ แห่งนี้นับว่าเป็นเรื่องที่น่ายกย่องมากเลยนะ$8",
  "Core.Hector.Generic.LateHeart.11": "แสงแห่งรุ่งอรุณสาดส่อง และเธอจะจดจำได้ทุกสิ่ง เพียงแค่รอจนกว่าดวงตะวันจะคล้อยต่ำลงอีกครา และรัตติกาลจะมาเยือน$3",
  "Core.Hector.Generic.LateHeart.12": "ฉันซาบซึ้งนะที่เธอมาเยี่ยม บางทีอยู่ที่นี่มันก็เหงาน่ะ ฉันแค่อยากให้เธอเชื่อฉันจริงๆ นะ เธอจะเชื่อไหม ถ้าฉันพูดบ่อยกว่านี้?$17#$b#มันก็แอบยากนิดนึงนะ แต่ฉันว่าฉันพอจะลองพยายามดูได้$16",
  "Core.Hector.Generic.LateHeart.13": "เธอเป็นพวกเชื่อเรื่องจิตวิญญาณไหม @? มันคงจะแปลกๆ นะถ้าเธอไม่เชื่อ หมายถึง เธอก็เป็นเพื่อนกับคนแบบนั้นอยู่นี่นา$7#$b#...เราเป็นเพื่อนกันใช่ไหม? คงไม่ใช่ว่าฉันเข้าใจผิดเรื่องที่เธอมาเยี่ยมบ่อยๆ ไปเองหรอกนะ?$2",
  "Core.Hector.Generic.LateHeart.14": "ฉันว่าโทรทัศน์นี่เป็นอะไรที่น่าสนใจมากเลยนะ มันช่วยให้เห็นมุมมองความสัมพันธ์ระหว่างมนุษย์กับงานศิลปะน่ะ$7#$b#โดยเฉพาะอย่างยิ่ง ฉันชอบรายการที่มีการผสมผสานแนวทางต่างๆ ได้อย่างลงตัว อย่างเช่น คาวบอยกับหุ่นยนต์ อะไรทำนองเนี้ย$8",
  "Core.Hector.Generic.LateHeart.15": "อย่าเข้าใจผิดไปนะ ฉันไม่ได้ตั้งใจทำสิ่งนี้ *ให้* เธอหรอกนะ ฉันก็แค่มีมันอยู่แล้ว แค่วางทิ้งไว้เฉยๆ แน่นอนสิ!$9[253]",
  "Core.Hector.Generic.LateHeart.16": "บางครั้งบางคราวก็มีสัตว์ป่าบุกเข้ามาที่นี่เพื่อหนีหนาวนะ ก็ไม่เป็นไรหรอก ฉันก็แค่พยายามทำให้ที่นี่เป็นบ้านสำหรับพวกมันน่ะ$1",
  "Core.Hector.Generic.LateHeart.17": "ฉันพยายามยืดเส้นยืดสายอะไรพวกนั้นมาตลอดเลย แต่การออกกำลังกายนี่มันห่วยชะมัด ใครกันนะที่สร้างร่างกายมนุษย์ให้เปราะบางขนาดนี้? ใครเป็นคนคิดว่าการต้องคอยดูแลรักษามันซะขนาดนี้เป็นความคิดที่ดีกัน?$2",
  "Core.Hector.Generic.LateHeart.18": "ฉันรู้เคล็ดลับที่จะชนะใจทุกคนได้นะ @ ก็พวกหินเท่ๆ ยังไงล่ะ! [86]$1#$b#มันเป็นแบบนั้นใช่ไหมล่ะ? ไม่มีอะไรจะเทียบได้กับชิ้นส่วนดีๆ จากธรรมชาติหรอกนะ",
  "Core.Hector.Generic.LateHeart.19": "นี่ รู้ไหม ฉันก็อยากไปดื่มกับเธอนะ แต่ฉันไม่ชอบรสชาติฮอปส์ (Hops) ในเบียร์ส่วนใหญ่เลย$24#$b#แต่ฉันชอบมากๆ เลยนะเวลาที่มันมีรสชาติออกผลไม้เปรี้ยวๆ น่ะ$8",
  "Core.Hector.Generic.LateHeart.20": "เฮอร์ดี้-เกอร์ดี้ (Hurdy gurdy) เหรอ? อ้อ มันเป็นของขวัญจากเพื่อนบ้านที่แสนดีและเป็นที่รักของฉันน่ะ คนเลี้ยงแพะน่ะ$0#$b#ฉันพยายามฝึกเล่นจนเก่งเพื่อที่จะได้เล่นให้เขาฟังน่ะ ฉันเล่นให้เธอฟังด้วยก็ได้นะ ถ้าเธออยากฟัง$7",
  "Core.Hector.Generic.LateHeart.21": "ฟาร์มของเธอเป็นยังไงบ้าง @? น่าทึ่งมากเลยนะที่เธอจัดการกับมันได้ดีเยี่ยม แถมยังต้องมารับภาระทางอารมณ์ของคนทั้งเมืองอีก$7#$b#รวมถึงของฉันด้วย ขอโทษทีนะเรื่องนั้น$2",
  "Core.Hector.Generic.LateHeart.22": "เอาจริงๆ ฉันไม่เคยออกไปข้างนอกหุบเขานี้เลยล่ะ แต่ฉันสำรวจป่าและภูเขารอบๆ นี้มาหมดทุกตารางนิ้วแล้วนะ...$23#$b#บางทีฉันอาจจะพาเธอไปดูความลับของธรรมชาติพวกนั้นบ้างก็ได้นะ @",
  "Core.Hector.Generic.LateHeart.23": "เธอเคยคิดที่จะละทิ้งสังคมนี้ไปเลย แล้วไปใช้ชีวิตอยู่ในภูเขาลึกดูบ้างไหม? ไม่เหรอ?$8#$b#หมายถึง ฉันเดาว่าเธอคงทำอะไรคล้ายๆ แบบนั้นไปแล้วกับฟาร์มน่ะนะ ใช่ไหม? โอเค แต่ว่านะ ลองฟังฉันก่อน ลองทำอะไรที่มันไปให้สุดกว่านี้สิ-$7",
  "Core.Hector.Generic.LateHeart.24": "ฉันไม่เคยไปทะเลทรายเลย และก็หวังว่าจะไม่มีเหตุผลให้ต้องไปนะ ฉันเกลียดความร้อน ฉันเกลียดทราย มันเข้าไปติดอยู่ทุกซอกทุกมุมเลย แค่คิดก็ อี๋ ละ ไม่เอาด้วยหรอก$18",
  "Core.Hector.Generic.LateHeart.25": "ระดับความเห็นอกเห็นใจของเอลัวส์ (Eloise) นี่มันเหลือเชื่อจริงๆ เลย เจค็อบนี่เป็นพ่อที่ยอดเยี่ยมมากเลยนะที่เลี้ยงดูเธอมาแบบนั้นน่ะ$14#$b#สักวันหนึ่ง ฉันจะสอนทุกอย่างที่ฉันรู้ให้เธอ บุ๊คคงดีใจมากแน่ๆ ที่ได้อยู่ในการดูแลของเธอ$13",
  "Core.Hector.Generic.LateHeart.26": "ฉันทำความสะอาดโรงนาซะเกลี้ยงเลย แล้วก็แอบทำงานบ้านข้างในให้เจค็อบไปบ้างเพื่อเซอร์ไพรส์เขาน่ะ$1#$b#เขามีอะไรต้องทำตั้งเยอะแยะ ฉันก็เลยอยากช่วยในเรื่องเล็กๆ น้อยๆ เท่าที่ทำได้ เพื่อที่เขาจะได้มีเวลาอยู่กับเอลัวส์เยอะๆ ไง$12",
  "Core.Hector.Generic.LateHeart.27": "สักวันนึง ฉันควรจะพาเธอไปเดินเที่ยวบนภูเขาบ้างนะ ฉันคิดว่าเธอคงจะชอบวิวทิวทัศน์ที่นั่นแน่ๆ มันน่าทึ่งมากเลยนะ$14",
  "Core.Hector.Generic.LateHeart.28": "มีอะไรบ้างไหมที่เธอให้ไป แล้วรู้ว่าจะไม่มีวันได้รับกลับคืนมา? เธอรู้หรือเปล่าว่ามันคืออะไร?$3",
  "Core.Hector.Generic.LateHeart.29": "รู้ไหม @ เธอเองก็มีพลังดรูอิด (Druidics) สื่อถึงธรรมชาติได้นะ - เธอเคยลองสื่อสารกับธรรมชาติดูบ้างไหม?$23#$b#ลองเลือกต้นไม้ต้นโปรดดูสิ ถอดรองเท้าออก แล้วก็ใช้เวลาอยู่กับมันสักพัก มันอาจจะมีอะไรจะบอกเธอเยอะแยะเลยล่ะ แค่อาจจะไม่ได้สื่อสารเป็นคำพูดก็เท่านั้นเอง$7",
  "Core.Hector.Generic.LateHeart.30": "เอลัวส์น่ะคุยเรื่องนกได้เป็นชั่วโมงๆ เลย ฉันเคยถามเธอเรื่องนกแม็กพาย - ซึ่งเป็นนกที่ฉันชอบมากที่สุดน่ะ แล้วเธอก็เล่าให้ฟังแบบไม่ยอมหยุดเลยล่ะ$13#$b#เจค็อบก็จะทำแบบเดียวกันนะถ้าเธอไปถามเขาเรื่องการรักษาสัตว์น่ะ ฉันรักพวกเขาทั้งคู่เลยล่ะ$14",
  "Core.Hector.Generic.LateHeart.31": "เธอต้องเอายางสนมาถูกงล้อของเฮอร์ดี้-เกอร์ดี้ (Hurdy gurdy) เหมือนกับที่ทำกับคันชักน่ะ แล้วก็เล่นมันด้วยการหมุนข้อเหวี่ยง แต่เสียงของมันก็จะดูโหยหวนกว่าไวโอลินนิดหน่อยนะ$8",
  "Core.Hector.Generic.LateHeart.32": "เธอเคยรู้สึกอยากกลับบ้าน ทั้งๆ ที่ตัวเองก็อยู่ที่บ้านแล้วบ้างไหม? ความรู้สึกนี้มันคืออะไรกันนะ?$23#$b#ต้องเป็นอะไรที่เฉพาะตัวมนุษย์แน่ๆ เลย$22",
  "Core.Hector.Generic.LateHeart.33": "ดรูอิดจะสามารถรับรู้ถึงการเปลี่ยนแปลงข้างขึ้นข้างแรมของดวงจันทร์ได้อย่างลึกซึ้งเลยล่ะ อิทธิพลของมันอาจจะแผ่วเบา แต่ก็มีอยู่จริงนะ$7#$b#มันส่งผลต่อทั้งพืชผลและพฤติกรรมของสัตว์ ฉันเองก็อดไม่ได้ที่จะรู้สึกบ้าคลั่งขึ้นมานิดหน่อยเวลาที่พระจันทร์เต็มดวง$8",
  "Core.Hector.Generic.LateHeart.34": "ยิ่งคิดก็ยิ่งอยากให้เอลัวส์ได้รู้จักกับบุ๊คนะ ยังไงซะ เธอก็เคยเห็นฉันแปลงร่างมาแล้วนี่นา$12#$b#ฉันคิดว่าสคาร์ป (Scarp) คงจะได้รับการดูแลเป็นอย่างดีหากอยู่ในความดูแลของเธอ อาจจะนะ สักวันหนึ่ง$14",
  "Core.Hector.Generic.LateHeart.35": "ต้นสนน่ะเป็นต้นไม้ที่ฉันชอบที่สุดเลย ฉันไม่ได้พูดเพราะว่าตอนนี้มันกำลังพยายามจะเขมือบหอคอยของฉันอยู่หรอกนะ แน่นอนสิ$4#$b#ก็นี่แหละธรรมชาติน่ะ เธอจะทำตามที่เธอพอใจ และจะพรากเอาสิ่งที่เธอต้องการไปเสมอ$0",
  "Core.Hector.Generic.LateHeart.36": "พืชพรรณและผืนดินคือช่องทางในการสื่อสารกับพระแม่ธรณี พวกเขาอาจจะไม่ได้พูดภาษาเดียวกัน แต่นั่นไม่ได้แปลว่าพวกเขาไม่ได้กำลังรับฟังอยู่นะ$13#$b#ฉันขอแนะนำให้เธอลองดูนะ ถ้ามีโอกาส$14",
  "Core.Hector.Generic.LateHeart.37": "ฉันจะใช้ประโยชน์สูงสุดจากกระแสน้ำที่กำลังพลิกผัน มันเพิ่งจะแหวกผ่านเศษซากแห่งความเงียบงันที่มอดไหม้อยู่$3#$b#อย่ารอช้าเลยนะ เพราะนี่อาจจะเป็นครั้งสุดท้ายที่เธอจะมาปรากฏอยู่ในภวังค์ความคิดของฉัน$3",
  "Core.Hector.Generic.LateHeart.38": "รู้ไหมว่าต้นไม้ก็ชอบของหวานเหมือนกันนะ พวกเขาพร้อมจะแบ่งปันให้เสมอถ้าเธอแค่ขอดีๆ น่ะ$8[724]",
  "Core.Hector.Generic.LateHeart.39": "เจค็อบให้พวกนี้ฉันมาบ้างแล้วล่ะ แต่... ฉันคิดว่าเธอจำเป็นต้องใช้มันมากกว่าฉันนะ[349]$12#$b#ฉันรู้ว่าช่วงที่ฟาร์มไม่ได้ปลูกอะไร เธอคงลงไปในเหมืองบ่อยขึ้นล่ะสิ อย่าให้บาดเจ็บกลับมาล่ะ เข้าใจไหม?$13",
  "Core.Hector.Generic.LateHeart.40": "ฉันไม่ค่อยได้ใช้เวลาคิดเรื่องอนาคตเท่าไหร่นักหรอก มันไม่เคยดูจำเป็นเลย ฉันแค่รับมือกับทุกสิ่งแบบวันต่อวัน แค่ให้ผ่านพ้นพระอาทิตย์ขึ้นไปในแต่ละวันก็พอ$22#$b#แต่ช่วงนี้ ฉันเริ่มคิดถึงเรื่องต่างๆ มากมายเลย ทั้งเรื่องของเจค็อบ, เอลัวส์, เรื่องความอุดมสมบูรณ์ของสคาร์ป...$23",
  "Core.Hector.Generic.LateHeart.41": "@! ช่วงนี้ฉันเริ่มอ่านหนังสือบ้างแล้วล่ะ ห้องสมุดของมาเทโอมีหนังสือเยอะน่าดูเลยนะ รู้ไหม?$7#$b#ฉันกำลังอินกับคอมมิคเรื่องนี้เลย Agent of As-อะไรสักอย่างนี่แหละ มันเป็นเรื่องเกี่ยวกับเทพแห่งเรื่องเล่าน่ะ สนุกมากเลยนะ$6",
  "Core.Hector.Generic.LateHeart.42": "เธอดูจะเป็นตัวเร่งปฏิกิริยาให้เกิดการเปลี่ยนแปลงเลยนะ @ เธอพามาเทโอกลับมาสู่สังคมได้ แล้วตอนนี้ - ก็นะ$3#$b#ฉันยอมออกจากหอคอย ฉันมีงานทำ ฉันได้สร้างมิตรภาพ ฉันคงจะปิดกั้นตัวเองจากประสบการณ์เหล่านี้ไปแล้วล่ะถ้าไม่ใช่เพราะเธอ$8",
  "Core.Hector.Generic.LateHeart.43": "บนโลกใบนี้ยังมีอะไรอีกมากมายนอกจากหอคอยของฉัน และป่าไม้ที่ล้อมรอบมันอยู่$13#$b#ฉันจินตนาการภาพตัวเองต้องถูกขังอยู่แต่ในนั้นไม่ออกอีกต่อไปแล้วล่ะ โดยเฉพาะอย่างยิ่งตอนที่มีเจค็อบและเอลัวส์พึ่งพาฉันอยู่ด้วย$14",
  // SEASONAL
  // SPRING
  "Core.Hector.Spring.1": "@! เธอตื่นเต้นที่จะได้เข้าสู่ฤดูเพาะปลูกอีกครั้งไหม? ฉันล่ะตื่นเต้นสุดๆ เลย!$1",
  "Core.Hector.Spring.2": "ฉันผิดหวังมากเลยนะที่มีคนมากมายชอบตัดวัชพืชทิ้งน่ะ$16#$b#อย่างแดนดิไลออนเนี่ย เอาไปชงชาอร่อยมากเลยนะ แค่เพราะว่าอะไรบางอย่างมันดูไม่สวย ก็ไม่ได้หมายความว่าเธอควรจะตัดมันทิ้งซะหน่อย$0[251]",
  "Core.Hector.Spring.3": "ฉันทำความสะอาดหอคอยล่ะ เพราะมันถึงช่วงเวลาของปีแล้วไง$0#$b#ซึ่งแต่แรกมันก็ไม่ได้รกอะไรมากหรอกนะ เพราะงั้นฉันเลยภูมิใจกับตัวเองเกินกว่าที่ควรจะเป็นไปหน่อย$8",
  "Core.Hector.Spring.4": "ฉันไม่ได้พึ่งพาคำพูดสุดโรแมนติกกับทุกสิ่งอย่างที่กิลด์มาสเตอร์ของเธอทำหรอกนะ...$12#$b#แต่ฉันก็จะบอกว่า พระอาทิตย์ขึ้นในฤดูใบไม้ผลินี่มันสวยงามเป็นพิเศษเลยล่ะ$13",
  "Core.Hector.Spring.5": "ฉันยอมพลีกายเพื่อสตรอว์เบอร์รี่เลยล่ะ$8[745]",
  "Core.Hector.Spring.6": "ทำไมคนถึงต้องตัดหญ้าหน้าบ้านตัวเองด้วยนะ? ก็ปล่อยให้มันโตตามธรรมชาติไปสิ ใครจะไปสนกัน$8#$b#ถ้าอยากจะให้มันสั้นนักล่ะก็ ปลูกมอสแทนสิ มอสจะโตเตี้ยๆ อยู่แล้ว$22",
  "Core.Hector.Spring.7": "ถ้าฤดูใบไม้ผลิคือฤดูกาลแห่งการเริ่มต้นใหม่ ฤดูร้อนก็คือฤดูกาลแห่งความอุดมสมบูรณ์$12#$b#ฉันไม่ค่อยถูกกับความร้อนเท่าไหร่หรอกนะ แต่ฉันก็ยอมรับเลยว่าความโหดร้ายของมันก็มีความงดงามในแบบของมันเองอยู่$14",
  "Core.Hector.Spring.8": "ฤดูใบไม้ผลิคือฤดูกาลแห่งการเริ่มต้นใหม่ ถึงฉันจะรักฤดูหนาวมากแค่ไหน แต่ก็ปฏิเสธไม่ได้หรอกนะว่ารู้สึกกระปรี้กระเปร่าขึ้นมาเลยล่ะตอนที่หิมะละลายหมดน่ะ$12#$b#ฉันมั่นใจเลยว่ามันคงโรแมนติกน้อยกว่าสำหรับเธอแน่ๆ ก็เธอต้องกลับไปทำฟาร์มต่อแล้วนี่นะ$9",
  "Core.Hector.Spring.9": "ฉันจะมีการเฉลิมฉลองส่วนตัวปีละสองครั้งน่ะ ตอนที่ดวงอาทิตย์อยู่ที่จุดสูงสุดหรือต่ำสุดบนท้องฟ้าของปี$12#$b#เธอสนใจจะมาร่วมด้วยไหม-? เอาจริงๆ มันเป็นเรื่องที่สำคัญมากสำหรับฉันเลยนะ$4",
  "Core.Hector.Spring.10": "$query DAY_OF_WEEK Sat Sun#วันหยุดสุดสัปดาห์แล้ว! เธอรู้ไหมว่ามันหมายความว่าอะไร! ถูกต้อง! ก็ทำแบบเดียวกับที่ฉันทำในวันอื่นๆ นั่นแหละ เพราะฉันไม่ใช่ทาสระบบทุนนิยมยังไงล่ะ$1#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|เอ้านี่ @ %farm สมควรได้รับดอกไม้สวยๆ บ้างนะ$13[597]",
  "Core.Hector.Spring.11": "เอ้านี่ @ %farm สมควรได้รับดอกไม้สวยๆ บ้างนะ$13[427]",
  "Core.Hector.Spring.12": "ถ้าฤดูใบไม้ผลิคือฤดูกาลแห่งการเริ่มต้นใหม่ ฤดูร้อนก็คือฤดูกาลแห่งความอุดมสมบูรณ์$12#$b#ฉันไม่ค่อยถูกกับความร้อนเท่าไหร่หรอกนะ แต่ฉันก็ยอมรับเลยว่าความโหดร้ายของมันก็มีความงดงามในแบบของมันเองอยู่$14",
  "Core.Hector.Spring.13": "ทำไมคนถึงต้องตัดหญ้าหน้าบ้านตัวเองด้วยนะ? ก็ปล่อยให้มันโตตามธรรมชาติไปสิ ใครจะไปสนกัน$8#$b#ถ้าอยากจะให้มันสั้นนักล่ะก็ ปลูกมอสแทนสิ มอสจะโตเตี้ยๆ อยู่แล้ว$22",
  "Core.Hector.Spring.14": "ฉันทำความสะอาดหอคอยล่ะ เพราะมันถึงช่วงเวลาของปีแล้วไง$0#$b#ซึ่งแต่แรกมันก็ไม่ได้รกอะไรมากหรอกนะ เพราะงั้นฉันเลยภูมิใจกับตัวเองเกินกว่าที่ควรจะเป็นไปหน่อย$8",
  "Core.Hector.Spring.15": "ฉันจะมีการเฉลิมฉลองส่วนตัวปีละสองครั้งน่ะ ตอนที่ดวงอาทิตย์อยู่ที่จุดสูงสุดหรือต่ำสุดบนท้องฟ้าของปี$12#$b#เธอสนใจจะมาร่วมด้วยไหม-? เอาจริงๆ มันเป็นเรื่องที่สำคัญมากสำหรับฉันเลยนะ$4",
  // SUMMER
  "Core.Hector.Summer.1": "$query RANDOM 0.5#ใครเป็นคนคิดค้นความชื้นขึ้นมากันเนี่ย? หลอกลวงกันชัดๆ$18#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ฉันต้องติดแอร์ในหอคอยนี้จริงๆ ซะแล้วสิ ไม่งั้นฉันคงละลายแน่ๆ แหวะ$16",
  "Core.Hector.Summer.2": "$query RANDOM 0.5#ด้วยความรักที่มีต่อสิ่งดีงามและศักดิ์สิทธิ์ทั้งปวง ฉันล่ะอยากให้ฝนตกชะมัด ความร้อนจะได้หายๆ ไปสักที$19#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|จะกินไอศกรีมปริมาณเท่าไหร่ก็ถือว่าปกติทั้งนั้นแหละ! ต่อให้เป็นสี่โคนก็เถอะ$1",
  "Core.Hector.Summer.3": "$query RANDOM 0.5#เดี๋ยวนะ การกินไอศกรีมมากเกินไปมัน *ไม่ดี* ต่อสุขภาพเหรอ? แล้วจุดประสงค์ของฤดูร้อนมันคืออะไรกันล่ะเนี่ย?$20#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|จะเป็นยังไงนะถ้าฉันแค่แปลงร่างเป็นตุ่นหนูเปลือย (Naked Mole Rat) ตลอดทั้งฤดูร้อนนี้เลย? ฉันจะได้รู้สึกอึดอัดน้อยลงไง$18",
  "Core.Hector.Summer.4": "เยี่ยม เมล่อน! แต่รู้ไหมว่าอะไรที่แย่สุดๆ? เมล่อนฮันนี่ดิว (Honeydew) ไงล่ะ$0[479]",
  "Core.Hector.Summer.8": "ข้างนอกมันแย่สุดๆ ไปเลย ฉันเกลียดอากาศแบบนี้ ขอบใจนะ ไม่รู้ว่าเธอทนออกไปทำงานในสภาพอากาศแบบนี้ได้ยังไง$18",
  "Core.Hector.Summer.5": "รู้ไหม ดอกทานตะวันน่ะฉลาดนะ? พวกมันจะหันตามทิศทางของดวงอาทิตย์ในตอนกลางวัน แต่จะหันไปทางทิศตะวันออกในตอนกลางคืนล่ะ$14#$b#แถมเมล็ดของมันก็อร่อยมากๆ ด้วยนะ เอาไปคั่วเกลือสักหน่อยน่ะ!$9[431]",
  "Core.Hector.Summer.6": "ฉันรู้สึกว่าคนส่วนใหญ่จะตื่นเต้นกันมากเลยนะในช่วงฤดูร้อน แต่ฉันน่ะมีแต่จะบ่นเรื่องนี้ซะมากกว่า$8#$b#คิดว่าการติดแอร์ในหอคอยจะยากไหมนะ?$9",
  "Core.Hector.Summer.7": "เธอเคยเห็นต้นมะเฟือง (Starfruit) ไหม? มันขึ้นในแนวนอนน่ะ เธอสามารถขึ้นไปนั่งบนนั้นได้เลยนะ[268]$0#$b#ธรรมชาตินี่มันน่าทึ่งจริงๆ ว่าไหม?$8",
  "Core.Hector.Summer.9": "ฉันไปว่ายน้ำก็ได้นะ แต่ - เอ้อ ช่างมันเถอะ ถ้าไปก็มีโอกาสจะ แบบว่า ถูกคนอื่นเห็นเข้า ฉันเกลียดอะไรแบบนั้นที่สุดเลย$25",
  "Core.Hector.Summer.10": "ช่วงกลางวันของฤดูร้อนจะยาวนานขึ้น พระแม่ธรณีกำลังบอกเราในแบบของเธอน่ะ ว่าให้เพลิดเพลินกับสิ่งที่ได้รับมาซะ 'ออกไปสัมผัสหญ้าซะบ้าง' แต่แบบว่า เป็นคำพูดที่น่าฟังกว่าน่ะ$9",
  "Core.Hector.Summer.11": "ถ้าฉันจะต้องเหงื่อออก ฉันก็อยากให้มันออกเพราะได้ทำอะไรที่เป็นชิ้นเป็นอันมากกว่านะ อากาศแบบนี้ห่วยชะมัด$18",
  "Core.Hector.Summer.12": "หิ่งห้อยนี่มันช่างน่าเศร้าเนอะ ว่าไหม? พวกมันอยู่ที่นี่ ในช่วงเวลาสั้นๆ เกิดมาเพื่อความสวยงามและให้คนชื่นชม แล้วพวกมันก็จากไป โคตรจะไม่ยุติธรรมเลย$24",
  "Core.Hector.Summer.13": "โอ๊ยยยย ปวดเมื่อยไปหมดเลย พออากาศร้อนทีไรอะไรๆ ก็บวมเต่งไปหมด เธอคงคิดว่าฉันอายุเป็นร้อยๆ ปีแล้วล่ะสิ$18#$b#อายุฉันน่ะเหรอ? หยาบคายจัง ฉันไม่มีเหตุผลอะไรให้ต้องมานั่งนับอายุตัวเองหรอกนะ ก่อนที่จะเริ่มมาอยู่ในร่างมนุษย์เนี่ย$16",
  "Core.Hector.Summer.14": "น่าเสียดายจังที่ฉันต้องมาปวดท้องทรมานแบบนี้เวลาที่กินไอศกรีม ทั้งๆ ที่มันเป็นของหวานที่ยอดเยี่ยมมากแท้ๆ สำหรับช่วงเวลานี้ของปี$17#$b#สิ่งเดียวที่ทำร้ายฉันได้มากกว่านี้ก็คือช็อกโกแลตนี่แหละ กินไม่ได้เลยสักนิด$4",
  "Core.Hector.Summer.15": "ฉันเกือบจะคลานเข้าไปซุกอยู่ใต้เตียงแล้วนะเนี่ย @ อากาศมันร้อนบ้าบอมากเลย$24",
  // FALL
  "Core.Hector.Fall.1": "อ่า ใช่เลย ช่วงเวลาของปีที่ทุกคนเริ่มเถียงกันแบบไร้เหตุผลเรื่องรสชาติ พัมพ์กิ้นสไปซ์ (Pumpkin Spice) หรือ แอปเปิ้ลซินนามอน (Apple Cinnamon) ทำไมไม่เอาทั้งสองอย่างเลยล่ะ? เธอมีความสามารถรับรสได้หลากหลายอยู่แล้วนี่นา$0",
  "Core.Hector.Fall.2": "ถึงฤดูกาลแห่งการป่วนแล้วนะ รู้ไหม$6",
  "Core.Hector.Fall.3": "ใช่ๆ ทิวทัศน์มันสวย ฉันรู้ ฉันไม่ต้องออกไปเดินดูใบไม้เปลี่ยนสีหรอกน่า$16",
  "Core.Hector.Fall.4": "ครึ่งหนึ่งคือจังหวะ ครึ่งหนึ่งคือเทพเจ้า ความบกพร่องท่ามกลางความหนาวเหน็บ หรือรอยโหว่ในความฝันอันแสนประหลาด$3",
  "Core.Hector.Fall.5": "เธอต้องพึ่งต้นไม้เพื่อบอกว่าฤดูกาลเปลี่ยนไปแล้วงั้นเหรอ? นั่นมันหน้าที่ของปฏิทินไม่ใช่หรือไง?$25",
  "Core.Hector.Fall.6": "ฤดูกาลแห่งความตาย ไม่ใช่เรื่องแย่เลยนะ ทุกสิ่งล้วนต้องตายเพื่อที่จะได้เกิดใหม่ มันเป็นส่วนหนึ่งของชีวิตล่ะ$7",
  "Core.Hector.Fall.7": "อากาศเริ่มเย็นลงจนฉันต้องกลับมาใส่รองเท้าอีกแล้วล่ะ น่าผิดหวังจัง ฉันรู้สึกเชื่อมต่อกับพื้นดินได้น้อยลงเลยแฮะ$24",
  "Core.Hector.Fall.8": "อ่า ใช่แล้ว ช่วงเวลาของปีที่ทุกสิ่งทุกอย่างเย็นลง ยกเว้นความคลั่งไคล้ขนมธีมฤดูใบไม้ร่วงของมาเทโอ$13",
  "Core.Hector.Fall.9": "จะเป็นยังไงนะถ้าฉันแค่เอาฟักทอง *จำนวนมหาศาล* ไปกองรวมกันไว้กลางจัตุรัสเมือง? คิดว่ามันจะสนุกไหม?$23#$b#เราคงได้กินแต่ของรสฟักทองไปจนถึงปีหน้าเลยล่ะ$13",
  "Core.Hector.Fall.10": "ชอบเสียงใบไม้กรอบๆ จัง การเหยียบพวกมันก็ไม่เป็นไรหรอกนะ ความตายเป็นส่วนหนึ่งของชีวิต และพวกมันก็ทำหน้าที่ของตัวเองเสร็จแล้วล่ะตอนที่ตกลงมาถึงพื้นน่ะ$0",
  "Core.Hector.Fall.11": "จริงๆ แล้วดอกผักโขม (Amaranth) เป็นหนึ่งในสิ่งที่ฉันชอบที่สุดที่ปลูกในช่วงนี้ของปีเลยล่ะ บางทีมันอาจจะไม่ได้กำไรเยอะแยะหรืออะไรก็ตามแต่... เอ้านี่ @$12[300]",
  "Core.Hector.Fall.12": "ถ้ามีประกวดชุดแฟนซีในงานสปิริตส์อีฟนะ ฉันจะดันให้เอลัวส์ชนะให้ได้เลย$9",
  "Core.Hector.Fall.13": "ฉันมีความเชื่อส่วนตัวแบบเฉพาะเจาะจงมากๆ ว่าการเปลี่ยนสีของใบไม้น่ะ เป็นสัญลักษณ์ของชีวิต ความตาย และการเกิดใหม่ มันเป็นอะไรที่ลึกซึ้งและเป็นนิรันดร์มากเลยนะ$6#$b#แล้วมันก็ แบบว่า ดูสุนทรีย์มากด้วยแหละ$8",
  "Core.Hector.Fall.14": "ฤดูใบไม้ร่วงคือผืนผ้าที่ถักทอขึ้นมาจากความทรงจำของฤดูร้อนล่ะ$14",
  "Core.Hector.Fall.15": "ฉันพยายามจะไม่ทำตัวให้พวกชาวเมืองเพลิแกนรู้หรอกนะว่าฉันเป็นหมาป่าในคราบมนุษย์น่ะ แต่ฉันก็ชอบใส่ชุดเกราะของฉันไปงานสปิริตส์อีฟนะ$12#$b#รัดเกล้านั่นมีความหมายกับฉันมากเลย น่าเสียดายนะที่มันพังไปแล้ว$14",
  // WINTER
  "Core.Hector.Winter.1": "$query RANDOM 0.5#ลองปาบอลหิมะใส่หัวนายกเทศมนตรีดูสิ เอาเลย เธอไม่กล้าหรอก!$9#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|แย่จังที่ของหลายอย่างปลูกไม่ขึ้นในฤดูหนาว แต่มันก็ไม่เป็นไรหรอก ผืนดินเองก็ต้องการการพักผ่อนเหมือนกันนะ$0",
  "Core.Hector.Winter.2": "$query RANDOM 0.5#มันเงียบมากเลย! ฉันรักความเงียบนะ ยกเว้นว่ามันจะเป็นเสียงของฉันเอง - ถ้าเป็นงั้นก็พูดต่อไปเถอะ$7#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ฉันอยู่ได้สบายๆ โดยไม่มีความร้อนของฤดูร้อนเลยนะ มันทำให้อวัยวะฉันรู้สึกเหมือนเป็นสนิมไปหมดเลย แต่ตอนนี้ก็ไม่ใช่ปัญหาแล้วล่ะ$24",
  "Core.Hector.Winter.3": "$query RANDOM 0.5#ฉันชอบเวลาอากาศเย็นนะ! ทุกอย่างให้ความรู้สึกสดชื่นไปหมดเลย!$1#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ฉันมั่นใจว่าเธอคงเคยได้ยินมานับครั้งไม่ถ้วนแล้วล่ะ - 'มาปั้นมนุษย์หิมะด้วยกันไหม? (do you want to build a snowman?)' ว่าไงล่ะ อยากปั้นไหม?$12",
  "Core.Hector.Winter.4": "$query RANDOM 0.5#บางทีทุกคนอาจจะไม่ได้บ้าคลั่งความหนาวแบบฉันหรอกมั้ง ฉันเดาว่างั้นนะ ก็แค่ เอ่อ ดูแลตัวเองด้วยก็แล้วกัน หรืออะไรทำนองนั้นน่ะ อย่าป่วยซะล่ะ$6#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|เธอคิดว่าจะมีใครโกรธไหม ถ้าฉันจัดฉากฆาตกรรมมนุษย์หิมะสุดสยองอะไรทำนองนั้นน่ะ?$6",
  "Core.Hector.Winter.5": "$query RANDOM 0.5#ฉันเปลี่ยนร่างได้เฉพาะสิ่งที่ฉันเป็นอยู่แล้วเท่านั้น ฉันไม่ใช่หมีแน่ๆ แต่ถึงอย่างนั้น ก็ไม่มีอะไรจะดีไปกว่าการได้งีบหลับยาวๆ ในช่วงฤดูหนาวหรอกนะ$6#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ค่ำคืนในฤดูหนาวก็เหมือนผืนผ้าใบที่สาดกระเซ็นไปด้วยดวงดาว ฉันตั้งตารอที่จะได้ใช้เวลาข้างนอกเพื่อชื่นชมมันเลยล่ะ$12",
  "Core.Hector.Winter.6": "$query RANDOM 0.5#ดูแลตัวเองด้วยนะ โอเคไหม? อย่าป่วยล่ะ ดื่มน้ำเยอะๆ แล้วก็แต่งตัวให้อบอุ่น อะไรก็ได้ที่จำเป็น ใส่ผ้าพันคอซะด้วยล่ะ$7#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|อยากช่วยฉันปั้นกองทัพมนุษย์หิมะเล็กๆ ไหม? ฉันว่านะ มันต้องดูหลอนสุดๆ แน่ๆ ถ้าเราสาดสีผสมอาหารสีแดงใส่พวกมันน่ะ$8",
  "Core.Hector.Winter.7": "$query RANDOM 0.5#ผืนดินกำลังหลับใหล วัฏจักรของธรรมชาตินั้นสะท้อนให้เห็นถึงตัวเราเอง เธอไม่คิดงั้นเหรอ?$23#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ฉันเดาว่าพอไม่มีอะไรให้ปลูก เธอก็คงลงไปในเหมืองพวกนั้นบ่อยขึ้นล่ะสิ ฉันไม่จำเป็นต้องเตือนให้เธอระวังตัวหรอกนะ เธอโตแล้วนี่$25",
  "Core.Hector.Winter.8": "$query RANDOM 0.5#มืดเร็วมากเลยนะเนี่ย ซึ่งก็ดีเหมือนกัน จะได้มีเวลาเหลือเฟือให้ไปสร้างเรื่องป่วนชาวบ้านแบบจงใจซะหน่อย$9#$action AddMail Current SnS_M_Hector_OverrideSeenToday received|ต้นไม้ของฉันไม่ค่อยได้รับแสงแดดในช่วงนี้ของปีเท่าไหร่ ฉันเลยต้องระวังให้มากแล้วก็ใช้เวทมนตร์เพิ่มอีกนิดหน่อยเพื่อรักษาชีวิตพวกมันไว้$23",
  "Core.Hector.Winter.9": "ฤดูหนาวนำพาความมืดมิดบางอย่างมาด้วย - ฉันเข้าใจนะว่ามันส่งผลกระทบต่อคนที่ชอบแสงสว่างยังไง$14#$b#แต่ฉันไม่ได้รังเกียจมันเลยสักนิดนะ$13",
  "Core.Hector.Winter.10": "ถ้ามีโอกาส ลองหาเวลาชื่นชมความเงียบสงบของผืนดินดูสิ ตอนนี้ข้างนอกมันเงียบสงบในแบบที่แตกต่างออกไปเลยนะ$8#$b#ตอนนี้เธอกำลังหลับใหล แต่ก็คงอีกไม่นานหรอกนะ$7",
  "Core.Hector.Winter.11": "ฮอลลี่ (Holly) น่ะกินเข้าไปแล้วจะทำให้ป่วยนะ ไม่รู้เหมือนกันว่าเธอจะไปกินมันทำไม แต่แบบ...$8#$b#ฉันเคยเห็นเธอเก็บของกินจากพื้น หรือคุ้ยจากถังขยะมาแล้วนี่นา ก็เลยคิดว่าควรจะเตือนเธอไว้ก่อนดีกว่า$9",
  "Core.Hector.Winter.12": "ฉันรักจังเลยเวลาที่แสงแดดทอประกายระยิบระยับบนหิมะที่เพิ่งตกใหม่ๆ ในตอนเช้าน่ะ เธอว่าไหม?$14#$b#หุบปากไปเลย ฉันไม่ได้อ่อนไหวซะหน่อย ฉันก็แค่ *พูดเฉยๆ*-$8",
  "Core.Hector.Winter.13": "ฉันมีกองผ้าห่มที่สูงจนภูเขายังต้องอิจฉาเลยล่ะ$8#$b#อะไร? ไม่ๆ นั่นไม่ใช่คำชวนนะ$4",
  "Core.Hector.Winter.14": "เจอที่มุมสบายๆ ริมหน้าต่างตรงนี้ที่แสงแดดส่องผ่านเกล็ดน้ำแข็งเข้ามาได้ด้วยล่ะ$1#$b#ฉันนึกว่าจะต้องเสียพื้นที่อาบแดดไปตลอดช่วงฤดูหนาวนี้ซะแล้ว แต่ดูเหมือนจะไม่ใช่นะ$0",
  "Core.Hector.Winter.15": "มันไม่ใช่ว่าผืนดินยอมแพ้ในช่วงเวลานี้ของปีหรอกนะ ไม่ใช่เลยสักนิด$7#$b#มันเหมือนกับว่าเธอกำลังพักผ่อนยาวๆ ต่างหาก การดูแลตัวเองก็สำคัญนะ รู้ไหม$8",
  // 10H PLATONIC
  // SPRING
  "Core.Hector.Spring.Relationship.Platonic.1": "เธอนี่เหมือนกับแสงแดดอุ่นๆ เลยนะ รู้ตัวไหม @? ทั้งอบอุ่น และเป็นที่ต้อนรับเสมอ$12#$b#อย่ามองฉันแบบนั้นสิ ฉันก็มีสิทธิ์ที่จะซึ้งบ้างเป็นบางเวลาเหมือนกันนะ โอเคไหม?$12",
  "Core.Hector.Spring.Relationship.Platonic.2": "@ ทักษะการเพาะปลูกของเธอนี่มันไม่ธรรมดาจริงๆ นะ เธอเริ่มจากศูนย์ แต่ %farm ก็ดูยอดเยี่ยมมากเลยทั้งที่ต้องเจอกับความท้าทายมากมาย$8#$b#...ขอไม่ขอโทษนะที่ฉัน *เป็น* หนึ่งในความท้าทายเหล่านั้นน่ะ แต่ฉันก็ชื่นชมในความทุ่มเทของเธอนะ$9",
  "Core.Hector.Spring.Relationship.Platonic.3": "ฉันเจอหินเท่ๆ ก้อนนึงน่ะ คิดว่าเธออาจจะชอบ$4[390]#$b#นั่นคือพื้นฐานการทำงานของมิตรภาพใช่ไหมล่ะ? หินเท่ๆ น่ะ?$8",
  "Core.Hector.Spring.Relationship.Platonic.4": "ช่วงนี้ของปี เจค็อบดูเหมือนจะได้ชาร์จพลังเต็มที่เลยล่ะ ซึ่งมันดีมากๆ เลยนะ ฉันล่ะเศร้าใจเวลาเห็นเขาซึมๆ น่ะ$12#$b#ฉันแค่อยากให้เขาและเอลัวส์มีความสุข และมีชีวิตที่เรียบง่าย พวกเขาสมควรได้รับมันนะ$14",
  "Core.Hector.Spring.Relationship.Platonic.5": "ความเปลี่ยนแปลงลอยมาตามสายลม ฉันสัมผัสได้ คำถามคือ อะไรกำลังจะเกิดขึ้น-$23#$b#โอ้ ไง @ เป็นไงบ้างล่ะ?$6",
  "Core.Hector.Spring.Relationship.Platonic.6": "เอลัวส์ทำถูกแล้วล่ะที่ต่อว่าฉันตอนที่เราเจอกันครั้งแรก ฉันนึกถึงเรื่องนี้บ่อยๆ นะ ถ้าเธอไม่ทำแบบนั้น ฉันรู้สึกว่าฉันคงจะแตกต่างออกไปจากตอนนี้อย่างบอกไม่ถูกเลยล่ะ$12#$b#บุ๊คก็เห็นด้วยนะ และเธอก็ตื่นเต้นมากที่จะได้เจอเอลัวส์ในสักวันนึง ไม่รู้สิว่าฉันจะดึงเจค็อบมาร่วมด้วยได้ไหมนะ$8",
  "Core.Hector.Spring.Relationship.Platonic.7": "ฉันทำตัวละครของฉันพลีชีพในบอร์ดเกมของมาเทโอน่ะ แล้วก็ตายมาอีกหลายครั้งด้วยวิธีที่ดราม่าน้อยกว่านั้นเยอะเลย$8#$b#หลักๆ ก็เป็นเพราะตอนนี้ฉันเอาแต่สร้างคอนเซปต์งี่เง่าๆ น่ะแหละ ตอนนี้ฉันเล่นเป็นคุณยายตัวจิ๋วที่ถือกระทะอยู่ ฉันหวังว่าเธอจะมีชีวิตอยู่รอดไปได้มากกว่าหนึ่งเซสชันนะ$4",
  // SUMMER
  "Core.Hector.Summer.Relationship.Platonic.1": "ฉันจะละเว้นการบ่นว่าฉันเกลียดความร้อนมากแค่ไหนให้เธอฟังก็แล้วกัน ฉันกำลังดูๆ เรื่องทางเลือกในการติดแอร์ให้หอคอยอยู่น่ะ$24#$b#น่าเสียดายที่ฉันไม่มีเวทมนตร์ที่จะช่วยลดอุณหภูมิของอากาศได้น่ะสิ$16",
  "Core.Hector.Summer.Relationship.Platonic.2": "เจค็อบกับฉันพาเอลัวส์ไปกินไอศกรีมมาน่ะ น่ารักมากๆ เลยที่เธอจำได้ว่าฉันกินช็อกโกแลตไม่ได้$7#$b#และข่าวที่เกี่ยวข้องก็คือ ตอนนี้ฉันค่อนข้างจะเสพติดซอร์เบต์ (Sorbet) ไปแล้วล่ะ$6",
  "Core.Hector.Summer.Relationship.Platonic.3": "เธอรู้ไหม ว่าถ้าเธอแบ่งเจ้านี่ให้ใครสักคน พวกเธอสองคนจะถูกกำหนดให้คู่กันตลอดไปนะ$8[268]#$b#ฉันล้อเล่นน่ะ$7#$b#ล้อเล่นจริงๆ เหรอ?$6",
  "Core.Hector.Summer.Relationship.Platonic.4": "การมีเธออยู่ด้วยก็เหมือนกับการเติบโตของดอกไม้ป่านั่นแหละ คาดไม่ถึง แต่น่ายินดี เธอเข้ามาพลิกฟื้นผืนดินแห่งความโดดเดี่ยวของฉันเลยนะ$12",
  "Core.Hector.Summer.Relationship.Platonic.5": "กลางวันมันยาวนานขึ้นในช่วงเวลานี้ของปี มีแสงแดดมากขึ้น ทำอะไรได้มากขึ้น$7#$b#มีเหตุผลมากมายที่ทำให้การเปลี่ยนฤดูกาลเป็นเรื่องที่น่ายินดี และนั่นก็เป็นหนึ่งในนั้นแหละ$8",
  "Core.Hector.Summer.Relationship.Platonic.6": "ฉันชอบใส่กระโปรงสั้นๆ เป็นส่วนหนึ่งของชุดว่ายน้ำนะ ไม่ว่าตอนนั้นฉันจะอยู่ในรูปลักษณ์ไหนก็ตาม กระโปรงน่ะสำหรับทุกคนแหละ และฉันก็สมควรจะรู้สึกว่าตัวเองสวยบ้าง$14",
  "Core.Hector.Summer.Relationship.Platonic.7": "เอลัวส์ให้ฉันยืมกล้องส่องทางไกลสำรองของเธอด้วยล่ะ เราจะได้ไปดูนกกัน มันยากนะที่จะนั่งนิ่งๆ และเงียบๆ น่ะ แต่เพื่อเธอ ฉันจะทำนะ$14",
  // FALL
  "Core.Hector.Fall.Relationship.Platonic.1": "มาเทโอกำลังพยายามลากฉันไปดูหนังมาราธอนกับพวกเขาน่ะ พวกบ้าความตื่นเต้นแบบไหนกันถึงได้เอาแต่ดูหนังสยองขวัญซ้ำไปซ้ำมา?$23#$b#แน่นอนว่าฉันไม่ได้ปฏิเสธไปหรอก ฉันคิดว่านั่นคือความหมายของการเป็นเพื่อนน่ะนะ บางครั้งเธอก็ต้องทำในสิ่งที่ไม่อยากทำเพื่อให้อีกคนมีความสุขไงล่ะ$8",
  "Core.Hector.Fall.Relationship.Platonic.2": "ถ้าฉันสามารถมอบชีวิตคืนให้กับสัตว์ทุกตัวที่เจค็อบสูญเสียไประหว่างทำงานได้ล่ะก็ ฉันก็จะทำนะ$21#$b#ไม่ใช่เพราะว่าฉันไม่เชื่อในวัฏจักรชีวิตหรอกนะ แต่เป็นเพราะการสูญเสียมันทำให้เขาเศร้า และฉันก็ไม่อยากให้เขาเศร้าน่ะ$25",
  "Core.Hector.Fall.Relationship.Platonic.3": "ความงามของฤดูใบไม้ร่วงคือความเงียบสงบนะ ฉันว่า บางทีนั่นอาจจะเป็นเหตุผลที่มันได้รับความชื่นชมอย่างลึกซึ้งล่ะมั้ง$23#$b#หรือบางทีอาจจะแค่เพราะข้างนอกมันไม่ร้อนเหนอะหนะอีกต่อไปแล้วก็ได้นะ$8",
  "Core.Hector.Fall.Relationship.Platonic.4": "ฟาร์มของเธอเป็นยังไงบ้างในช่วงนี้ของปี? ฉันพนันได้เลยว่ามันต้องสีสันสดใสมากแน่ๆ ฉันอาจจะแวะไปดูสักครั้งนะ$12",
  "Core.Hector.Fall.Relationship.Platonic.5": "ฉันทำนี่ให้มาเทโอน่ะ แต่เดี๋ยวแกก็คงมาทำซึ้งใส่ฉันอีก ฉันไม่ได้อยู่ในอารมณ์จะมารับมือกับเรื่องพวกนั้นหรอกนะ[746]$9#$b#เอาไปสิ เธอเอาไปให้พวกเขาแทนก็แล้วกัน หรือจะเก็บไว้เองก็ได้นะ แล้วแต่เธอเลย$14",
  "Core.Hector.Fall.Relationship.Platonic.6": "กุหลาบขาว, พิราบดำ, แม่ทูนหัว, จงลุกขึ้นเถิด ข้าต้องการให้ท่านเห็นว่าข้าได้กลายเป็นสิ่งใดไปแล้ว$3#$b#โอ้ ดวงตาที่ดั่งเปลวเพลิงนั่น ข้าคือแมลงมีปีก ส่วนท่านคือแท่นเผาศพ$3",
  "Core.Hector.Fall.Relationship.Platonic.7": "ฤดูกาลแห่งการผุพัง เห็ด หญ้าแห้งตาย ใบไม้ร่วงหล่น มันก็คล้ายๆ กับการเป็นสัตว์เลื้อยคลานล่ะนะ เธอต้องลอกคราบเพื่อที่จะเติบโตขึ้นน่ะ$7#$b#อีเมอริทัส (Emeritus) ลอกคราบไหมนะ?$23",
  // WINTER
  "Core.Hector.Winter.Relationship.Platonic.1": "ความหนาวเหน็บของฤดูหนาวนั้นเย็นยะเยือกไปถึงกระดูก แต่การมีเธออยู่ด้วยก็ทำให้ฉันอุ่นขึ้นมาได้ทันทีเลยล่ะ$7#$b#ฉันรู้สึกเหมือนเธอชอบมองฉันแปลกๆ เวลาฉันพูดอะไรดีๆ แฮะ$8",
  "Core.Hector.Winter.Relationship.Platonic.2": "บุ๊คบอกให้ฉันเอาของนี่มาให้เธอน่ะ มันสำคัญมากเลยนะ[390]$13",
  "Core.Hector.Winter.Relationship.Platonic.3": "บางทีฉันก็คิดนะว่าฉันคงไม่ได้เป็นฉันในตอนนี้หรอกถ้าไม่ใช่เพราะเธอ$12#$b#แล้วฉันก็คิดได้ว่า เธอเองก็คงจะได้ยินประโยคนี้จากมาเทโอเหมือนกัน$13#$b#นั่นก็หมายความว่าเธอเป็นคนที่ดีมากๆๆ เลยล่ะ$14",
  "Core.Hector.Winter.Relationship.Platonic.4": "เธอนี่มีความเห็นอกเห็นใจผู้อื่นสูงจัง บางทีฉันก็แอบกังวลนะ - ในอดีตเคยมีใครทำร้ายเธอหรือเปล่า?$2#$b#เธอใส่ใจคนอื่นอย่างลึกซึ้งมากเลย ฉันแค่สงสัยน่ะว่ามันมาจากไหน$23",
  "Core.Hector.Winter.Relationship.Platonic.5": "ฉันรู้ว่าเธอไม่ค่อยมีงานฟาร์มให้ทำเท่าไหร่หรอกนะ แต่เธอเห็นแล้วใช่ไหมว่าเกิดอะไรขึ้นกับมาเทโอ การใช้เวลาในเหมืองมากเกินไปจะทำให้เธอขาดแสงแดดได้นะ$7",
  "Core.Hector.Winter.Relationship.Platonic.6": "ปกติแล้ว ฉันรักฤดูหนาวนะ แต่บางทีอาจจะเป็นเพราะฉันชอบที่จะมีข้ออ้างให้อยู่สันโดษก็ได้ล่ะมั้ง$7#$b#แต่อดไม่ได้ที่จะตั้งตารอฤดูใบไม้ผลิล่ะนะ เวลาที่ทุกคนออกมาใช้ชีวิตกันข้างนอกน่ะ$1",
  "Core.Hector.Winter.Relationship.Platonic.7": "ฉันกล่อมให้เอลัวส์มาช่วยฉันสร้างกองทัพหิมะตัวป่วน (Snowgoon) ได้แล้วล่ะ ดีใจจังที่เธอมีพรสวรรค์เรื่องการแกล้งคนน่ะ$1#$b#มาเทโอตื่นมาเจอฉากนี้ต้องสะดุ้งแน่ๆ$9",
  // 10H ROMANTIC
  // SPRING
  "Core.Hector.Spring.Relationship.Romantic.1": "โอ้ ไง แสงแดดอุ่นๆ ของฉัน พอได้เจอเธอ โลกมันก็ดูสว่างไสวขึ้นนิดหน่อย อบอุ่นขึ้นนิดนึงล่ะนะ เป็นยังไงบ้างล่ะ?$12",
  "Core.Hector.Spring.Relationship.Romantic.2": "วิธีที่เธอดูแล %farm น่ะ มันเป็นแรงบันดาลใจได้ดีเลยนะ วิธีที่เธอปลุกเสกชีวิตจากผืนดินได้โดยไม่ต้องพึ่งเวทมนตร์น่ะ...$14#$b#ฉันเดาว่าเธอคงจะเก่งกว่าฉันล่ะมั้ง เพราะฉันขี้โกงใช้เวทมนตร์กับต้นไม้ของฉันนี่นา$8",
  "Core.Hector.Spring.Relationship.Romantic.3": "เอลัวส์เล่าให้ฉันฟังว่านอกจากนาก (Otters) จะมีกระเป๋าหน้าท้องไว้เก็บหินก้อนโปรดแล้ว พวกมันยังจับมือกันตอนงีบหลับด้วยนะ จะได้ไม่ลอยห่างจากกันน่ะ$10[390]",
  "Core.Hector.Spring.Relationship.Romantic.4": "ทุกครั้งที่ฉันเห็นดอกไม้ที่บานอยู่ทั่วเมือง ฉันจะนึกถึงเธอนะ ทั้งงดงาม อ่อนโยน...$10#$b#คืนนี้เธอจะแสดงให้ฉันเห็นหน่อยไหม ว่าความอ่อนโยนนั้นมันสิ้นสุดลงตรงไหน @?$11",
  "Core.Hector.Spring.Relationship.Romantic.5": "วันนี้เอดีนพาบารอน มันชิงตัน (Baron Munchington) มาฉีดวัคซีนด้วยล่ะ$7#$b#เขาบอกว่าเขาไม่จำเป็นต้องฉีดหรอกนะ เพราะเขามีศักดิ์เป็นถึงเชื้อพระวงศ์ ก็นะ ฉันเลยรีบบอกเขาไปว่าฉันเป็นพวกอนาธิปไตยน่ะสิ$9",
  "Core.Hector.Spring.Relationship.Romantic.6": "บุ๊คเรียกร้องอยากให้เธอมาอยู่น่ะ แวะมาหาเธอหน่อยนะ โอเคไหม? โดยเฉพาะอย่างยิ่งถ้าเธอว่างตอนที่ฉันไปทำงานน่ะ$8",
  "Core.Hector.Spring.Relationship.Romantic.7": "เราเล่นบอร์ดเกมกันเมื่อคืนก่อน ฉันลองจีบมังกรดู แต่มันไม่ได้ผลหรอก มาเทโอไม่รู้จักหรอกนะว่าความสนุกคืออะไร พวกเขาไม่รู้จักความโรแมนติกหรอก ต่อให้มันพุ่งชนหน้าก็เถอะ$16",
  // SUMMER
  "Core.Hector.Summer.Relationship.Romantic.1": "ฉันจะบ่นเรื่องอากาศร้อนให้ฟังก็ได้นะ หรือจะบอกว่ามันคูล (Cool) แค่ไหนที่ได้อยู่กับเธอก็ได้เหมือนกัน$11#$b#โธ่ มันไม่ตลกเลยแฮะ ฉันพยายามแล้วนะ$25",
  "Core.Hector.Summer.Relationship.Romantic.2": "เธอ ฉัน ซอร์เบต์ คืนเดตของเรา จัดไปเลย$8#$b#แต่เราจะไปร้านไอศกรีมโดยไม่ซื้อกลับมาฝากเอลัวส์ไม่ได้หรอกนะ นั่นคือกฎเหล็กเลยล่ะ$14",
  "Core.Hector.Summer.Relationship.Romantic.3": "โอเค สิ่งหนึ่งที่ฉัน *ชอบ* เกี่ยวกับฤดูร้อนก็คือ ชุดว่ายน้ำมันทำให้ฉันรู้สึกว่าตัวเองสวย และฉันก็ชอบใส่มันด้วยสิ$9",
  "Core.Hector.Summer.Relationship.Romantic.4": "เธอรู้ไหม ว่าถ้าเธอแบ่งเจ้านี่ให้ใครสักคน พวกเธอสองคนจะถูกกำหนดให้คู่กันตลอดไปนะ$10[268]#$b#มันก็เป็นแค่เรื่องเล่าปรัมปราแหละ แต่... ฉันก็ไม่รังเกียจหรอกนะถ้ามันจะเป็นเรื่องจริง$11",
  "Core.Hector.Summer.Relationship.Romantic.5": "นี่ฉันแค่รู้สึกอยากเป็นหมาป่านิดหน่อย หรือว่าเธอดูน่ากินเกินไปกันแน่นะ @?$10",
  "Core.Hector.Summer.Relationship.Romantic.6": "ฉันรักรอยยิ้มของเธอจัง @ มันทำให้ทั้งห้องสว่างไสวขึ้นมาเลยนะ$12#$b#...อะไรเล่า? การที่ฉันชมเธอขึ้นมาดื้อๆ มันดูแปลกเหรอ?$8",
  "Core.Hector.Summer.Relationship.Romantic.7": "เอลัวส์ให้ฉันยืมกล้องส่องทางไกลสำรองของเธอด้วยล่ะ เราจะได้ไปดูนกกัน มันยากนะที่จะนั่งนิ่งๆ และเงียบๆ น่ะ แต่เพื่อเธอ ฉันจะทำนะ$14#$b#ฉันอยากให้เธอไปด้วยกันกับเรานะ @ ฉันว่ามันน่าจะดีเลยล่ะ$12",
  // FALL
  "Core.Hector.Fall.Relationship.Romantic.1": "ได้คืบจะเอาศอกน่ะ - ฉันบอกมาเทโอว่าจะดูหนังกับพวกเขา แล้วตอนนี้พวกเขาก็ดันอยากจะแต่งชุดคู่กันไปงานสปิริตส์อีฟซะงั้น เธอ ฉัน พวกเขา - ทหารเสือทั้งสามงั้นเหรอ? $8",
  "Core.Hector.Fall.Relationship.Romantic.2": "ถ้าฉันสามารถมอบชีวิตคืนให้กับสัตว์ทุกตัวที่เจค็อบสูญเสียไประหว่างทำงานได้ล่ะก็ ฉันก็จะทำนะ$21#$b#ไม่ใช่เพราะว่าฉันไม่เชื่อในวัฏจักรชีวิตหรอกนะ แต่เป็นเพราะการสูญเสียมันทำให้เขาเศร้า และฉันก็ไม่อยากให้เขาเศร้าน่ะ$25",
  "Core.Hector.Fall.Relationship.Romantic.3": "มันเป็นฤดูเก็บเกี่ยวนะ และฉันก็รู้สึกขอบคุณในสิ่งที่เธอและฉันได้ร่วมกันฟูมฟักมา$10#$b#แต่ฉันอยากเห็นเธออยู่บนเตียงของฉันมากกว่าบนทุ่งดอกทานตะวันนะ$11",
  "Core.Hector.Fall.Relationship.Romantic.4": "แม้ว่าทุกสิ่งจะแปรเปลี่ยนไป แต่ฉันกลับรู้สึกมั่นคงมากเลยล่ะ$14#$b#ฤดูใบไม้ร่วงช่วยเตือนใจว่าความตายเป็นส่วนหนึ่งของชีวิต",
  "Core.Hector.Fall.Relationship.Romantic.5": "ฉันปลูกแล้วก็แกะสลักเจ้านี่ให้มาเทโอน่ะ แต่พวกเขาก็คงจะทำซึ้งใส่อีกแหงๆ เธอเอาไปให้พวกเขาแทนได้ไหม?[746]",
  "Core.Hector.Fall.Relationship.Romantic.6": "ที่รัก ฉันชักจะติดใจรสชาติของเธอเข้าแล้วสิ อยากรู้ไหมว่ามันจะไปได้ไกลแค่ไหน?#$b#อยากจะลองดีกับฉันเหรอ ที่รัก? เธอต้องบ้าไปแล้วแน่ๆ ถ้าคิดว่าฉันจะยอมจำนนง่ายๆ น่ะ$3",
  "Core.Hector.Fall.Relationship.Romantic.7": "อยากรู้จังว่าเอลัวส์จะแต่งเป็นอะไรในงานสปิริตส์อีฟ คงจะเป็นนกแหงๆ นี่ฉันหลอกใครอยู่เนี่ย$8#$b#บางทีฉันอาจจะเกลี้ยกล่อมให้เธอแต่งเป็นไดโนเสาร์ได้นะ พวกมันก็ เอ่อ คล้ายๆ นกใช่ไหมล่ะ? ใช่ไหม?$9",
  // WINTER
  "Core.Hector.Winter.Relationship.Romantic.1": "เวลาที่ฉันคิดถึงเธอ ฉันนึกถึง... ผ้าห่มนุ่มๆ อุ่นๆ ที่ฉันไม่อยากจะปล่อยมือไปไหนเลยล่ะ$12#$b#ขอบใจนะที่มอบความอบอุ่นแบบนั้นให้ฉันน่ะ$10",
  "Core.Hector.Winter.Relationship.Romantic.2": "กาแฟสักหน่อยสำหรับคนโปรดของฉันนะ[250]$13#$b#อย่าไปตากอากาศหนาวจนป่วยซะล่ะ ไม่งั้นฉันก็ต้องมาคอยดูแลเธอ ซึ่งมันจะ 'แย่สุดๆ' ไปเลย$11",
  "Core.Hector.Winter.Relationship.Romantic.3": "ฉันคงไม่ได้เป็นฉันในตอนนี้หรอกถ้าไม่ใช่เพราะเธอ ฉันมั่นใจเรื่องนั้นเลยล่ะ$12#$b#พนันได้เลยว่าเธอคงเคยได้ยินประโยคนี้จากมาเทโอเหมือนกัน นั่นก็หมายความว่าเธอเป็นคนที่ดีมากๆๆ เลยล่ะ และฉันก็โชคดีมากที่ได้เรียกเธอว่าที่รักของฉัน$11",
  "Core.Hector.Winter.Relationship.Romantic.4": "ถ้ามีใครมาทำให้เธอเสียใจล่ะก็ เธอรู้ใช่ไหมว่าฉันจะกินมันซะ?$8#$b#แล้วฉันก็จะเอากระดูกพวกมันมาแคะฟันด้วย รุนแรงเหรอ? อะไรกัน? โรแมนติกจะตายไป!$9",
  "Core.Hector.Winter.Relationship.Romantic.5": "เธอมีเรือนกระจกใช่ไหม? บางทีน่าจะไปโฟกัสตรงนั้นมากกว่าลงเหมืองนะ เธอคงไม่อยากจบลงด้วยการขาดแสงแดดจนเฉาเหมือนที่มาเทโอเคยเป็นหรอกใช่ไหม$12",
  "Core.Hector.Winter.Relationship.Romantic.6": "ฉันคิดว่าฉันชอบฤดูหนาวก็แค่เพราะความหนาว และเพราะมันทำให้ฉันได้อยู่สันโดษตามที่ต้องการล่ะมั้ง$7#$b#แต่ตอนนี้ฉันตั้งตารอฤดูใบไม้ผลิล่ะนะ เวลาที่ทุกคนออกมาใช้ชีวิตกันข้างนอกน่ะ$1",
  "Core.Hector.Winter.Relationship.Romantic.7": "ฉันเตรียมของขวัญสนุกๆ ไว้ให้เธอ เอลัวส์ เจค็อบ แล้วก็มาเทโอสำหรับงาน Winter Star ด้วยนะ... มันเป็นของขวัญที่ดีไหมน่ะเหรอ ในแง่ความเป็นกลาง? คงไม่อ่ะ แต่มัน *สนุก* แน่ๆ! $9",
  // MARRIED - SPRING 
  "Marriage.Hector.GoodWeather.1": "พูดจริงๆ นะ ฉันรักการทำงานที่คลินิกรักษาสัตว์ล่ะ ฉันจินตนาการภาพตัวเองไปทำอย่างอื่นไม่ออกเลย$1",
  "Marriage.Hector.GoodWeather.2": "ฉันกำลังคิดว่าจะจัดมื้อค่ำให้เธอ เจค็อบ แล้วก็เอลัวส์น่ะ แต่ฉันว่าเจค็อบคงไม่ค่อยชอบหอคอยนี้เท่าไหร่หรอก$23",
  "Marriage.Hector.GoodWeather.3": "นี่ ถ้าฉันทำความสะอาดโรงนาให้เจค็อบเสร็จแล้ว จะให้ฉันไปช่วยเธอไหม? ฉันว่าเธอจัดการเองได้แหละ แต่ถามเผื่อไว้ก่อนน่ะ$8",
  "Marriage.Hector.GoodWeather.4": "สปริงเกอร์นี่มันอัจฉริยะจริงๆ ฉันจินตนาการไม่ออกเลยว่าเธอจะจัดการรดน้ำทุกอย่างที่ปลูกไว้ด้วยมือได้ยังไง$7",
  "Marriage.Hector.GoodWeather.5": "ที่รัก (deer-ly beloved) ของฉัน วันนี้เป็นยังไงบ้างล่ะ?$1",
  "Marriage.Hector.GoodWeather.6": "หวังว่าเธอจะทำงานเท่าที่จำเป็นนะ ไม่ใช่ทำจนเหนื่อยสายตัวแทบขาดน่ะ$8",
  "Marriage.Hector.GoodWeather.7": "นี่ จุ๊บเหม่ง %pet เผื่อฉันด้วยนะ โอเคไหม?$8",
  "Marriage.Hector.GoodWeather.8": "เธอได้ทุกอย่างที่เป็นฉันไปแล้วนะ @ - ทั้งหัวใจ ร่างกาย และจิตวิญญาณ แล้วเธออยากจะทำอะไรกับมันล่ะ?$11",
  "Marriage.Hector.GoodWeather.9": "รู้ไหม ตรงทางรถไฟมีบ่อน้ำพุร้อนอยู่ด้วยนะ จะเป็นยังไงนะถ้าเรา...?$11",
  "Marriage.Hector.GoodWeather.10": "พนันได้เลยว่าเธอต้องดูดีมากแน่ๆ ตอนที่โดนดันแนบกับหน้าต่างหอคอยน่ะ @$11",
  "Marriage.Hector.GoodWeather.11": "@ ฉันคิดว่าเธอเป็นมากกว่าแค่คนที่ฉันถูกกำหนดมาให้พบเจอนะ$10",
  "Marriage.Hector.GoodWeather.12": "ความรักของฉันคือเสียงเพรียกของสัตว์ป่า แหวกผ่านความมืดมิด สะท้อนก้องไปตามกำแพง$3",
  "Marriage.Hector.GoodWeather.13": "เธอจะตามฉันมา ท่ามกลางขากรรไกรแห่งโชคชะตาไหม @? ไม่ว่ามันจะหมายความว่ายังไงก็ตามน่ะ?$11",
  "Marriage.Hector.GoodWeather.14": "ฉันอยากให้เธอเติมเต็มฉันนะ @ ฉันไม่เคยรู้สึกพอเลยเมื่อเป็นเรื่องของเธอ$11",
  "Marriage.Hector.GoodWeather.15": "อืม ฉันว่าฉันเลิกต่อต้านความเปลี่ยนแปลงแล้วล่ะ นี่คือชีวิตของฉันในตอนนี้ และฉันก็มีความสุขกับมัน มีความสุขกับเธอนะ$12",
  "Marriage.Hector.GoodWeather.16": "หุบเขานี้เป็นสถานที่ที่สวยงามนะ ฉันรู้ว่าสำหรับบางคนมันเหมือนเป็นกับดัก แต่พวกเขาแค่ไม่ได้มองเห็นมันในแบบที่ฉันเห็นต่างหาก$14",
  "Marriage.Hector.GoodWeather.17": "ท่องเที่ยวเหรอ? ออกไปนอกหุบเขางั้นสิ? ไม่ล่ะ คงจะไม่ ฉันไม่รู้เลยว่าการต้องอยู่ห่างจาก The Grove ไกลขนาดนั้นจะส่งผลยังไงบ้าง ต่อให้เป็นแค่ช่วงเวลาสั้นๆ ก็เถอะ$23",
  "Marriage.Hector.GoodWeather.18": "ฉันชอบไปหาผลไม้ป่ากับเห็ดตอนที่ถึงฤดูของมันนะ เธอควรจะไปด้วยกันกับฉันสิ$1",
  "Marriage.Hector.GoodWeather.19": "ฉันจะเข้าเมืองก็ต่อเมื่อมีเธอไปด้วยเท่านั้นแหละ ฉันสบายใจเวลาอยู่ที่ The Scarp ก็จริง แต่ฉันแทบไม่รู้จักใครในเมืองเพลิแกนเลยนะ$4",
  "Marriage.Hector.GoodWeather.20": "เธอคือตอนจบแสนสุขของฉันนะ @$15",
  "Marriage.Hector.GoodWeather.21": "รู้ไหม @... เวลาที่ฉันมองเธอ ฉันรู้สึกผูกพันไปถึงจิตวิญญาณเลยนะ$15",
  "Marriage.Hector.GoodWeather.22": "ที่รัก (deer-ly beloved) ของฉัน วันนี้เป็นยังไงบ้างล่ะ? มีอะไรให้ฉันช่วยไหม?$12",
  "Marriage.Hector.GoodWeather.23": "มีหลายอย่างเลยนะที่ฉันรักในตัวเธอ$12#$b#แต่... ฉันก็รักที่เธอทำให้ฉันรู้สึกคู่ควร *กับ* ความรักด้วย$13",
  "Marriage.Hector.GoodWeather.24": "บางทีฉันก็คิดนะ ว่าจริงๆ แล้วเธอไม่รู้ตัวเลยว่าตัวเองน่ะสุดยอดแค่ไหน$8#$b#เธอควรเริ่มส่องกระจกแล้วก็ชมตัวเองบ้างนะ! สำหรับฉันน่ะมันได้ผลนะ$9",
  "Marriage.Hector.GoodWeather.25": "วัฏจักรแห่งความสงสัยในตัวเองอันแสนเหนียวหนืด มันจบลงตั้งแต่วินาทีที่เธอยิ้มให้ฉันแล้วล่ะ$10",
  "Marriage.Hector.GoodWeather.26": "มันน่าจะมีคำอุปมาเซ็กซี่ๆ อะไรทำนองนั้นนะ เรื่องที่เธอแปลงร่างเป็นกวางส่วนฉันเป็นหมาป่าน่ะ? แต่ฉันนึกไม่ออกแฮะ...$8",
  "Marriage.Hector.GoodWeather.27": "มันจะฟังดูเป็นคำชมที่แปลกไหม ถ้าจะบอกว่าเธอทำให้ฉันรู้สึก... ปลอดภัย?$13",
  "Marriage.Hector.GoodWeather.28": "ฉันล่ะอยากให้หุบเขานี้มีแวดวงดนตรีที่คึกคักกว่านี้จัง$17#$b#ฉันจะได้พาเธอไปดูคอนเสิร์ตบ่อยๆ ตอนนี้เราก็เลยต้องทนเต้นไปกับเพลงจากวิทยุไปก่อนล่ะนะ$19",
  "Marriage.Hector.GoodWeather.29": "%Hector ดึงคุณเข้าไปจูบอย่างดูดดื่มโดยไม่ทันตั้งตัว ก่อนจะผละออกไป",
  "Marriage.Hector.GoodWeather.30": "ในเมื่อฉันก็ทำงานบ้านให้เจค็อบเยอะอยู่แล้ว ถ้าเธออยากให้ฉันไปช่วยงานที่ฟาร์มบ้างก็บอกได้เลยนะ ฉันจัดสรรเวลาให้ได้$1",
  "Marriage.Hector.GoodWeather.31": "ทุกครั้งที่ฉันเห็นดอกไม้ที่บานอยู่ทั่วเมือง ฉันจะนึกถึงเธอนะ ทั้งงดงาม อ่อนโยน...$10#$b#คืนนี้เธอจะแสดงให้ฉันเห็นหน่อยไหม ว่าความอ่อนโยนนั้นมันสิ้นสุดลงตรงไหน @?$11",
  "Marriage.Hector.GoodWeather.32": "สัตว์ของเธอรักเธอมากเลยนะ @ เราเม้าท์มอยเรื่องนี้กันบ่อยเลยล่ะ$1",
  "Marriage.Hector.GoodWeather.33": "ฉันรู้สึกอยากงีบแฮะ เธอว่าไง? อยากมานอนด้วยกันไหม?$8",
  "Marriage.Hector.GoodWeather.34": "เฮอร์ดี้-เกอร์ดี้ (Hurdy gurdy) เหรอ? เสียงมันอาจจะไม่ได้โรแมนติก *ที่สุด* หรอกนะ แต่ฉันก็เล่นให้เธอฟังได้นะ ไม่แน่ใจเหมือนกันว่าเธอชอบอะไรแบบนี้หรือเปล่าน่ะ$4",
  "Marriage.Hector.GoodWeather.35": "ฉันรักเธอมากนะ แต่สำหรับฉัน การกระทำมันง่ายกว่าคำพูดน่ะ - เพราะงั้นให้ฉันพิสูจน์ให้ดูนะ$11",
  "Marriage.Hector.GoodWeather.36": "%farm ดูยอดเยี่ยมไปเลย เธอลงแรงไปกับมันเยอะจริงๆ เธอนี่น่าทึ่งมากเลยนะ @$8",
  "Marriage.Hector.GoodWeather.37": "ฉันรู้สึกว่าตัวเองพลังเหลือล้นเลยล่ะ เธอมาช่วยทำให้ฉันหมดแรงหน่อยดีไหม หืม?$11",
  "Marriage.Hector.Spring1": "ปีใหม่! รู้สึกสดชื่นจัง พลังงานเหลือล้นเลย รู้สึกไฮเปอร์นิดๆ แฮะ รู้ไหม ถ้าเธอรู้สึกแบบเดียวกัน เราก็สามารถหาอะไรทำเพื่อปลดปล่อยมันได้นะ$11",
  "Marriage.Hector.Spring13": "โอเค คือฉันมีแผนใหญ่ว่าจะโกงงานเทศกาลพรุ่งนี้นิดหน่อย เพื่อให้เอลัวส์ชนะล่ะ...$9",
  "Marriage.Hector.Spring23": "แน่นอนสิ ฉันจะเต้นรำกับเธอ ไม่ต้องห่วงหรอกว่าฉันจะงอแงน่ะ$12",
  "Marriage.Hector.Spring24": "การไปเต้นแร้งเต้นกากับพวกคนเด๋อๆ มันใช่สิ่งที่ฉันอยากทำไหม? ไม่หรอก แต่ฉันยอมทำเพื่อเธอไหม? แน่นอน$10",
  "Marriage.Hector.Spring28": "นี่ ใกล้จะเข้าหนาวร้อนแล้ว นั่นหมายความว่าเธอจะใส่เสื้อผ้าน้อยชิ้นลงเวลาอยู่ใกล้ๆ หรือเปล่า-?$10#$b#อะไรเล่า จะโทษฉันที่ถามได้ไง?$11",
  "Marriage.Hector.Summer": "รู้กันแค่สองคนนะ ถ้าฉันสามารถเดินเพ่นพ่านไปมาด้วยชุดชั้นในตัวเดียวเพื่อรับมือกับอากาศร้อนได้ล่ะก็ ฉันทำไปแล้ว$4",
  "Marriage.Hector.Summer1": "ข้างนอกอากาศเหนอะหนะชะมัด! แต่ไม่เป็นไรหรอก ฉันก็อยากจะเหนอะหนะกับเธอให้มากกว่านี้เหมือนกัน$9",
  "Marriage.Hector.Summer11": "จริงๆ แล้ว ฉันจะเอาผลไม้โบราณ (Ancient berries) ของฉันใส่ลงไปในซุปด้วยแหละ ฉันอาจจะทำให้มันวุ่นวายสุดๆ ไปเลยก็ได้นะ แต่ฉันว่าเราสองคนคงไม่อยากป่วยหลังจากกินเสร็จหรอก$8",
  "Marriage.Hector.Summer28": "เธออยากจะ... จับมือกันที่งานเทศกาลระบำแมงกะพรุน (Moonlight Jellies) ไหม?#4",
  "Marriage.Hector.Fall": "อะไรสักอย่าง พัมพ์กิ้นสไปซ์ (Pumpkin Spice) อะไรสักอย่าง พายแอปเปิ้ล (Apple Pie) อะไรสักอย่าง มาเทโอช่างน่ารำคาญสุดๆ ในช่วงเวลานี้ของปี$8",
  "Marriage.Hector.Fall1": "ฤดูกาลนี้เธอวางแผนจะปลูกอะไรเหรอ @? มีอะไรน่าสนุกบ้างไหม? หมายถึง พวกพืชผลหลักๆ ก็ดีนะ อย่างแครนเบอร์รี่ ทานตะวัน ฟักทอง...$12",
  "Marriage.Hector.Fall15": "ฉันควรจะแอบเอาของไปให้เธอประกวดในงานแฟร์ดีไหม? คงไม่ดีกว่า ช่างเถอะ ฉันก็ไม่ได้แปลกหน้าอะไรกับการโกงการแข่งขันซะหน่อย$7[454]",
  "Marriage.Hector.Fall16": "โชคดีนะ! ฉันมั่นใจว่าวันนี้เธอต้องชนะแน่ๆ ถ้าไม่ล่ะก็ ฉันจะไปแบล็กเมล์นายกเทศมนตรีเอง!$9",
  "Marriage.Hector.Fall25": "วันนี้วันเกิดมาเทโอ ไปแกล้งพวกเขาหรือทำอะไรสักอย่างสิ$12",
  "Marriage.Hector.Fall26": "รู้ไหม ฉันนึกเรื่องสนุกๆ ที่เราทำกันในเขาวงกตพรุ่งนี้ได้ตั้งหลายอย่างเลยนะ$11",
  "Marriage.Hector.Fall27": "คืนนี้เธอตื่นเต้นไหม? ฉันก็ตื่นเต้นเหมือนกันนะ$10#$b#ไม่ใช่แค่เพราะลูกอม งานฉลอง หรืออะไรพวกนั้นหรอก ฉันมีแผนสำหรับเธอต่างหาก$11",
  "Marriage.Hector.Winter": "นี่ @ ทำตัวให้อบอุ่นเข้าไว้นะ เข้าใจไหม? แต่ถ้าเธอหนาวล่ะก็ เตียงแล้วก็อ้อมกอดของฉันพร้อมต้อนรับเธอเสมอนะ$10",
  "Marriage.Hector.Winter1": "มาเทโอจะจัดเล่นบอร์ดเกมอีกแล้วล่ะ ฉันเดาว่าคงเพื่อบรรเทาอาการซึมเศร้าของพวกเขาน่ะแหละ เธอควรจะมาด้วยกันนะ @ นั่นคือสิ่งที่เพื่อนเขาทำกันน่ะ$7",
  "Marriage.Hector.Winter8": "ฉันเกลียดเทศกาลตกปลานั่นชะมัด มันทั้งห่วยทั้งงี่เง่า ฉันจะไปหาเรื่องนายกเทศมนตรีของเธอเรื่องนี้แหละ$23",
  "Marriage.Hector.Winter8.Filtered": "ฉันเกลียดเทศกาลตกปลานั่นชะมัด มันทั้งงี่เง่าและโหดร้าย ฉันจะไปหาเรื่องนายกเทศมนตรีของเธอเรื่องนี้แหละ$23",
  "Marriage.Hector.Winter14": "สงสัยจังว่าฉันจะหาซื้อเมล็ดพันธุ์นำเข้าที่ตลาดกลางคืนได้ไหมนะ$12",
  "Marriage.Hector.Winter24": "หาซื้อของขวัญให้เธอนี่มันยากจังแฮะ @ แต่ไม่ต้องห่วงไปหรอก ฉันมีของขวัญในใจให้เธอแล้วล่ะ$10",
  "Marriage.Hector.Winter25": "เอาจริงๆ นะ ของขวัญของเธอคือการที่ฉันไปปรากฏตัวที่งานเทศกาลไง ...ไม่ๆ ล้อเล่นน่ะ ของขวัญของเธอรออยู่ *หลังจาก* งานเทศกาลต่างหาก$11",
  "Marriage.Hector.Winter28": "ผ่านไปอีกปีแล้วสินะ? อืม ถ้าให้มองย้อนกลับไป ฉันรู้ดีว่าปีนี้ของฉันมันดีขึ้นมากเลยล่ะที่มีเธออยู่ในนั้นด้วย$15",
  // MARRIED - BAD WEATHER 
  "Marriage.Hector.BadWeather.1": "นี่เธอพกร่มบ้างไหม หรือแค่ชอบวิ่งตากฝนจนเปียกโชกไปทั้งวันกันแน่?$8",
  "Marriage.Hector.BadWeather.2": "ไม่ได้จะฟังดูน้ำเน่าหรอกนะ แต่ฉันชอบเสียงฝนที่ตกกระทบหน้าต่างหอคอยจัง มันสมบูรณ์แบบมากเลยล่ะ$14",
  "Marriage.Hector.BadWeather.3": "วันนี้ฉันน่าจะอ่านหนังสือสักหน่อยแฮะ บรรยากาศมันให้เลย ว่าไหม?$12#$b#ฉันกำลังอ่านนิยายสยองขวัญแนวชีววิทยาเกี่ยวกับหอคอยกลับหัวอยู่น่ะ$8",
  "Marriage.Hector.BadWeather.4": "วันนี้ฉันทำงานบ้านให้เจค็อบกับเอลัวส์ตั้งเยอะแน่ะ อยากให้ฉันแวะไปที่ฟาร์มเพื่อช่วยเธอทำความสะอาดบ้างไหม?$12",
  "Marriage.Hector.BadWeather.5": "โชคร้ายจังที่พวกสัตว์ต้องอยู่แต่ข้างในเวลาอากาศแย่น่ะ เอาเถอะ ก็เพื่อสุขภาพที่ดีของพวกมันล่ะนะ$12",
  "Marriage.Hector.BadWeather.6": "ไดโนเสาร์ของมาเทโอ - อีเมอริทัสน่ะเหรอ? - กลัวฟ้าร้องกับฟ้าผ่าสุดๆ ไปเลย น่าสงสารจัง$2",
  "Marriage.Hector.BadWeather.7": "ฉันรักเธอนะ รู้ใช่ไหม ต่อให้เธอจะดูเหมือนแมวตกน้ำในอ่างอาบน้ำก็เถอะ$8",
  "Marriage.Hector.BadWeather.8": "สิ่งเดียวที่ฉันรักมากกว่าฝน ก็คือความเปียกปอนนี่แหละ$11",
  "Marriage.Hector.BadWeather.9": "ฉันคงจะโกหกถ้าบอกว่าฉันไม่ได้ชอบเวลาเห็นเธอเปียกโชกสักนิดนึงน่ะ$11",
  "Marriage.Hector.BadWeather.10": "ข้างนอกพายุเข้าแฮะ เรามาสร้างเสียงดังของเราเองบ้างดีไหม หืม?$11",
  "Marriage.Hector.BadWeather.11": "อืม @ ฉันพนันได้เลยว่าตอนนี้รสชาติของเธอต้องดีพอๆ กับหน้าตาแน่ๆ อยากให้ฉันลองชิมดูสักคำไหม?$11",
  "Marriage.Hector.BadWeather.12": "ให้ฉันช่วยถอดเสื้อผ้าเปียกๆ พวกนั้นออกให้นะ @ โอ๊ะ ไม่นะ ฉันไม่มีเสื้อผ้าให้เธอเปลี่ยนเลย แย่จัง$11",
  "Marriage.Hector.BadWeather.13": "เธอดูกำลังยุ่งอยู่นะ$10#$b#มาทำตัว 'ยุ่ง' กับฉันแทนสิ$11",
  "Marriage.Hector.BadWeather.14": "คืนนี้ให้ฉันพาเธอกลับบ้านนะ @ ทำให้ฉันเห็นทีว่าเธอเป็นยังไง ฉันล่ะอยากรู้ใจจะขาดอยู่แล้ว$11",
  "Marriage.Hector.BadWeather.15": "ฉันรักเธอมากนะ แต่สำหรับฉัน การกระทำมันง่ายกว่าคำพูดน่ะ - เพราะงั้นให้ฉันพิสูจน์ให้ดูนะ$11",
  // ENGAGEMENT DIALOGUE 
  "Marriage.Hector.Engagement.Hector0": "ถ้าตอนที่เราเจอกันครั้งแรก เธอมาบอกฉันว่าสุดท้ายแล้วเราจะลงเอยกันแบบนี้ล่ะก็ ฉันคงไม่เชื่อหรอก นี่มันให้ความรู้สึกเหมือนกำลังฝันอยู่เลยแฮะ$4",
  "Marriage.Hector.Engagement.Hector1": "ยอมรับเลยนะ ว่าการต้องมาแต่งงานต่อหน้าคนตั้งเยอะแยะที่ฉันไม่รู้จักเนี่ย มันก็ทำเอาฉันประหม่านิดหน่อยเหมือนกันนะ$4",
