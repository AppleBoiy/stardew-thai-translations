  // NAME & INTRO 
  "Core.Mateo.Name.Mateo": "มาเทโอ (Mateo)",
  "Core.Mateo.Name.Val": "แวร์ (Val)",
  "Core.Mateo.Name.Tay": "เทย์ (Tay)",
  "Core.Mateo.Introduction": "ไง ชาวไร่ รู้ไหมว่าทำไมนักโบราณคดีถึงล้มละลาย?$0#$b#ก็เพราะอาชีพการงานเขามันมีแต่เรื่อง 'ขุดค้น' (Ruins) ไงล่ะ$1",
  // COMMUNITY CENTER BUNDLES  
  "Core.Mateo.JojaBegin": "ไม่อยากจะเชื่อเลยว่าโจจ้ามาร์ทจะทุบศูนย์ศาลาว่าการทิ้ง ไอ้พวกทุนนิยมหน้าเลือดเอ๊ย$11#$b#การปล่อยให้พวกนั้นเหยียบย่ำชุมชนเล็กๆ แบบนี้นี่แหละ คือวิธีที่ทำให้พวกมันยังคงเติบโตขึ้นเรื่อยๆ$9",
  "Core.Mateo.CCBegin": "นายกำลังจะเริ่มฟื้นฟูศูนย์ศาลาว่าการงั้นเหรอชาวไร่? เป็นความพยายามที่น่ายกย่องมาก โชคดีนะ$32",
  "Core.Mateo.CCBus": "รถบัสนั่นจะช่วยให้เดินทางไปทะเลทรายง่ายขึ้นเยอะเลย$1#$b#ไม่งั้นคงต้องเดินทางกันยาวไกลเลยล่ะ... เก่งมากเลยนะ @! นายนี่มันทำให้เมืองกลับมารุ่งเรืองเหมือนเมื่อก่อนจริงๆ$32",
  "Core.Mateo.CCMinecart": "พอนายซ่อมรถรางกลับมาใช้งานได้แล้ว ชีวิตนายคงจะง่ายขึ้นเยอะเลยนะ$14#$b#ถึงจะมีม้าก็เถอะ แต่นายก็ยังมีพื้นที่อีกกว้างมากที่ต้องไปสำรวจ ทำได้ดีมาก @$1",
  "Core.Mateo.CCComplete": "ศูนย์ศาลาว่าการดูยอดเยี่ยมไปเลย! แล้วนั่นเป็นผลงานของนายทั้งหมดเลยเหรอ @? $1#$b#เหลือเชื่อจริงๆ นายทำผลงานได้สุดยอดมาก! ดีใจที่ได้เห็นมันกลับมาใช้งานได้อีกครั้งนะ$80",
  "Core.Mateo.MovieTheater": "อยากไปดูหนังไหม @? ฉันเลี้ยงเอง ถือซะว่าเลี้ยงที่นายยอมเหนื่อยยากสร้างมันขึ้นมาจากซากปรักหักพังนั่น$1#$b#ไม่มีอะไรจะดีต่อสุขภาพเส้นเลือดไปกว่าการใช้เวลายามเย็นไปกับการกินป๊อปคอร์นอีกแล้วล่ะ!$32",
  // BIRTHDAYS
  "Core.Mateo.Winter12": "วันนี้เป็นวันเกิดกุนเธอร์น่ะ เขาเป็นคนประเภทที่ฉันไม่รู้เลยว่าจะซื้ออะไรให้ดี...$34#$b#นายจะซื้ออะไรให้ผู้ชายที่หาทุกอย่างให้ตัวเองได้กันล่ะ? รายชื่อหนังสือ 'ที่ต้องอ่าน' ของเขานี่ยาวเป็นกิโลเลยนะ$21",
  "Core.Mateo.Winter19": "วันนี้วันเกิดมาร์ลอนล่ะ! ฉันไม่รู้เลยว่าชายแก่คนนั้นอยากจะได้อะไร$8#$b#เขามีอุปกรณ์ดีๆ ครบทุกอย่างแล้ว บางทีอาจจะเป็นของที่ช่วยบำรุงรักษาอุปกรณ์พวกนั้นล่ะมั้ง... หรือบางทีฉันอาจจะทำมื้อค่ำดีๆ ให้เขาสักมื้อก็พอ$32",
  // END OF SEASON
  "Core.Mateo.SpringEnd": "ฤดูใบไม้ผลิจบลงแล้วสินะ? เริ่มต้นปีนี้ได้คุ้มค่าไหมล่ะ?$1#$b#สงสัยนายคงจะยุ่งอยู่กับการเตรียมพื้นที่สำหรับฤดูร้อนล่ะสิ เนอะ?$14",
  "Core.Mateo.SummerEnd": "พืชผลฤดูร้อนของนายคงใกล้จะตายหมดแล้วล่ะสิ @? ไม่เป็นไรหรอก มันก็แค่หมายความว่าถึงเวลาแห่งการเปลี่ยนแปลงแล้ว; ไม่ใช่เรื่องแย่ซะหน่อย$0",
  "Core.Mateo.FallEnd": "ฤดูหนาวกำลังจะมาแล้วสินะ? พูดไม่ได้เต็มปากหรอกนะว่าตั้งตารอมันน่ะ แต่เดี๋ยวฤดูใบไม้ผลิก็จะวนกลับมาหาเราในที่สุดแหละ$23",
  "Core.Mateo.WinterEnd": "ขอบคุณพระเจ้าที่เราเกือบจะพ้นไอ้สภาพอากาศเฮงซวยนี่สักที แสงอาทิตย์จะกลับมาส่องแสงให้เราอีกครั้งในไม่ช้าแหละ$10",
  "Core.Mateo.WinterEnd.Filtered": "ขอบคุณพระเจ้าที่เราเกือบจะพ้นสภาพอากาศแย่ๆ นี่สักที แสงอาทิตย์จะกลับมาส่องแสงให้เราอีกครั้งในไม่ช้าแหละ$10",
  // SVE COMMUNITY DAY
  "Core.Mateo.CommunityCenter4": "ฉันดีใจมากเลยนะที่ทุกคนพยายามหาเวลามาอยู่ด้วยกันที่นี่ มันเป็นบรรยากาศที่อบอุ่นใจมากเลย$0",
  "Core.Mateo.CommunityCenter6": "ดีจังเลยนะที่ได้มาอยู่ที่นี่ ใช้เวลาอยู่กับชาวเมือง ฉันรู้สึกเป็นที่ต้อนรับมาก และบรรยากาศก็เต็มไปด้วยความสุข$32",
  "Core.Mateo.CommunityCenter8": "เอาจริงๆ นะ มันดีมากเลยที่ได้มาคุยอัปเดตชีวิตกับมาร์ลอนบ้าง$11#$b#ฉันกับชายแก่คนนั้นไม่ค่อยได้ออกมาแฮงเอาต์ด้วยกันนอกเวลางานเท่าไหร่หรอกนะ$1#$b#นี่น่าจะเป็นช่วงเวลาเดียวที่ฉันไม่ต้องมานั่งฟังแกบ่นเรื่องความปลอดภัยในการลงดันเจี้ยนน่ะ$1",
  "Core.Mateo.CommunityCenter10": "ดีใจที่ได้เจอนายที่นี่นะ @ แค่เดินทักทายพูดคุยกับทุกคนน่ะ$14#$b#บางทีมันก็ยากนะที่จะหาเวลามาเจอเพื่อนๆ ฉันเลยดีใจที่ชาวเมืองยังคงตั้งใจที่จะมารวมตัวกันแบบนี้ทุกฤดูกาล$1",
  // FESTIVALS
  "Core.Mateo.EggFestival": "พรุ่งนี้มีเทศกาลไข่แล้วนะ! งานใหญ่เทศกาลแรกเพื่อต้อนรับปีใหม่เลยสินะ?$15#$b#หวังว่าทักษะการล่าไข่ของนายจะเฉียบคมนะ @ ฉันได้ยินมาว่านายเจอคู่แข่งที่ค่อนข้างหินเลยล่ะ$14",
  "Core.Mateo.FlowerDance": "จริงๆ แล้วฉันชอบเต้นนะ สมัยเรียนมหาวิทยาลัยฉันเป็นขาประจำในคลับเลยล่ะ แต่ว่า-$12#$b#เอ่อ มันเป็นการเต้นที่ต่างกันมากเลยล่ะ ปกติจะมาพร้อมกับเหล้าเยอะกว่านี้มากเลยล่ะ$13",
  "Core.Mateo.Luau": "ฉันชอบความหมายของเทศกาลในวันพรุ่งนี้นะ - แน่นอนว่าประเพณีเป็นสิ่งสำคัญมากๆ เลยล่ะ -$10#$b#แต่มันไม่ดูมักง่ายไปหน่อยเหรอที่เอาของหลายๆ อย่างมาโยนลงไปในซุปหม้อเดียวกันมั่วๆ แบบนี้น่ะ? ฉันชอบความเสี่ยงนะ แต่นี่มันดูจะเกินไปหน่อย$9",
  "Core.Mateo.MoonlightJelly": "งานฉลองพรุ่งนี้เป็นงานที่ฉันชอบเป็นอันดับสองเลย รองจากงาน Spirit's Eve น่ะ$0#$b#ฉันมองเห็นพวกแมงกะพรุนจากอ่าวตรงนี้ได้เลยล่ะ มันสวยจนลืมหายใจเลยล่ะ$12",
  "Core.Mateo.SDVFair": "พรุ่งนี้มีงานเทศกาลแล้วนะ @! นายจะเอาฟักทองมาด้วยหรือเปล่า?$11#$b#และก็... ของผลิตผล... ที่สำคัญอื่นๆ ด้วยไหม?$21#$b#ฉันแค่จะบอกว่า ถ้าฉันเป็นคนโหวตแล้วมันมีแต่ฟักทองล่ะก็ นายชนะแน่ๆ$15",
  "Core.Mateo.SpiritsEve": "เทศกาล Spirit's Eve น่ะมีกฎสองสามข้อที่ต้องทำตามนะ ตั้งแต่สมัยฉันยังเด็กๆ นู่นเลย$1#$b#ข้อแรก เช็คลูกอมของนายเสมอ ข้อสอง ต้องใส่ชุดคอสตูมเสมอ ข้อสาม เตรียมขนมไว้แจกจ่ายเสมอ$13#$b#และสุดท้าย ห้ามเป่าตะเกียงฟักทองให้ดับก่อนเที่ยงคืนเด็ดขาด นั่นเป็นข้อที่สำคัญที่สุดเลยนะ$14",
  "Core.Mateo.IceFestival": "เทศกาลน้ำแข็งพรุ่งนี้สินะ?$14#$b#ฉันไม่ใช่พวกชอบตกปลาหรอกนะ แต่ฉันปาบอลหิมะเก่งมากเลยล่ะ - และก็นะ ถ้านายหลบค้างคาวอิริเดียม (Iridium Bat) ได้ล่ะก็...$15",
  "Core.Mateo.NightMarket": "อ้อ จริงด้วย ตลาดกลางคืน (Night Market) เริ่มแล้วนี่นา$3#$b#ฉันลืมไปเลย บางทีฉันอาจจะแวะไปดูซะหน่อยว่ามีของจากโกโตโร่มาขายบ้างไหม คงต้องมีใครสักคนลักลอบเอาของน่าสนใจเข้ามาบ้างแหละ เนอะ?$36",
  "Core.Mateo.WinterStar": "เทศกาลแห่งดาวฤดูหนาว (Feast of the Winter Star) นี่มันกดดันชะมัดเลย$22#$b#ฉันไม่รู้เลยว่าจะซื้ออะไรให้ใครดี! ยกเว้นนาย มาร์ลอน แล้วก็กุนเธอร์... สงสัยมันจะไม่ใช่แค่เรื่องของขวัญหรอกมั้ง แต่น่าจะเป็นเรื่องของสปิริตในช่วงเทศกาลมากกว่า$23",
  // ROMANTIC (POSITIVE) 
  "Core.Mateo.GiveFlowersA": "...นี่เรากำลังคบกันจริงจังใช่ไหม ที่รัก? ใช่! คำตอบคือใช่รัวๆ เลยล่ะ$27#$b#นายคือแสงไฟนำทางของฉันนะ @ และฉันถือว่าตัวเองโชคดีมากที่ได้รับความรักจากนาย$4",
  "Core.Mateo.GiveFlowersB": "ให้ตายสิ @ นายชิงตัดหน้าฉันไปก่อนซะได้$30#$b#แน่นอนว่าฉันจะเป็นของนาย ตราบใดที่นายก็เป็นของฉันเหมือนกัน$31#$b#ขอบใจนะ ที่รัก ฉันไม่ได้รู้สึกแบบนี้มา... เอ่อ นานมากๆ แล้วล่ะ$4",
  "Core.Mateo.GivePendant": "%มาเทโอจ้องมองจี้ห้อยคอ รับมันมาจากคุณด้วยมือที่สั่นเทา และสวมมันไว้ที่คอของเขา#$b#ตกลง$4#$b#%เขาดึงคุณเข้าไปจูบ แล้วเอนตัวคุณลงอย่างกับฉากในละคร$18#$b#ฉันขโมยหัวใจนายมาแล้วนะ แต่ฉันสัญญาเลย @ - ฉันจะดูแลมันอย่างดีที่สุดเลยล่ะ$31",
  "Core.Mateo.StardropGiftA": "อรุณสวัสดิ์ ที่รัก! นายต้องไม่เชื่อแน่ว่าฉันเจออะไรในป่าลึกมา$1#$b#ฉันรู้ว่ามันจะทำให้นายมีพลังเพิ่มขึ้น นายทำงานหนักมากเลยนะ - นายสมควรได้รับมันแล้วล่ะ$32#$b#ขอให้วันนี้เป็นวันที่ยอดเยี่ยมนะ เข้าใจไหม?$11#$b#%มาเทโอโน้มตัวไปข้างหน้าแล้วจูบที่หน้าผากของคุณ",
  "Core.Mateo.StardropGiftB": "อรุณสวัสดิ์ ที่รัก! นายต้องไม่เชื่อแน่ว่าฉันเจออะไรในถ้ำกะโหลกมา$1#$b#ฉันรู้ว่ามันจะทำให้นายมีพลังเพิ่มขึ้น นายทำงานหนักมากเลยนะ - นายสมควรได้รับมันแล้วล่ะ$32#$b#ขอให้วันนี้เป็นวันที่ยอดเยี่ยมนะ เข้าใจไหม?$11#$b#%มาเทโอโน้มตัวไปข้างหน้าแล้วจูบที่หน้าผากของคุณ",
  // ROMANTIC (NEGATIVE)
  "Core.Mateo.DanceRejection": "ขอโทษนะ @ ฉันไม่อยากทำตัวน่าอายให้เราสองคนต้องขายหน้าน่ะ$21",
  "Core.Mateo.Divorced": "...ฉันเคยจริงจังกับนายนะ นายเคยเป็นทุกสิ่งทุกอย่างของฉัน แต่นายกลับโยนมันทิ้งไปหมด เพื่ออะไรล่ะ? เพื่อมาเป็นศัตรูกับฉันหลังจากที่ทุกอย่างจบลงงั้นเหรอ?$6#$b#ได้โปรดเถอะ ออกไปจากชีวิตที่เหลืออยู่ของฉันซะ$5",
  "Core.Mateo.BreakUp": "โอ้... สงสัยฉันจะอ่านบรรยากาศไม่ออกสินะ ขอโทษทีนะ ที่ร- @$16#$b#ฉันจะปล่อยให้นายอยู่คนเดียว ฉันก็แค่คิดว่า หลังจากทุกสิ่งทุกอย่างที่ผ่านมา สิ่งที่เรามีมันคือเรื่องจริงซะอีก$19",
  "Core.Mateo.DumpedGirls": "สงสัยนายจะไม่ใช่คนแบบที่ฉันคิดไว้แฮะ @$8#$b#ฉันคาดหวังไว้ดีกว่านี้นะ ทุกคนก็มีภาระของตัวเองกันทั้งนั้น ฉันแค่ปฏิเสธที่จะแบกรับมันแทนนายน่ะ$9",
  "Core.Mateo.SecondChanceGirls": "...ถือว่าโชคดีนะที่ฉันไม่ใช่พวกที่จะปล่อยของๆ ตัวเองไปง่ายๆ @$4#$b#แค่อย่าทำพังอีกก็พอ เข้าใจไหม? หัวใจของฉันรับเรื่องพวกนี้ได้ไม่มากหรอกนะ$28",
  "Core.Mateo.Reject2HA": "ไม่ล่ะ ขอบใจนะชาวไร่ ฉันไม่อยากให้คนทั้งเมืองถือคบเพลิงกับคราดตามล่านายน่ะ$24",
  "Core.Mateo.Reject2HB": "ชาวไร่ นายรู้ไหมว่าไอเดียแย่ๆ มันหน้าตาเป็นยังไง? แบบนี้ไง แบบที่อยู่ตรงหน้านี้แหละ$10",
  "Core.Mateo.Reject4HA": "@ ฉันซาบซึ้งใจนะ และฉันก็รู้สึกดีกับนายด้วย แต่ตอนนี้คงต้องปฏิเสธไปก่อน - ฉันต้องจัดการเรื่องของตัวเองก่อนน่ะ$21",
  "Core.Mateo.Reject4HB": "ขอโทษนะ @ ฉันทำไม่ได้ มันจะยุ่งเหยิงไปหมดสำหรับเราทั้งคู่ ฉันยังไม่พร้อมมีความสัมพันธ์ และสิ่งสุดท้ายที่ฉันอยากจะทำคือการทำให้เพื่อนที่สนิทที่สุดต้องเจ็บปวด$16",
  "Core.Mateo.EngageA": "...นายหมั้นอยู่ไม่ใช่เหรอ? ฉันไม่เอาด้วยหรอกนะ และฉันก็ไม่คิดว่านายจะเป็นพวกตีสองหน้าแบบนี้ด้วย$34",
  "Core.Mateo.EngageB": "งานแต่งนายจะจัดขึ้นในอีกไม่กี่วันนี้แล้วนะ แต่นายยังทำตัวแบบนี้เนี่ยนะ? ฉันควรจะไปบอกคู่หมั้นนายนะ ก่อนที่นายจะทำให้เขาหัวใจสลาย$22",
  "Core.Mateo.MarriedA": "เรื่องแบบนี้มันจะย้อนกลับมาทำร้ายนายทีหลังนะ @ ทำกรรมอะไรไว้ก็ได้อย่างนั้นแหละ คู่สมรสของนายคู่ควรกับสิ่งที่ดีกว่านี้นะ$23",
  "Core.Mateo.MarriedB": "นายเป็นบ้าอะไรเนี่ย @? คู่ของนายควรได้รับอะไรที่ดีกว่านี้สิ ฉันไม่คิดเลยนะว่านายจะเป็นพวกนอกใจน่ะ$33",
  "Core.Mateo.RefusalNoHeartsA": "ประเพณีการให้จี้แห่งนางเงือกน่ะสืบทอดกันมาหลายศตวรรษแล้วนะ ดีใจด้วยนะสำหรับคนที่นายจะเอามันไปให้$32",
  "Core.Mateo.RefusalNoHeartsB": "เรามีประเพณีที่ค่อนข้างแตกต่างออกไปนะที่หมู่เกาะเฟิร์นน่ะ แต่มันก็น่ารักดีนะ - โชคดีล่ะ!$32",
  "Core.Mateo.RefusalKnownA": "มันคงจะน่ารักดีนะ ถ้ามันไม่ดูแปลกประหลาดขนาดนี้ ขอบใจนะ แต่ไม่ล่ะ$34",
  "Core.Mateo.RefusalKnownB": "นายกำลังรนหาที่ใส่ตัวชัดๆ เลยนะเนี่ย? ฉันก็รู้สึกดีใจนะ นิดหน่อยล่ะมั้ง แต่ไม่ล่ะ$37",
  "Core.Mateo.RefusalBotherA": "ครั้งแรกมันก็ไม่ได้ตลกหรือน่ารักเลยนะ ทำไมนายถึงคิดว่าทำแบบนี้แล้วมันจะดีขึ้นล่ะ?$22",
  "Core.Mateo.RefusalBotherB": "หยุดเถอะ @ กว่าจะมาถึงจุดนี้ได้มันยากนะ แต่นายกำลังล้ำเส้นจนทำให้ฉันอึดอัดแล้วนะ$23",
  // RESORT
  "Core.Mateo.ResortEntering": "ที่นี่สุดยอดไปเลย! ทำให้ฉันรู้สึกเหมือนได้กลับไปที่หมู่เกาะเฟิร์นเลยล่ะ ให้ตายสิ คิดถึงจัง$1",
  "Core.Mateo.ResortLeaving": "วันนี้เป็นวันที่ดีนะ แต่ฉันพอใจแล้วล่ะ ไม่มีอะไรจะดีไปกว่าการอาบน้ำหลังกลับจากทะเลอีกแล้ว ต้องล้างครีมกันแดดออกให้หมด$0",
  "Core.Mateo.ResortShore": "ฉันเคยไปมาหลายเกาะแล้วนะ @ แต่มีสิ่งหนึ่งที่ควรจำไว้: ทุกเกาะต่างก็อยู่ใต้ท้องฟ้าเดียวกัน$4",
  "Core.Mateo.ResortUmbrella": "ขอพักเหนื่อยจากการวิ่งเล่นสักหน่อยนะ @ อย่าลืมทาครีมกันแดดล่ะ ถ้านายจะใช้เวลาอยู่ข้างนอกนานๆ$32",
  "Core.Mateo.ResortWander": "ฉันรู้ว่าตัวเองก็อาศัยอยู่บนชายหาดนะ แต่มันก็ยังมีความรู้สึกพิเศษอยู่ดีเวลาได้มาเที่ยวหาดอื่น$1",
  "Core.Mateo.ResortWander.2": "ฉันอยากได้แว่นกันแดดดีๆ สักอัน อันใหญ่ๆ แบบที่พวกสาวชาวกรุงไฮโซเขาใส่กันน่ะ$35",
  "Core.Mateo.ResortChair": "ฉันอาจจะเผลอหลับตรงนี้ได้เลยนะ แต่ถ้าหลับทีไรฉันหลับเป็นตายแน่ๆ แล้วคงพลาดเรือกลับแหงๆ$6",
  "Core.Mateo.ResortBar": "เราควรจะดื่มฉลองให้กับความเหนื่อยยากของนายนะ @ ถ้าไม่มีนาย ที่นี่คงไม่ได้สร้างขึ้นมาหรอก$12",
  "Core.Mateo.ResortTowel": "%มาเทโอ (Mateo) ดูผ่อนคลายสุดๆ",
  "Core.Mateo.ResortTowel.2": "สมัยเรียน ฉันใช้เวลาหลายวันหมดไปกับการนั่งดื่มที่ชายหาด แทนที่จะเขียนรายงานส่ง...$15",
  "Core.Mateo.Resort_Towel.3": "ที่นี่เหมาะจะเป็นที่จัดปาร์ตี้สุดๆ ไปเลย$13",
  "Core.Mateo.Resort": "นายสร้างบ้านไว้ที่นี่ด้วยเหรอ @? บ้านพักตากอากาศงั้นสิ เจ๋งไปเลย!$1",
  // ADDITIONAL LOCATIONAL DIALOGUE
  "Core.Mateo.Saloon.4h": "ดีจังเลยนะที่ได้กลับมาที่นี่ @ ฉันชอบการที่ได้อยู่ท่ามกลางผู้คน ทุกคนดูสนุกสนานและมันก็ง่ายมากเลยที่จะรู้สึกผ่อนคลายไปกับพวกเขาด้วย ฉันรู้สึกเป็นที่ต้อนรับและเติมเต็มสุดๆ$4",
  "Core.Mateo.Saloon.6h": "ฉันชอบมาใช้เวลาที่นี่นะ เพราะมันเป็นวิธีที่เยี่ยมมากในการเจอทุกคนพร้อมๆ กัน การนั่งมองดูผู้คนก็สนุกดีเหมือนกัน...$0#$b#ดีมีเทรียสเต้นคร่อมจังหวะสุดๆ ส่วนมาร์นี่ก็ดีเกินไปสำหรับลูอิส ฉันล่ะอยากให้มาร์ลอนรวบรวมความกล้าแล้วเข้าไปจีบสักที$36",
  "Core.Mateo.Saloon.8h": "ไม่มีอะไรจะดีไปกว่าการใช้เวลายามเย็นไปกับเพื่อนฝูงอีกแล้ว ดีใจจริงๆ ที่นายโน้มน้าวให้ฉันกลับมาเข้าสังคมอีกครั้ง @ ฉันชอบเวลาที่ได้มาแฮงเอาต์กับทุกคนนะ$12#$b#ฉันติดเลี้ยงเหล้านายแก้วนึงเลยล่ะ ไม่สิ ต้องหลายแก้วเลยต่างหาก$14",
  "Core.Mateo.Saloon.10h.Platonic": "ไง @ เรามานั่งเล่นด้วยกันสักพักไหม? นายคงต้องการพักผ่อนบ้างแหละหลังจากทำงานมาทั้งวัน ถึงเวลาพักผ่อนสมองแล้วนะ$1",
  "Core.Mateo.Saloon.10h.Romantic": "ไง ที่รัก เรามาดื่มกันสักสองสามแก้วแล้วปล่อยตัวปล่อยใจกันหน่อยดีไหม? โชคดีนะที่ฟาร์มอยู่ไม่ไกลเท่าไหร่ ถ้าเกิดว่าเรายังพอมีแรงกลับไปถึงน่ะนะ$31",
  "Core.Mateo.ArchaeologyHouse.4h": "ที่นี่ทำให้รู้สึกคิดถึงอดีตจัง... เหมือนได้กลับมาใช้เวลาในบ้านสมัยเด็กของฉันเลย$12#$b#ฉันไม่รู้ตัวเลยว่าฉันคิดถึงที่นี่มากแค่ไหน จนกระทั่งได้กลับมาอีกครั้งนี่แหละ$32",
  "Core.Mateo.ArchaeologyHouse.6h": "ฉันไม่ได้อ่านหนังสือเพื่อความบันเทิงมานานมากแล้ว ฉันเลยมาเริ่มใหม่กับหนังสือเล่มโปรดของฉันนี่แหละ#$b#การที่ต้องอ่านหนังสือเพื่อเรียน มันดูดความสนุกไปหมดเลยน่ะสิ",
  "Core.Mateo.ArchaeologyHouse.8h": "ฉันชอบดูผู้คนเดินเข้าเดินออก เรียนรู้ อ่านหนังสือ พักผ่อน ไม่มีอะไรทำให้ฉันมีความสุขไปกว่าการได้เห็นผู้คนใส่ใจกับการศึกษาอีกแล้ว$32#$b#โดยเฉพาะพวกเด็กๆ พวกเขากระตือรือร้นที่จะเรียนรู้กันมาก และฉันรักในสิ่งนั้น ขอให้เพนนีมีความอดทนอย่างไม่มีที่สิ้นสุดด้วยเถอะ$1",
  "Core.Mateo.ArchaeologyHouse.10h.Platonic": "ฉันรู้ว่านายยุ่งนะ @ แต่หนังสือดีๆ สักเล่มก็คุ้มค่าที่จะหาเวลาอ่านนะ ตอนนี้ฉันกำลังอ่าน 'The Great Gatsbish' ใหม่อีกรอบ มันเป็นหนึ่งในเล่มโปรดของฉันเลยล่ะ$4",
  "Core.Mateo.ArchaeologyHouse.10h.Romantic": "ฉันกำลังอ่าน 'The Great Gatsbish' ใหม่อีกรอบ มันเป็นหนังสือเล่มโปรดของฉันเลยล่ะ ฉันรู้สึกเชื่อมโยงกับมันมาตลอด เหมือนเป็นบทละครที่เขียนมาเพื่อชีวิตฉันเลย แต่ว่า...$2#$b#แกตส์ติดอยู่กับกระแสน้ำแห่งภาพลวงตาที่ตัวเองสร้างขึ้น และไม่สามารถพายเรือต่อไปได้ แต่ตอนนี้ฉันไม่ได้รู้สึกว่าตัวเองต้องดิ้นรนแบบนั้นอีกแล้วล่ะ เพราะฉันสามารถทิ้งอดีตไว้ในที่ที่มันควรอยู่ได้แล้ว$12#$b#ไม่ได้หมายความว่าฉันรักนิยายเรื่องนี้น้อยลงนะ แต่บางทีฉันอาจจะต้องเริ่มมองหาเล่มโปรดเล่มใหม่แล้วล่ะ$32",
  "Core.Mateo.AdventureGuild.4h": "ขอทักทายนักผจญภัย! โถ่เอ๊ย ฟังดูเลี่ยนสุดๆ ไปเลยเนอะว่าไหม?$1",
  "Core.Mateo.AdventureGuild.6h": "ขอทักทายนักผจญภัย!$1#$b#ฮ่าๆ ฉันชักจะชอบคำนี้แล้วสิ แต่บางทีฉันควรปล่อยให้การทักทายแบบนี้เป็นหน้าที่ของมาร์ลอนจะดีกว่านะ$32",
  "Core.Mateo.AdventureGuild.8h": "ไง @! ขอทักทายนักผจญภัย มาหาซื้ออุปกรณ์ใหม่ๆ เหรอ? หรือว่าจะเอาของเก่ามาโละทิ้งล่ะ?$36#$b#มาร์ลอนมีของให้เลือกเพียบเลยนะ ดูแลตัวเองดีๆ ตอนลงไปข้างล่างด้วยล่ะ เข้าใจไหม?$32",
  "Core.Mateo.AdventureGuild.10h.Platonic": "ไง @ ขอทักทายนักผจญภัยนะ นายกำลังออกสำรวจอยู่เหรอ? ได้ของที่ต้องการครบหรือยัง?$32#$b#เตรียมอาวุธพร้อมแล้วใช่ไหม? ดูแลตัวเองดีๆ ตอนอยู่ข้างล่างด้วยล่ะ ระมัดระวังด้วยนะ$1",
  "Core.Mateo.AdventureGuild.10h.Romantic": "ขอทักทายนักผจญภัยนะ ที่รัก! ได้ของที่ต้องการครบหรือยัง? เตรียมอาวุธพร้อมแล้วใช่ไหม?$31#$b#ดูแลตัวเองดีๆ นะถ้านายจะลงไปในเหมือง เข้าใจไหม? ฉันรักนายนะ$29",
  // PLAYER DEATH
  "Core.Mateo.PlayerKilled.Mines.01": "ที่รัก!",
  "Core.Mateo.PlayerKilled.Mines.02": "ที่รัก เกิดอะไรขึ้นเนี่ย? ฉันเสียใจด้วยจริงๆ!",
  "Core.Mateo.PlayerKilled.Mines.03": "ระวังตัวให้มากกว่านี้หน่อยสิ! ขนาดนักผจญภัยที่เก่งกาจอย่างนายยังเจ็บหนักได้ขนาดนี้เลยนะ!$2#$b#บางทีนายควรกลับบ้านไปพักผ่อนก่อนที่จะลงไปอีกรอบนะ ตกลงไหม?$21",
  "Core.Mateo.PlayerKilled.Skull.01": " ... @?",
  "Core.Mateo.PlayerKilled.Skull.02": "ใจเย็นๆ นะ... ค่อยๆ ขยับ",
  "Core.Mateo.PlayerKilled.Skull.03": "นายฟื้นแล้ว! ขอบคุณพระเจ้า มาเทโอไปเจอนายในสภาพสะบักสะบอมอยู่ในถ้ำกะโหลกน่ะ!$2",
  "Core.Mateo.PlayerKilled.Skull.04": "ที่รัก!$18#$b#ฉันเป็นห่วงแทบแย่ การที่นายบาดเจ็บมันคือฝันร้ายที่สุดของฉันเลยนะ!$19",
  "Core.Mateo.PlayerKilled.Skull.05": "{{CPPNI}} {{LPPN1}} จะไม่เป็นไรใช่ไหม ฮาร์ว (Harv)?$29",
  "Core.Mateo.PlayerKilled.Skull.06": "{{CPPN1}} ไม่เป็นไรหรอก แต่คราวหน้า {{LPPN1}} ต้องระวังตัวให้มากกว่านี้หน่อยนะ$2",
  "Core.Mateo.PlayerKilled.Skull.07": "ฉันจะปล่อยให้พวกนายสองคนคุยกันนะ มีอะไรก็เรียกฉันได้เลย$2",
  "Core.Mateo.PlayerKilled.Skull.08": "ฉันกลัวแทบแย่ว่าจะเสียนายไป @ ฉันไม่รู้เลยว่าจะทำยังไงถ้าไม่มีเพื่อนสนิทที่สุด คนที่ฉันรักที่สุดในชีวิต$17#$b#คราวหน้าถ้านายต้องการความช่วยเหลือ ขอร้องล่ะ บอกฉันนะที่รัก! ฉันยอมไปเผชิญอันตรายด้วยกันกับนาย ดีกว่าปล่อยให้นายไปถ้ำกะโหลกคนเดียว!$19",
  // GREEN RAIN
  "Core.Mateo.GreenRain": "ฉันไม่เคยเห็นฝนแบบนี้มาก่อนเลย ขนาดตอนเด็กๆ ที่ใช้เวลาอยู่ในเมืองเพลิแกนมาตั้งนาน หวังว่ามันจะเป็นลางดีนะ$37",
  "Core.Mateo.GreenRainFinished": "ฝนตกหนักเอาเรื่องเลยนะ แต่ดูเหมือนจะไม่มีผลข้างเคียงแย่ๆ อะไรเลย ตอนนี้ทุกอย่างดูเขียวชอุ่มไปหมด!$1",
  "Core.Mateo.GreenRain2": "มีบางอย่างบอกฉันว่าเฮกเตอร์ (Hector) ต้องมีส่วนเกี่ยวข้องกับฝนประหลาดนี่แน่ๆ นายคิดว่าไงล่ะ @?$14",
  // POLYAMORY 
  "Core.Mateo.MarriedMonogamousNPC": "ขอโทษทีนะ @! ฉันรู้สึกดีใจนะ แต่นายมีคู่ครองที่รักเดียวใจเดียวอยู่แล้ว ถ้าฉันเข้าไปยุ่งมันคงเป็นการล้ำเส้นกฎในความสัมพันธ์ของพวกนาย$16",
