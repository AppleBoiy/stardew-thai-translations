  // STARDROP TEA 
  "Gifts.Mateo.GiftReaction.StardropTea": "ว้าว @! นี่มันสุดยอดไปเลย! กลิ่นหอมมาก มันทำมาจากอะไรเหรอ? ขอบคุณนะที่เอามาแบ่งให้ฉัน$1",
  // ANCIENT SWEET TEA
  "Gifts.Mateo.GiftReaction.AncientSweetTea": "กลิ่นนี่มันหอม มากๆ เลยนะ ของที่มาจากฟาร์ม %farm ไม่เคยทำให้ฉันเลิกทึ่งได้เลย ขอบคุณนะ @",
  // BASIC GIFT RESPONSES 
  "Gifts.Mateo.GiftReaction.Love": "ว้าว ฉันรู้สึกได้เลยว่าเธอตั้งใจนึกถึงฉันจริงๆ ขอบคุณนะ",
  "Gifts.Mateo.GiftReaction.Like": "เธอเอามาให้ฉันเหรอ? ขอบคุณมากนะ ช่างน่ารักจริงๆ",
  "Gifts.Mateo.GiftReaction.Dislike": "ลางเนื้อชอบลางยา สินะ?",
  "Gifts.Mateo.GiftReaction.Hate": "นี่มันไม่ได้คิดเลยนะเนี่ย ฉันไม่แน่ใจว่าเธอจะให้ฉันทำไม",
  "Gifts.Mateo.GiftReaction.Neutral": "ขอบคุณสำหรับเจ้านี่นะ ใจดีจัง",
  // FISH
  "Gifts.Mateo.GiftReaction.CategoryFish": "ฉันไม่ค่อยชอบอาหารทะเลเท่าไหร่ แต่ก็ขอบคุณแล้วกันนะ$37",
  "Gifts.Mateo.GiftReaction.SeaUrchin": "ฉันไม่ค่อยชอบอาหารทะเลเท่าไหร่ แต่ก็ขอบคุณแล้วกันนะ$37",
  "Gifts.Mateo.GiftReaction.Crab": "ฉันเกลียดปู พวกมันเอาทรายไปเลอะเทอะทุกที่ แล้วก็เป็นตัวอันตรายสำหรับเมือง อีสต์สคาร์ป (East Scarp) ด้วย$11#$b#ข้อดีอย่างเดียวของพวกมันคือการเอาเนื้อไปจุ่มในเนยกระเทียมนี่แหละ$9",
  "Gifts.Mateo.GiftReaction.CrabCakes": "ฉันเกลียดปู พวกมันเอาทรายไปเลอะเทอะทุกที่ แล้วก็เป็นตัวอันตรายสำหรับเมือง อีสต์สคาร์ป (East Scarp) ด้วย$11#$b#ข้อดีอย่างเดียวของพวกมันคือการเอามาเสิร์ฟเป็นอาหาร แบบนี้นี่แหละ ขอบคุณนะ @$13",
  // ARTISANAL GOODS
  "Gifts.Mateo.GiftReaction.CategoryArtisanalGoods": "เธอทำเองเลยเหรอ? น่าประทับใจมากเลย ขอบคุณนะ$1",
  // TRASH
  "Gifts.Mateo.GiftReaction.CategoryTrash": "...ไม่เอาล่ะ ขอบใจ$16",
  // MINERALS & GEMS
  "Gifts.Mateo.GiftReaction.CategoryGemsMinerals": "สวยจังเลย @! ฉันชอบวิธีที่มันสะท้อนแสงนะ ขอบคุณนะ$1",
  // LOVES - PLATONIC
  "Gifts.Mateo.GiftReaction.PrismaticShard.Platonic": "ไวแอตต์เป็นคนสุดท้ายที่ให้เจ้านี่กับฉันนะ$1#$b#ฉันใช้มันตีดาบของฉัน และฉันก็เข้าใจดีถึงคุณค่าของของที่ล้ำค่าขนาดนี้ ขอบคุณนะ$4",
  "Gifts.Mateo.GiftReaction.Pumpkin.Platonic": "นี่ของโปรดฉันเลย! ไม่มีอะไรจะดีไปกว่าการแกะสลักตะเกียงฟักทองในฤดูใบไม้ร่วงอีกแล้ว และนอกจากนั้น มันก็อร่อยด้วยล่ะ$1",
  "Gifts.Mateo.GiftReaction.JackOLantern.Platonic": "นี่ดูยอดเยี่ยมมากเลย! เธอแกะสลักเองด้วยเหรอ? มันดูน่ากลัวแบบสมบูรณ์แบบเลย ทำได้ดีมาก!$1",
  "Gifts.Mateo.GiftReaction.GoldenPumpkin.Platonic": "เธอชนะรางวัลมา...แล้วก็เอามันมาให้ฉันเนี่ยนะ?$26#$b#ขอบคุณนะ @ ฉันมีที่ที่เหมาะเจาะสำหรับวางโชว์มันแล้วล่ะ$1",
  "Gifts.Mateo.GiftReaction.FairyRose.Platonic": "รู้ได้ไงว่านี่เป็นดอกไม้โปรดของฉัน @? มันใช้ทำน้ำผึ้งแบบที่ฉันชอบที่สุดด้วย... ขอบคุณมากเลยนะ$1",
  "Gifts.Mateo.GiftReaction.Honey.Platonic": "ฉันชอบของหวานแบบนี้ที่สุดเลย! ขอบคุณนะ @ เราน่าจะเอามากินคู่กับแครกเกอร์และชีสด้วยกันนะ$1",
  "Gifts.Mateo.GiftReaction.RainbowShell": "พวกนี้สะท้อนแสงอาทิตย์ได้สวยงามมากเลยนะตอนที่เธอเจอมันบนชายหาดในตอนเช้าน่ะ ขอบคุณนะที่เอามาแบ่งให้ฉัน @$1",
  "Gifts.Mateo.GiftReaction.MapleBar": "รู้ไหม ฉันมีความทรงจำดีๆ เกี่ยวกับการได้กินเมเปิ้ลบาร์ทำเองกับเพื่อนสนิทนะ... มันเป็นขนมอบที่ฉันชอบที่สุดเลย ขอบคุณนะ @$1",
  "Gifts.Mateo.GiftReaction.AutographedPhoto": "เธอไปได้เจ้านี่มายังไงเนี่ย-? ฉันเป็นแฟนตัวยงผลงานของร็อดนีย์ (Rodney) เลยนะ! รู้ไหมว่าเขาเคยชนะรางวัลมาแล้วถึงสองครั้ง? นี่มันสุดยอดมาก ฉันจะเก็บรักษามันอย่างดีเลย! ขอบคุณนะ!$32",
  "Gifts.Mateo.GiftReaction.SalishBourbon": "นี่เป็นเครื่องดื่มที่พิเศษมากเลยนะ ฉันรู้เลยว่าต้องใช้ความพยายามแค่ไหนกว่าจะทำมันขึ้นมาได้ - ขอบคุณนะ @ ทั้งสำหรับที่ทำมันขึ้นมา และที่เอามาแบ่งให้ฉัน$4",
  "Gifts.Mateo.GiftReaction.AutumnalStew": "รสชาติของเจ้านี่เหมือนบรรยากาศของเทศกาลสปิริตอีฟ (Spirit's Eve) เลย ขอบคุณนะ @!$1",
  "Gifts.Mateo.GiftReaction.AncientFairyRose": "ฉันจำพวกนี้ได้ตอนที่ไปเดินเล่นในป่าสมัยเด็กๆ มันเป็นของโปรดฉันเลย ขอบคุณนะ @$12",
  // LOVES - ROMANTIC 
  "Gifts.Mateo.GiftReaction.PrismaticShard.Romantic": "ไวแอตต์เป็นคนสุดท้ายที่ให้เจ้านี่กับฉันนะ ฉันใช้มันตีดาบของฉัน และฉันก็เข้าใจดีถึงคุณค่าของของที่ล้ำค่าขนาดนี้$4#$b#สิ่งเดียวที่พอจะเทียบเคียงกับมันได้... ก็คือเธอไง ขอบคุณนะ แสงตะวัน$27",
  "Gifts.Mateo.GiftReaction.Pumpkin.Romantic": "เธอรู้ใจฉันดีจังนะ แสงตะวัน ทำไมเราไม่ไปแกะสลักมันด้วยกันเลยล่ะ หืม?$31#$b#%มาเทโอกระตุกแขนเสื้อนายเบาๆ อย่างหยอกล้อ",
  "Gifts.Mateo.GiftReaction.JackOLantern.Romantic": "ฉันจะเอามันไปตั้งโชว์ให้ทุกคนเห็นเลย แสงตะวัน และฉันจะป่าวประกาศอย่างภูมิใจเลยว่าเธอเป็นคนแกะสลักให้ฉัน$27",
  "Gifts.Mateo.GiftReaction.GoldenPumpkin.Romantic": "เธอชนะรางวัลมา...แล้วก็เอามันมาให้ฉันเนี่ยนะ? ขอบคุณนะ แสงตะวัน คราวหน้า เราไปหลงทางในเขาวงกตด้วยกันดีไหม?$30",
