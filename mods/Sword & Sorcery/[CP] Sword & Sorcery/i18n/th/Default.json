  // EGG FESTIVAL 
  "Festivals.Mateo.spring13.False.1": "ชอบงานล่าไข่จังเลย เมื่อก่อนฉันเคยเอาไข่ไปซ่อนรอบๆ มหาวิทยาลัยนะ แต่ซ่อนเนียนเกินไปจนคนหาไม่เจอไปหลายวัน จนกระทั่งมันเริ่มส่งกลิ่นเหม็นนั่นแหละ$1",
  "Festivals.Mateo.spring13.False.2": "เชียร์อยู่นะ @ สมัยก่อนฉันเก่งเรื่องนี้มากเลยตอนที่ลูอิสยังยอมให้ฉันเล่นตอนเป็นเด็กน่ะ แต่ตอนนี้ไม่ค่อยแล้วล่ะ$1",
  "Festivals.Mateo.spring13.False.3": "กัสทุ่มสุดตัวทำอาหารเลยสินะ? ที่นี่มีไข่ทุกประเภทที่พอจะนึกออกเลย ทำมาตั้งหลายแบบแหนะ$36",
  "Festivals.Mateo.spring13.True.1": "โอเค เอาล่ะ มีอยู่ฟองนึงหลังต้นไม้ตรงนั้น แล้วก็อีกฟองนึงซ่อนอยู่ใต้พุ่มไม้นั่นไง$14#$b#อ้า เวรล่ะ ลูอิสมองมาทางนี้ โชคดีนะ แสงตะวัน$15",
  "Festivals.Mateo.spring13.True.1.Filtered": "โอเค เอาล่ะ มีอยู่ฟองนึงหลังต้นไม้ตรงนั้น แล้วก็อีกฟองนึงซ่อนอยู่ใต้พุ่มไม้นั่นไง$14#$b#อ้า ปัดโธ่เอ๊ย ลูอิสมองมาทางนี้ โชคดีนะ แสงตะวัน$15",
  "Festivals.Mateo.spring13.True.2": "รู้ไหม ฉันชอบการเล่นแบบร่วมมือกันมากกว่า ฉันควรจะได้รับอนุญาตให้ช่วยเธอได้สิโดยที่ลูอิสไม่ต้องมาหัวเสียแบบนี้$80",
  "Festivals.Mateo.spring13.True.3": "ฉันรักเธอนะไม่ว่าจะแพ้หรือชนะ แสงตะวัน แต่เธอก็รู้เรื่องนั้นอยู่แล้วนี่นา เพราะงั้น ไปสนุกกับการคว้าชัยชนะมาให้เต็มที่เลยนะ$82",
  // FLOWER DANCE 
  "Festivals.Mateo.spring24.False.1": "เอาจริงๆ ฉันเป็นพวกชอบเที่ยวผับเที่ยวคลับมากกว่านะ แต่งานนี้ก็น่ารักดีเหมือนกัน$1",
  "Festivals.Mateo.spring24.False.2": "ฉันชอบงานปาร์ตี้ใหญ่ๆ แบบนี้นะ มันดูใกล้ชิดกันดี ถ้าเป็นงานรวมญาติวงเล็กๆ มันไม่มีความเป็นส่วนตัวเอาซะเลย$32",
  "Festivals.Mateo.spring24.False.3": "เพลงดังๆ กับสถานที่แคบๆ มักจะเป็นแนวที่ฉันชอบนะ แต่ฉันก็ชื่นชมงานแบบนี้เหมือนกัน$32",
  "Festivals.Mateo.spring24.True.1": "พอได้เห็นเธอแต่งตัวเต็มยศแบบนี้ ทุกสิ่งทุกอย่างรอบตัวก็ดูช้าลง แล้วคนอื่นก็ไม่มีความหมายอีกต่อไป มันทำให้ฉันนึกถึงวันแต่งงานของเราเลยล่ะ รักเธอนะ @$4",
  "Festivals.Mateo.spring24.True.2": "ฉันรักเธอจนโงหัวไม่ขึ้นเลย แสงตะวัน พอเห็นเธอแต่งตัวเต็มยศแบบนี้ มันทำให้ฉันอยากจะจับเธอถอดชุดออกซะเดี๋ยวนี้เลยล่ะ$14",
  "Festivals.Mateo.spring24.True.3": "ฉันได้รับสิทธิพิเศษที่จะตกหลุมรักเธออีกครั้ง ทุกครั้งที่ฉันได้เต้นรำกับเธอนะ @$4",
  "Festivals.Mateo.spring24.Accept": "ฉันอยากจะเต้นรำกับเธออยู่แล้วล่ะ @ ขอบใจนะที่ชวน$4",
  // LUAU 
  "Festivals.Mateo.summer11.False.1": "ฉันชอบเห็นทุกคนมารวมตัวกันนะ มันเป็นภาพที่อบอุ่นหัวใจจริงๆ เอาจริงๆ นะ มันทำให้รู้สึกเหมือนเป็นชุมชนที่แน่นแฟ้นกันมากเลย จริงๆ นะ มันคือเวทมนตร์ของอาหาร เครื่องดื่ม แล้วก็การเต้นรำน่ะ$1",
  "Festivals.Mateo.summer11.False.2": "ฉันยังคงสงสัยอยู่เลยว่าทำไมซุปนี่ถึงรสชาติไม่ออกมาหายนะ บางทีอาจจะเป็น... พลังแห่งมิตรภาพ หรืออะไรเทือกนั้นมั้ง?$34#$b#ถึงยังไงฉันก็ชอบนะ ไม่ยอมพลาดงานนี้เด็ดขาดเลย$36",
  "Festivals.Mateo.summer11.False.3": "ฉันเอาน้ำผึ้งแฟรี่โรส (Fairy Rose Honey) มาแบ่งนิดหน่อยนะ ถ้าซุปรสชาติออกมาแปลกๆ ฉันไม่อยากโดนเพ่งเล็งว่าเป็นเพราะฉันน่ะ$13",
  "Festivals.Mateo.summer11.True.1": "เอาจริงๆ การรอดชีวิตจากซุปนี่ทุกปี - โดยเฉพาะเวลาที่มีคนเอาของมาโยนใส่เยอะขนาดนี้ - ดูเหมือนจะเป็นความท้าทายเลยนะ เอาเป็นว่า ถ้าเราจะป่วย เธอกับฉันก็ต้องร่วงไปด้วยกันนี่แหละ$32",
  "Festivals.Mateo.summer11.True.2": "อาหารพวกนี้ทำเอาฉันอยากงีบเลยล่ะ ตั้งตารอที่จะได้ไปนอนขดตัวซุกอยู่กับเธอเลยนะ แสงตะวัน$27",
  "Festivals.Mateo.summer11.True.3": "ฉันชอบเวลาที่อากาศร้อนแบบนี้นะ แดดออก โชว์กล้าม - แล้วก็นะ ฉันยินดีมากเลยที่จะโชว์ให้สุดที่รักของฉันได้ดูเป็นอาหารตา$30",
  // MOONLIGHT JELLIES
  "Festivals.Mateo.summer28.False.1": "ฉันชอบแมงกะพรุนพวกนี้นะ แต่ที่หมู่เกาะเฟิร์น (Fern Islands) มีแมงกะพรุนสายพันธุ์นึงที่ต่อยเจ็บสุดๆ ไปเลยล่ะ เพราะงั้น เธอคงไม่อยากไปว่ายน้ำเล่นหรอกนะตอนที่พวกมันอยู่แถวๆ นี้น่ะ$32",
  "Festivals.Mateo.summer28.False.2": "น้ำดูสวยงามมากเลยนะเวลาที่เจ้าพวกตัวน้อยพวกนี้เปล่งแสงออกมา ว่าไหม? ฉันมองเห็นได้ชัดเจนจากอ่าวเลยล่ะ แต่มันดีกว่ามากเลยนะที่ได้ใช้เวลาค่ำคืนนี้ร่วมกับทุกคน$1",
  "Festivals.Mateo.summer28.False.3": "ฉันตกลงไปจากท่าเรือน่ะ...$39",
  "Festivals.Mateo.summer28.True.1": "ฉันไม่เคยคิดเลยนะว่าจะมีโอกาสได้มายืนดูสิ่งนี้อยู่ด้วยกันตรงนี้ แสงที่สะท้อนจากตัวเธอน่ะ คือหนึ่งในสิ่งที่สวยงามที่สุดที่ฉันเคยเห็นมาเลยนะ$4",
  "Festivals.Mateo.summer28.True.2": "ไม่มีอะไรจะดีไปกว่าการได้กอดเธอแล้วมองดูเจ้าพวก ลูนาลู (Lunaloos) เปล่งประกายหรอก หุบเขานี้เป็นที่ที่สวยงามนะ แต่มันสวยขึ้นไปอีกเมื่อมีเธออยู่ด้วย$70",
  "Festivals.Mateo.summer28.True.3": "ตอนที่ฉันออกจากหุบเขานี้ ฉันคิดว่าฉันจะไม่มีวันได้เห็นอะไรแบบนี้อีกแล้ว ช่างเป็นพรที่แสนวิเศษจริงๆ ที่ฉันได้แบ่งปันสิ่งนี้ร่วมกับเธอในตอนนี้$80",
  // SDV FAIR
  "Festivals.Mateo.fall16.False.1": "ชิ กระดิ่งนั่นไม่รอดหรอก! โทษทีนะ พอดีฉันไม่ได้ยินเสียงเธอเลย เพราะเสียงกล้ามพวกนี้มันดังกลบน่ะ$13#$b#%มาเทโอเบ่งกล้ามโชว์อย่างหยอกล้อ",
  "Festivals.Mateo.fall16.False.2": "เธอกำลังคุยอยู่กับแชมป์ตีระฆังหลายสมัยนะ @ การแกว่งดาบไปมาตลอดเวลานี่มันส่งผลดีต่อร่างกายสุดๆ ไปเลยล่ะ$13",
  "Festivals.Mateo.fall16.False.3": "ฉันค่อนข้างจะถนัดเรื่องใช้กำลังกับความคล่องตัวน่ะ ฉันใช้เทศกาลนี้สะสมพวกตุ๊กตารางวัลแปลกๆ$35",
  "Festivals.Mateo.fall16.True.1": "เรื่องนี้กินหมูแน่นอน แสงตะวัน ฉันจะชนะแข่งประลองพลัง เธอจะชนะแข่งจัดของโชว์ - แล้วเราก็จะกลับบ้านไปฉลองด้วยกัน ฟังดูเข้าท่าไหมล่ะ?$28",
  "Festivals.Mateo.fall16.True.2": "เกมประลองพลังน่ะก็แค่ทางผ่าน แต่การได้แข็งแกร่งพอที่จะอุ้มเธอได้นั่นแหละคือรางวัลที่แท้จริง$82",
  "Festivals.Mateo.fall16.True.3": "ถ้ามีปาเป้าหรือขว้างขวานนะ ฉันคงปาได้แม่นพอๆ กับที่ฉัน-แม่น-กับเธอเลยล่ะ! เฮ้ หยุดหัวเราะเดี๋ยวนี้นะ -$36",
  // SPIRIT'S EVE
  "Festivals.Mateo.fall27.False.1": "คืนนี้เป็นคืนเดียวในรอบปีที่โอเคเลยที่จะรู้สึกไม่ปลอดภัย เธอควรจะอยากรู้สึกกลัวขึ้นมาบ้าง ถึงมันจะเป็นแค่คืนเดียวก็ตาม$84#$b#ถ้าเธอเอาชีวิตรอดจากความกลัวในวัยเด็กไม่ได้ แล้วเธอจะรับมือกับมันได้ยังไงตอนโตขึ้นล่ะ? มีอะไรให้ต้องกลัวอีกเยอะเลยนะในชีวิตภายหน้าน่ะ$84",
  "Festivals.Mateo.fall27.False.2": "ห้ามทำลายตะเกียงฟักทอง หรือไปขโมยขนมเด็กๆ เด็ดขาดเลยนะ คืนนี้เป็นคืนที่ต้องเคารพคนตาย เพราะนี่คือคืนเดียวที่พวกนั้น รวมถึงพวกสิ่งลี้ลับอื่นๆ จะออกมาเพ่นพ่านได้อย่างอิสระ$84#$b#ประเพณีพวกนี้ทั้งหมดน่ะเหรอ? ตะเกียงฟักทอง, การแต่งชุดผี, การแจกขนม... ทุกอย่างมันเริ่มขึ้นมาเพื่อปกป้องเธอนะ$84",
  "Festivals.Mateo.fall27.False.3": "ไม่โกหกเลยนะ ชุดนี้มันแอบคันนิดหน่อย แล้วก็ค่อนข้างจะคีพคาร์แรกเตอร์ยากด้วยล่ะ$84",
  "Festivals.Mateo.fall27.True.1": "ฉันแค่อยากจะร่าย, ร่ายมนต์สะกดเธอ, ท่ามกลางแสงจันทร์~$84",
  "Festivals.Mateo.fall27.True.2": "มีความมืดมิดซ่อนอยู่ ณ ใจกลางความรักที่ฉันมีต่อเธอ, มันช่างเย็นเยียบและลึกล้ำเหลือเกิน~$84",
  "Festivals.Mateo.fall27.True.3": "ฉันจะเป็นเงามืด ส่วนเธอจะเป็นแสงสว่าง เราจะค่อยๆ กลืนหายเข้าไปในรัตติกาล~$84",
  // ICE FESTIVAL 
  "Festivals.Mateo.winter8.False.1": "%มาเทโอกำลังปั้นลูกบอลหิมะให้กลมดิกอย่างสมบูรณ์แบบ#$b#เอาล่ะ มาร์ลอน... ถ้าคุณหลบการโจมตีของมอนสเตอร์ได้ คุณก็ต้องหลบลูกบอลหิมะได้เหมือนกันแหละ$13",
  "Festivals.Mateo.winter8.False.2": "มีหนังเก่าเรื่องนึงที่ฉันชอบมากๆ เกี่ยวกับที่มาของหิมะน่ะ $32#$b#ชายที่มีมือเป็นกรรไกรคอยแกะสลักน้ำแข็ง แล้วเศษน้ำแข็งที่ปลิวว่อนก็กลายมาเป็นพายุหิมะในบ้านเรา เทศกาลนี้ทำให้นึกถึงเรื่องนั้นเลย$1",
  "Festivals.Mateo.winter8.False.3": "บางครั้งมันก็ทรมานนะที่ต้องมาอยู่ท่ามกลางความหนาวแบบนี้ แต่การได้อยู่ท่ามกลางเพื่อนฝูงก็ช่วยให้ทนได้ง่ายขึ้นเยอะเลย$27",
  "Festivals.Mateo.winter8.True.1": "ใจจริงฉันก็อยากจะชวนแอบหนีไปกันสองคนนะ แต่ฉันรู้ว่าเธอกำลังสนุกอยู่ เดี๋ยวฉันค่อยไปหาความอบอุ่นกับเธอทีหลังก็แล้วกัน$30",
  "Festivals.Mateo.winter8.True.2": "ในระดับตั้งแต่ 'หย่ากัน' ไปจนถึง 'รักกันมากขึ้น' เธอจะโกรธฉันมากแค่ไหน ถ้าฉันพยายามยุให้ลูอิสจัดแข่งปาบอลหิมะแทนแข่งตกปลาน่ะ?$15",
  "Festivals.Mateo.winter8.True.3": "ฉันรักเธอมากพอที่จะเตือนให้รู้ไว้นะ ว่าเธอไม่ได้มีอภิสิทธิ์รอดพ้นจากการโดนปาบอลหิมะใส่หรอกนะ แค่เพราะเราแต่งงานกันน่ะ$14#$b#เงื่อนไขของเราคือ 'ตราบจนความตายจะมาพรากเราจากกัน' ไม่ใช่ 'จนกว่าที่รักของฉันจะปาหิมะใส่ฉัน' ระวังตัวไว้ให้ดีล่ะ$15",
  // WINTER STAR 
  "Festivals.Mateo.winter25.False.1": "ตอนฉันยังเด็ก มาร์ลอนเคยให้ดาบเป็นของขวัญฉันล่ะ ลูอิสหัวฟัดหัวเหวี่ยงเลยล่ะ$13",
  "Festivals.Mateo.winter25.False.2": "ทั้งอาหาร, ของขวัญ, การมีคนอยู่ด้วย - ไม่มีอะไรจะดีไปกว่านี้อีกแล้วล่ะ จริงๆ นะ โดยเฉพาะตอนที่ฤดูหนาวมันน่าเบื่อแบบนี้$1#$b#มาร์ลอนกับกุนเธอร์เคยซื้ออุปกรณ์ผจญภัยให้ฉันตอนเด็กๆ และตอนนี้ฉันก็พร้อมตอบแทนพวกเขาด้วยของขวัญเจ๋งๆ แล้วล่ะ$32",
  "Festivals.Mateo.winter25.False.3": "เธอเป็นคนที่หาของขวัญให้ยากมากเลยนะ @ ",
  "Festivals.Mateo.winter25.True.1": "มันวิเศษมากเลยนะที่ได้เป็นส่วนหนึ่งของอะไรสักอย่าง ส่วนหนึ่งของชุมชน, ของกิลด์, ของครอบครัว เทศกาลทั้งหมดนี้มันทำให้ทุกอย่างรู้สึกเป็นจริงขึ้นมาได้น่ะ$4#$b#%มาเทโอจูบที่ปลายจมูกของนาย$18",
  "Festivals.Mateo.winter25.True.2": "ฉันดีใจมากเลยที่ได้รับการต้อนรับกลับมาอย่างอบอุ่น ฉันคิดถึงเทศกาลพวกนี้ แล้วก็ความรู้สึกเป็นน้ำหนึ่งใจเดียวกันของชุมชนที่เราสร้างขึ้นมาจริงๆ$4",
  "Festivals.Mateo.winter25.True.3": "ฉันมีแผนสำหรับเธอคืนนี้แล้วล่ะ แสงตะวัน หวังว่าเธอจะยอมตามใจฉันนะ$28",
  // RSV GATHERING 
  "Festivals.Mateo.fall20.False.1": "มันเจ๋งดีนะที่ได้ดูทุกคนแข่งกัน แต่ฉันไม่แน่ใจว่าจะอยู่ทีมไหนดี เอาเป็นว่า ฉันขออยู่เป็นเพื่อนตาลุงนี่แทนละกัน$32",
  "Festivals.Mateo.fall20.False.2": "โชว์คืนนี้น่าจะยอดเยี่ยมมากแน่ๆ ฉันมั่นใจเลย$82",
  "Festivals.Mateo.fall20.False.3": "อาหารที่นี่อร่อยมากเลยล่ะ แต่การแข่งขันมันดูน่าอึดอัดไปหน่อยสำหรับฉันนะ$27",
  "Festivals.Mateo.fall20.True.1": "เธออยากจะแยกตัวออกไป แล้วไปสำรวจป่ากับฉันไหม แสงตะวัน?$28",
  "Festivals.Mateo.fall20.True.2": "ขอโทษที ฉันกำลังนึกถึงสถานที่ดีๆ ที่เราจะแอบไปกันแถวๆ นี้อยู่น่ะ มีมุมลับตาคนเต็มไปหมดเลย$35",
  "Festivals.Mateo.fall20.True.3": "อากาศบนภูเขานี่คงทำให้ฉันหน้ามืดหรืออะไรสักอย่างแล้วล่ะ...$31",
  // RSV EMBER OF RESOLUTIONS 
  "Festivals.Mateo.winter28.False.1": "ความเปลี่ยนแปลงคือชุดของการตัดสินใจ ที่เกิดขึ้นเมื่อเวลาผ่านไป เธอไม่จำเป็นต้องเป็นคนเดิมเหมือนเมื่อวานหรอกนะ ถ้าเธอไม่อยากเป็นน่ะ$80",
  "Festivals.Mateo.winter28.False.2": "บอกกับกองไฟไปสิว่าเธออยากจะเป็นใคร แล้วเถ้าถ่านที่ปลิวไปตามสายลมจะปลดปล่อยเธอให้เป็นอิสระเอง$80",
  "Festivals.Mateo.winter28.False.3": "การได้ขึ้นมาอยู่บนนี้ ทำให้ฉันนึกถึงเทือกเขาลึก (Deep Mountains) เลย มันให้ความรู้สึกเหมือนอยู่บ้านนะ แต่มันไม่ได้เกี่ยวอะไรกับริดจ์ไซด์ (Ridgeside) หรอก ฉันก็นึกไม่ออกเหมือนกัน$80",
  "Festivals.Mateo.winter28.True.1": "ฉันตั้งตารอที่จะได้แบ่งปันประสบการณ์นี้ร่วมกับเธอนะ แสงตะวัน$80",
  "Festivals.Mateo.winter28.True.2": "ฉันรักเธอนะ แสงตะวัน ก้าวไปสู่ปีหน้าพร้อมๆ กันเถอะ$80",
  "Festivals.Mateo.winter28.True.3": "เธอช่วยให้ฉันเปลี่ยนไป ตัดสินใจในสิ่งที่ถูกต้อง และเติบโตขึ้น ขอบใจมากนะ แสงตะวัน ฉันรักและซาบซึ้งในตัวเธอมากเลยล่ะ$80",
