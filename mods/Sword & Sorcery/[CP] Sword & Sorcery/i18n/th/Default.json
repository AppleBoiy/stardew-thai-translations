*/
  // PATIO   
  "Marriage.Mateo.Patio.1": "%มาเทโอหาว แล้วยื่นกาแฟในแก้วใบโปรดของนายมาให้[395]#$b#อรุณสวัสดิ์ แสงตะวัน! ขอให้เป็นวันที่ยอดเยี่ยมนะ ตกลงไหม? รักเธอนะ$4",
  "Marriage.Mateo.Patio.2": "%มาเทโอลูบแก้มของนายตอนที่นายเดินผ่าน แล้วประทับจูบลงบนขมับของนาย#$b#ฉันกะจะพูดอะไรสักหน่อยเกี่ยวกับความสวยงามของทิวทัศน์นะ แต่พอเธอเดินออกมา เธอก็ขโมยลมหายใจของฉันไปหมดเลย$4",
  "Marriage.Mateo.Patio.3": "มันมหัศจรรย์มากเลยนะ ที่ได้ตื่นมาแล้วเห็น %pet วิ่งเล่นไปมา ได้มองดูสัตว์เลี้ยงเดินเตร่ และมองดูพืชผลเติบโต$12#$b#ขอบคุณนะที่ให้ฉันได้เป็นส่วนหนึ่งในชีวิตของเธอ แสงตะวัน$4",
  "Marriage.Mateo.Patio.4": "%มาเทโอจูบแก้มของนายก่อนที่นายจะออกไปทำงาน#$b#ไปลุยให้เต็มที่เลยนะ แสงตะวัน ฉันรักเธอ แล้วเจอกันคืนนี้นะ$4",
  "Marriage.Mateo.Patio.5": "ถึงคลินต์ (Clint) จะเข้าสังคมไม่ค่อยเก่ง แต่เขาเป็นครูที่ดีมากเลยนะ ฉันรู้สึกเหมือนเขาพลาดงานที่ใช่สำหรับเขาไปเลย พอเขาได้พูดเรื่องที่เขามั่นใจ เขาทำได้เยี่ยมมาก!$1",
  "Marriage.Mateo.Patio.6": "ขอบคุณนะที่แบ่งพื้นที่ข้างนอกนี้ให้ฉัน แสงตะวัน แล้วก็สนับสนุนความสนใจแปลกๆ ของฉันด้วย$12",
  // SPOUSE ROOM 
  "Marriage.Mateo.SpouseRoom.1": "รู้ไหม... ฉันไม่เคยมีภาพชัดเจนเลยว่าชีวิตของฉันจะเป็นยังไง จนกระทั่งเธอหาทางมาเจอฉันนี่แหละ$29#$b#และตอนนี้ ฉันได้ใช้ชีวิตร่วมกับเธอ ฉันคงไม่ขออะไรมากไปกว่านี้แล้วล่ะ$27",
  "Marriage.Mateo.SpouseRoom.2": "หลายปีมานี้ฉันย้ายอพาร์ตเมนต์มาเยอะมาก หอพักก็ด้วย ไม่เคยมีที่ไหนให้ความรู้สึกมั่นคงถาวรเลย$8#$b#แต่ตอนนี้ฉันมีบ้านแล้ว แล้วก็มีกิลด์ด้วย เป็นที่ที่พายุร้ายๆ จะพัดมาพังมันไม่ได้ง่ายๆ และฉันซาบซึ้งกับมันมากๆ เลย ขอบคุณนะ @$1",
  "Marriage.Mateo.SpouseRoom.3": "หนังสือหลายเล่มของฉันค่อนข้างน่าเบื่อนะ ฉันไม่แน่ใจว่ามันจะช่วยอะไรเธอได้มากแค่ไหน เผื่อว่าเธออยากจะลองหยิบมาเปิดอ่านดูน่ะ$37#$b#แต่เธอหยิบอะไรตรงนี้ไปอ่านก็ได้เลยนะ โอเคไหม? โดยเฉพาะถ้าจู่ๆ เธอเกิดสนใจเรื่องคนที่ตายไปนานแล้วหรือของเก่าๆ ขึ้นมาน่ะ$32",
  "Marriage.Mateo.SpouseRoom.4": "%มาเทโอกำลังจ้องมองใบปริญญาเอกของตัวเองที่แขวนอยู่บนผนัง เขาดูภูมิใจมาก แม้ว่าจะเป็นสิ่งที่เขาไม่ค่อยพูดถึงบ่อยนักก็ตาม#$b#ไง แสงตะวัน โทษทีนะ แค่รู้สึกดีมากๆ ที่เรียนจบมหาลัยมาได้น่ะ ฉันได้ทำในสิ่งที่รัก และหลายคนก็พูดแบบเดียวกันนี้ไม่ได้ ฉันเป็นคนที่โชคดีมากๆ เลยนะ$4",
  "Marriage.Mateo.SpouseRoom.5": "%นายเข้าไปประทับจูบที่แก้มของมาเทโอ แต่จู่ๆ เขาก็หันหน้ามาประกบริมฝีปากของนายแทน",
  // FUN LEAVE & FUN RETURN
  "Marriage.Mateo.funLeave.1": "ฉันจะออกไปข้างนอกนะ แสงตะวัน จะไปดูความเรียบร้อยที่กิลด์หน่อย แล้วก็จะไปเยี่ยมโครบุสด้วย แต่เดี๋ยวฉันก็กลับมา สัญญาเลย รักเธอนะ!$4#$b#%มาเทโอประคองใบหน้าของนายด้วยสองมือ แล้วประทับจูบอย่างอ่อนโยนลงบนริมฝีปากของนาย",
  "Marriage.Mateo.funLeave.2": "แสงตะวัน ฉันจะไปดูความเรียบร้อยที่กิลด์หน่อยนะ น่าจะเดินตรวจตราแล้วก็แวะไปหากุนเธอร์กับมาร์ลอนด้วย$0#$b#แล้วเจอกันตอนมื้อค่ำนะ ตกลงไหม? รักเธอนะ$4",
  "Marriage.Mateo.funLeave.3": "ฉันหวังจริงๆ นะว่าการมีไดโนเสาร์พ่นไฟได้อยู่ในบ้านจะไม่สร้างผลเสียอะไร ฉันขอไปหาถังดับเพลิงมาเพิ่มก่อนนะ$34",
  "Marriage.Mateo.funReturn.1": "ไง แสงตะวัน ดีใจจังที่ได้กลับบ้าน ฉันคิดถึงเธอแทบแย่เลยล่ะ$30",
  "Marriage.Mateo.funReturn.2": "ไง แสงตะวัน ดีใจจังที่เธออยู่บ้าน ฉันคิดถึงเธอทั้งวันเลยนะ$28",
  "Marriage.Mateo.funReturn.3": "ไง แสงตะวัน รู้สึกเป็นยังไงบ้าง? บางทีเราอาจจะเอนหลังพักผ่อนกันสักหน่อยดีไหม$4",
  // SPECIAL DATES - SPRING
  "Marriage.Mateo.Spring": "ฉันมักจะรู้สึกตื่นเต้นมากตอนต้นปีใหม่ เหมือนฉันมีพลังงานที่หลับใหลอยู่ข้างในพร้อมจะระเบิดออกมา เธออยากจะช่วยจัดการเรื่องนั้นไหม แสงตะวัน?$28",
  "Marriage.Mateo.Spring1": "มันเป็นจุดเริ่มต้นของปีใหม่ และไม่มีอะไรจะทำให้ฉันมีความสุขมากไปกว่าความคิดที่จะได้ใช้เวลานี้ทั้งหมดไปกับเธอ ฉันรักเธอนะ แสงตะวัน ตลอดไปและเสมอมา$4",
  "Marriage.Mateo.Spring13": "ลูอิส (Lewis) ขอให้ฉันช่วยซ่อนไข่ล่ะ แต่ถ้าฉันทำนะ คงไม่มีใครหามันเจอหรอก เราน่าจะฮั้วกันนะ @ ฉันน่าจะเอาไปซ่อนในที่แปลกๆ ที่มีแค่เธอเท่านั้นที่รู้น่ะ$13#$b#แต่นั่นมันคงไม่ค่อยแฟร์กับพวกเด็กๆ เท่าไหร่ใช่ไหมล่ะ? เอาเถอะ โชคดีนะสำหรับวันนี้ แสงตะวัน$1",
  "Marriage.Mateo.Spring23": "พรุ่งนี้เป็นงานเต้นรำดอกไม้ (Flower Dance) แล้ว - เตรียมชุดพร้อมหรือยัง? ฉันตั้งตารอที่จะได้เห็นเธอแต่งตัวสวยๆ อยู่นะ$27",
  "Marriage.Mateo.Spring24": "มันดีจังเลยนะที่มีคนที่คุ้มค่าพอให้แต่งตัวหล่อๆ ไปหา ตอนไปงานเต้นรำดอกไม้ครั้งแรกฉันไม่ได้ใส่สูทนะ แต่ตอนนี้ฉันตั้งตารอที่จะใส่มันแล้วล่ะ$4",
  "Marriage.Mateo.Spring28": "ใกล้จะเข้าฤดูร้อนแล้ว! และหลังจากนั้น ก็จะใกล้เข้าฤดูใบไม้ร่วงอีก! ฉันรู้ ฉันตื่นเต้นไปแล้วล่ะ ฉันแค่ชอบดูว่าทุกอย่างมันเปลี่ยนแปลงไปยังไงน่ะ$1",
  // SPECIAL DATES - SUMMER
  "Marriage.Mateo.Summer": "ถึงช่วงเวลาของปีที่ฉันจะใส่เสื้อปลดกระดุมได้อย่างมีเหตุผลแล้ว! ไม่ใช่ว่าเคยมีใครมาวุ่นวายเรื่องนี้กับฉันหรอกนะ แต่ฉันก็แอบกังวลมาตลอดว่ารอยแผลเป็นพวกนี้มันจะทำให้เด็กๆ กลัวหรือเปล่าน่ะ$14#$b#แถมฉันก็รู้ด้วยว่าเธอชอบวิวนี้นะ แสงตะวัน$15",
  "Marriage.Mateo.Summer1": "ข้างนอกร้อนมากเลย อย่าปล่อยให้ความชื้นทำให้เธออารมณ์บูดนะ แสงตะวัน อย่าลืมดื่มน้ำเยอะๆ ล่ะ$0",
  "Marriage.Mateo.Summer11": "วันนี้ฉันมีซุปฟักทองบดมานิดหน่อยสำหรับงานเทศกาลด้วย! ฉันมั่นใจเลยว่าอะไรก็ตามจากฟาร์ม %farm จะต้องเป็นส่วนผสมที่ยอดเยี่ยมแน่ๆ - เธอมีรสนิยมดีในเรื่องพวกนี้นี่นา$0#$b#แต่ฉันก็สงสัยนะว่าซุปนั่นมันอร่อยได้ยังไงทั้งๆ ที่ใส่ของผสมกันลงไปมั่วซั่วไปหมดน่ะ$37",
  "Marriage.Mateo.Summer28": "แมงกะพรุนแสงจันทร์นี่มันเป็นความมหัศจรรย์ทางระบบนิเวศเลยเนอะ? ฉันตื่นเต้นที่จะได้เห็นพวกมันทุกปีเลย$4#$b#แสงเรืองรองจางๆ ของพวกมันหมายความว่าฤดูใบไม้ร่วงกำลังจะมาเยือนในไม่ช้า และนอกจากนั้น ไม่มีอะไรจะทำให้ฉันมีความสุขไปกว่าการได้ใช้เวลายามเย็นบนชายหาดกับทุกคน โดยเฉพาะกับเธอ @$27",
  // SPECIAL DATES - FALL
  "Marriage.Mateo.Fall": "มันเป็นช่วงเวลาที่ดีที่สุดของปีเลย! ทั้งทำกำไรให้ฟาร์ม %farm ได้ดี อากาศก็เย็นสบาย สดชื่น ฉันได้เห็นเธอใส่เสื้อแจ็คเก็ตของฉัน - ฟังนะ ฉันน่ะชอบการแชร์เสื้อผ้ากันใส่จะตาย$30#$b#ตัวเธอ ที่ใส่เสื้อของฉัน ยืนอยู่กลางทุ่งฟักทอง แครนเบอร์รี่ และดอกทานตะวันของเธองั้นเหรอ? นั่นแหละคือคำว่าสมบูรณ์แบบในสายตาฉันล่ะ$27",
  "Marriage.Mateo.Fall1": "มันเป็นช่วงเวลาที่ดีที่สุดของปีเลย! ทั้งทำกำไรให้ฟาร์ม %farm ได้ดี อากาศก็เย็นสบาย สดชื่น ฉันได้เห็นเธอใส่เสื้อแจ็คเก็ตของฉัน - ฟังนะ ฉันน่ะชอบการแชร์เสื้อผ้ากันใส่จะตาย$30#$b#ตัวเธอ ที่ใส่เสื้อของฉัน ยืนอยู่กลางทุ่งฟักทอง แครนเบอร์รี่ และดอกทานตะวันของเธองั้นเหรอ? นั่นแหละคือคำว่าสมบูรณ์แบบในสายตาฉันล่ะ$27",
  "Marriage.Mateo.Fall15": "@ ฉันขุดเจอมันแล้วก็เอาไปเจียระไนมาให้เธอสำหรับจัดแสดงในงานเทศกาลพรุ่งนี้น่ะ[72]$0#$b#การมีของที่มีคุณภาพสูงหลากหลายรูปแบบเป็นวิธีที่ดีที่สุดที่จะชนะใช่ไหมล่ะ? ฉันมั่นใจว่าเธอเตรียมตัวมาพร้อมแล้วล่ะ ฉันแค่หวังว่าจะช่วยอะไรเธอได้บ้างน่ะ$1",
  "Marriage.Mateo.Fall16": "โชคดีนะสำหรับวันนี้ แสงตะวัน! ฉันรู้ว่าเธอน่ะชนะใสๆ อยู่แล้ว เธอทำงานหนักมาก และฟาร์ม %farm ก็สมควรได้รับการยอมรับจากทุกคน$32#$b#และแน่นอน ฉันก็มีแผนจะจัดแสดงความชื่นชมในแบบของฉันให้เธอด้วย ตอนที่เรากลับถึงบ้านน่ะ$31",
  "Marriage.Mateo.Fall25": "อรุณสวัสดิ์ แสงตะวัน มีแค่อย่างเดียวที่ดีกว่าการได้ตื่นมาข้างๆ เธอในวันเกิดของฉัน-$28#$b#-และนั่นก็คือการจะได้เห็นเธอโน้มตัวทำอะไรสักอย่างในภายหลังไงล่ะ$30#$b#%มาเทโอประคองใบหน้าของนายด้วยสองมือแล้วจูบนาย เขาดูจะต้องการนายมากกว่าปกตินะ",
  "Marriage.Mateo.Fall26": "เธอรู้ใช่ไหมว่าพรุ่งนี้คือวันอะไร @ วันที่ดีที่สุดเป็นอันดับสองของปี เป็นรองแค่วันครบรอบของเราเท่านั้นแหละ[746]$1#$b#ฉันเตรียมตัวมาตลอดทั้งฤดูกาลเลย แต่ตอนนี้มันถึงเวลาเอาจริงแล้วล่ะ$13",
  "Marriage.Mateo.Fall27": "จำกฎไว้ให้ดีนะ @! ตรวจดูขนมให้ดี แต่งชุดคอสตูม แจกขนมเด็กๆ และที่สำคัญที่สุด - ห้ามเป่าตะเกียงฟักทองดับก่อนเที่ยงคืนเด็ดขาด!$32#$b#คืนนี้มีอะไรให้ทำตั้งเยอะแยะ! รวมถึงเธอด้วย$13#$b#%มาเทโอจับไหล่ของนายแล้วจูบที่ปลายจมูกของนาย",
  // SPECIAL DATES - WINTER 
  "Marriage.Mateo.Winter": "%จู่ๆ มาเทโอก็ดึงเสื้อฮู้ดตัวเก่งสวมหัวนาย ก่อนจะใช้สายรัดดึงนายเข้ามาจูบ#$b#ปลอดภัยไว้ก่อน แล้วก็ทำตัวให้อุ่นเข้าไว้นะ แสงตะวัน โดยเฉพาะถ้าเธอตัดสินใจจะออกไปผจญภัยน่ะ$4",
  "Marriage.Mateo.Winter1": "มาถึงช่วงเวลานี้ของปีอีกแล้วสิ ช่วงที่อากาศมันหดหู่ไปหมด เรามาพยายามติดต่อกับเพื่อนๆ ให้มากขึ้นกันเถอะ$12",
  "Marriage.Mateo.Winter8": "ดีจังเลยนะที่ทุกคนสละเวลามาเจอหน้ากันในช่วงฤดูหนาวน่ะ ไม่งั้นมันคงจะรู้สึกเหงามากๆ เลย$12#$b#ขอให้ตกปลาโชคดีนะ แสงตะวัน ฉันจะคอยเชียร์เธออยู่ข้างสนามนะ$27",
  "Marriage.Mateo.Winter12": "วันนี้วันเกิดกุนเธอร์ เขาเป็นคนประเภทที่ฉันไม่รู้เลยว่าจะซื้ออะไรให้ดี... เธอจะซื้ออะไรให้คนที่มีทุกอย่างอยู่แล้วดีล่ะ?$37",
  "Marriage.Mateo.Winter14": "ตลาดกลางคืน (Night Market) จะเริ่มพรุ่งนี้นะ @ อย่าลืมไปเช็คดูนะว่าพ่อค้าแม่ค้าเขามีอะไรมาขายบ้าง - เธอไม่มีทางรู้เลยว่าพวกเขาจะเอาอะไรมาบ้างน่ะ$1",
  "Marriage.Mateo.Winter19": "วันนี้วันเกิดมาร์ลอนล่ะ! ฉันไม่รู้เลยว่าตาแก่นั่นอยากได้อะไร เขามีอาวุธยุทโธปกรณ์เจ๋งๆ ครบทุกอย่างแล้ว บางทีอาจจะเป็นของที่ช่วยซ่อมบำรุงมันล่ะมั้ง$35",
  "Marriage.Mateo.Winter24": "ตัวเธอเองก็เป็นของขวัญอยู่แล้ว @ พรุ่งนี้ฉันไม่ต้องการอะไรเลยนอกจากมีเธออยู่ด้วยก็พอแล้ว$27",
  "Marriage.Mateo.Winter25": "สุขสันต์วันเทศกาลนะ แสงตะวัน ฉันมีของขวัญให้มาร์ลอนกับกุนเธอร์นะ แต่ของขวัญของเธอคงต้องรอให้จบเทศกาลก่อนล่ะ$28",
  "Marriage.Mateo.Winter28": "ฤดูหนาวใกล้จะจบลงสักที ฉันไม่ได้มีปัญหาใหญ่อะไรกับมันเหมือนแต่ก่อนแล้วล่ะ แต่ฉันก็ยังดีใจอยู่ดีที่ฤดูกาลจะเปลี่ยนแล้ว$32#$b#อีกไม่นานทุ่งนาของเธอก็จะเต็มไปด้วยพืชผล %pet ก็จะได้ออกมาวิ่งเล่นข้างนอก แล้วทุกอย่างก็จะกลับมารู้สึกปกติอีกครั้ง$1#$b#แต่นั่นไม่ได้หมายความว่าคืนนี้ฉันจะปล่อยให้มันสูญเปล่าหรอกนะ เธอสมควรได้รับจูบที่น่าจดจำตอนที่เข็มนาฬิกาข้ามวันใหม่นะ$31",
  // GENERIC DIALOGUE - RAINY
  "Marriage.Mateo.Rainy.Day.0": "วันนี้เป็นวันที่ดีมากที่จะไปผจญภัยนะ แสงตะวัน ในเมื่อเธอไม่ต้องรดน้ำอะไรเลยนี่นา เอาเจ้านี่ไปสิ เผื่อเธอต้องใช้น่ะ$1#$b#และบางทีฉันอาจจะลงไปเจอเธอข้างล่างนั่นนะ$32[243]",
  "Marriage.Mateo.Rainy.Day.1": "ฉันรักสายฝนนะ ไม่ใช่แค่เพราะเธอดูน่าจะผ่อนคลายขึ้นหน่อยเวลาฝนตกหรอก แต่เพราะมันรู้สึกเหมือนอะไรๆ มันก็ช้าลงน่ะ$0#$b#เอเมริทัสคิดถูกแล้วล่ะ เขาเลยใช้ชีวิตช้าๆ สบายๆ$1",
  "Marriage.Mateo.Rainy.Day.2": "ในวันที่อากาศแบบนี้ ไม่มีอะไรจะดีไปกว่าไวน์สักแก้วกับหนังสือดีๆ สักเล่มแล้วล่ะ$0#$b#บทความวิชาการที่ดีที่สุดบางชิ้นของฉันก็เขียนตอนช่วงที่มีพายุนี่แหละ ฉันไม่รู้ว่ามันเป็นเพราะอะไร แต่สภาพอากาศแบบนี้มันทำให้หัวฉันแล่นได้ดีน่ะ$1",
  "Marriage.Mateo.Rainy.Day.3": "วันนี้ฉันจะใช้เวลาสะสางงานบ้านสักหน่อยล่ะ ไม่ใช่งานบ้านทั่วไปหรอกนะ แต่เป็นการทำความสะอาดแบบหมดจดเลย$24#$b#ฉันไม่รู้ว่าอะไรในสายฝนที่ทำให้ฉันอยากจะเช็ดทำความสะอาดตั้งแต่พื้นยันบัวเชิงเพดานขนาดนี้ แต่ก็นะ มันก็เป็นการใช้เวลาให้เป็นประโยชน์ล่ะนะ$14",
  "Marriage.Mateo.Rainy.Day.4": "ทายสิว่าฉันทำอะไรไว้ให้ในวันที่อากาศหดหู่ได้อย่างสมบูรณ์แบบแบบนี้? [236]$0#$b#ซุปไง! ทานให้อร่อยนะ @ ฉันรู้ว่าการพยายามทำตัวให้แห้งตอนอยู่ข้างนอกนั่นมันยาก แต่ก็ทำให้ดีที่สุดนะ อย่าหักโหมทำงานหนักเกินไปล่ะ เดี๋ยวฉันจะเอาไปแบ่งให้โครบุสด้วย$1",
  "Marriage.Mateo.Rainy.Day.5": "พวกสัตว์เลี้ยงในฟาร์มจะรู้สึกอะไรกับการที่ฝนตกบ้างไหมนะ เพราะพวกมันต้องติดอยู่แต่ข้างในน่ะ$16#$b#ฉันหวังว่าพวกมันจะไม่เบื่อนะ หรือบางทีพวกมันอาจจะชอบใจที่ได้พักผ่อนเหมือนกับพวกเราก็ได้",
  "Marriage.Mateo.Rainy.Day.6": "ฉันรักเธอนะ @ ฉันหวังว่าเธอจะอยู่ข้างในกับฉันได้ แต่ฉันรู้ว่าเธอมีเรื่องต้องทำ แค่เพิ่มฉันลงไปในรายการสิ่งที่ต้องทำทีหลังด้วยล่ะ ตกลงไหม?$31",
  "Marriage.Mateo.Rainy.Night.0": "วันนี้ฉันไปเจอมันมาตอนสำรวจน่ะ แสงตะวัน ฉันตื่นเต้นมากเลยที่จะเอามันกลับมาให้เธอ[275]$1#$b#แต่ตอนนี้เราทั้งคู่ก็อยู่บ้านแล้ว ได้เวลาพักผ่อนและผ่อนคลายแล้วล่ะ$32",
  "Marriage.Mateo.Rainy.Night.1": "ฉันคิดว่าค่ำคืนนี้ของเราน่าจะเป็นแบบนี้นะ: เธอ, ฉัน, และไวน์สักขวด$28#$b#แต่ก่อนอื่นเรามาถอดเสื้อผ้าเปียกๆ ของเธอออกก่อนดีกว่าไหม?$30",
  "Marriage.Mateo.Rainy.Night.2": "โอ้ ฉันเห็นด้วย มันดึกเกินกว่าจะดื่มกาแฟแล้วล่ะ แต่ฉันก็ชงมาให้แล้วนะ[395]$28#$b#บางทีฉันอาจจะมีเหตุผลที่อยากให้เธออยู่ดึกๆ ก็ได้นะ$31",
  "Marriage.Mateo.Rainy.Night.3": "ไง แสงตะวัน ฉันทำความสะอาดและลงออยล์ให้รองเท้าบูทของเธอทุกคู่ตอนที่เธอไม่อยู่น่ะ ตอนนี้มันน่าจะกันน้ำได้ดีขึ้นนิดหน่อยแล้วล่ะ$1#$b#ใส่ถุงเท้าหนาๆ คู่กับมันนะ แล้วเธอจะรู้สึกสบายขึ้นเยอะเลย$32",
  "Marriage.Mateo.Rainy.Night.4": "วันนี้ฉันไปเยี่ยมโครบุสมาล่ะ! เขาสบายดี ฉันแค่เป็นห่วงน่ะ เขาขอให้ฉันพาเอเมริทัสไปด้วยในครั้งหน้านะ$4",
  "Marriage.Mateo.Rainy.Night.5": "ฉันใช้เวลาทั้งวันอยู่กับ %pet ทำงานวิชาการไปนิดหน่อยน่ะ การมีอะไรให้ทำมันทำให้รู้สึกดีเสมอแหละ แต่ฉันก็ดีใจนะที่เธอกลับมาแล้ว$4#$b#เรามากอดกันแล้วใช้เวลาด้วยกันเถอะ แสงตะวัน$27",
  "Marriage.Mateo.Rainy.Night.6": "นั่นความรักในชีวิตฉันนี่ กลับมาจาก - โอ้ เธอเปียกโชกเลย ให้ฉันช่วยนะ$30",
  "Marriage.Mateo.Rainy.Night.Mateo": "แสงตะวัน ฉันทำของว่างให้เธอด้วยล่ะ! $1[608]#$b#ฉันรู้ พายเนี่ยนะ ดูเป็นพ่อบ้านพ่อเรือนจัง เอาเถอะ บางทีฉันอาจจะชอบการเป็นแบบนั้นก็ได้นะ$80",
  // GENERIC DIALOGUE - INDOOR & OUTDOOR
  "Marriage.Mateo.Indoor.Day.0": "ช่วงนี้ฉันยุ่งอยู่กับการเขียนบทความวิชาการ โดยมีโครบุสช่วยน่ะ เหตุการณ์ทั้งหมดนั้นมันเปลี่ยนมุมมองของฉันไปเลยจริงๆ$0",
  "Marriage.Mateo.Indoor.Day.1": "ฉันน่าจะแวะไปคุยกับมาร์ลอนหน่อย ถ้าตาแก่นั่นคิดว่าเขาจะกำจัดฉันพ้นทางได้เพียงเพราะฉันแต่งงานแล้วก็มีตึกเป็นของตัวเองล่ะก็ เขาคิดผิดแล้วล่ะ$1#$b#ฉันรู้สึกอยากออกไปผจญภัยมากกว่าที่เคยเป็นมาซะอีกนะเนี่ย$32",
  "Marriage.Mateo.Indoor.Day.2": "อรุณสวัสดิ์ แสงตะวัน ฉันจะติดต่อไปหาเพื่อนร่วมงานสักหน่อย เพื่อทำงานวิชาการเพิ่มน่ะ$0#$b#ถ้า %pet ยอมให้ฉันทำน่ะนะ เหมือนพวกมันพยายามจะช่วยเลยนะ พยายามอย่างดีที่สุดแล้ว-$14#$b#-ดีที่สุดของมันก็ยังไม่ค่อยจะดีเท่าไหร่นี่สิ$15",
  "Marriage.Mateo.Indoor.Day.3": "ฉันไม่มีความรู้เรื่องอะไรที่เกี่ยวกับการเกษตรเลยนะ แต่ถ้าท่อสปริงเกลอร์แตก ฉันซ่อมได้นะ!$36#$b#หลายปีมานี้ฉันได้ทักษะงานช่างแปลกๆ มาเยอะเลย ฉันยังงัดประตูให้เรากลับเข้าบ้านได้ด้วยนะในกรณีที่เราเผลอล็อคตัวเองไว้ข้างนอกน่ะ แต่นั่นมันก็ไม่ใช่ประเด็นหรอกนะ...$7",
  "Marriage.Mateo.Indoor.Day.4": "เป็นวันที่อากาศดีจัง หลังจากทำงานบ้านเสร็จ ฉันจะพา %pet ออกไปข้างนอกสักหน่อย บางทีพวกมันอาจจะได้เล่นกับเอเมริทัสด้วย!$14#$b#นายจะเรียนรู้ที่จะชื่นชมความงามของทุ่งนาที่ทอดยาวและท้องฟ้าที่ไร้เมฆหมอกได้จริงๆ ก็ต่อเมื่อนายต้องใช้เวลาอยู่ในเหมืองเยอะๆ นั่นแหละ$35",
  "Marriage.Mateo.Indoor.Day.5": "มานี่สิ แสงตะวัน ขอให้เป็นวันที่ยอดเยี่ยมนะ ตกลงไหม? ฉันจะคิดถึงเธอนะ$27#$b#%มาเทโอเชยคางของนายขึ้น แล้วจูบนายอย่างอ่อนโยน",
  "Marriage.Mateo.Indoor.Night.0": "วันนี้ %pet ไปกลิ้งคลุกโคลนมา ฉันเลยต้องจับพวกมันอาบน้ำ ไม่สนุกเอาซะเลย$9#$b#ฉันโดนข่วนมานิดหน่อยด้วย เธอจะช่วยจูบปลอบขวัญให้หายเจ็บได้ไหม?$29",
  "Marriage.Mateo.Indoor.Night.1": "แสงตะวัน วันนี้ฉันคิดถึงเธอจังเลย แล้วก็ดีใจมากๆ ที่เธอกลับมาบ้านแล้ว$29#$b#เรามาใช้เวลาอยู่ด้วยกันเถอะ นี่มันก็ดึกมากแล้ว ฉันว่าคงไม่มีใครอยู่บนบ่อน้ำพุร้อนแล้วล่ะ...$31",
  "Marriage.Mateo.Indoor.Night.2": "ฉันรู้สึกเหมือนเคลียร์งานไปได้เยอะเลยในออฟฟิศที่นี่ ฉันว่าคนเราคงไม่เห็นค่าของไฟฟ้าจริงๆ จนกว่าจะไม่มีมันให้ใช้นั่นแหละ$37#$b#ฉันซาบซึ้งใจที่มีเธอนะ แสงตะวัน เธอช่วยดึงฉันกลับมาสู่เส้นทางที่ถูกต้องในหลายๆ เรื่องเลย$32#$b#ถึงอย่างนั้น ถ้าเธออยากจะแวะไปที่กิลด์แล้วไปสนุกกันตอนที่ไม่มีใครอยู่ล่ะก็ ฉันก็ไม่ขัดข้องหรอกนะ$36",
  "Marriage.Mateo.Indoor.Night.3": "บางครั้ง พอนายเก่งอะไรสักอย่าง นายก็จะคิดว่านั่นคือสิ่งเดียวที่ทำให้นายมีคุณค่า$8#$b#ฉันเคยรู้สึกแบบนั้นกับการตามล่าหาสมบัติ, กับงานวิชาการ, แล้วก็กับกิลด์น่ะ$2#$b#แต่ฉันเริ่มเข้าใจแล้วว่ามันไม่จริงเลย แค่ฉันเป็นของเธอ แค่นั้นก็เพียงพอแล้ว ทุกสิ่งทุกอย่างเป็นเรื่องรองไปเลย$27",
  "Marriage.Mateo.Indoor.Night.4": "สิ่งเดียวที่ฉันชอบเวลาที่เธอไม่อยู่คือฉันสามารถเปิดเพลงน่าอายๆ ดังลั่นบ้านได้นี่แหละ$32#$b#เดี๋ยว เธอได้ยินเสียงมันออกไปข้างนอกเลยเหรอ?$3#$b#โอ้ เวรล่ะ ฉันไม่ทันรู้ตัวเลยว่ามันดังขนาดนั้น$11#$b#...ฉันไม่ขอโทษหรอกนะ เธอเลือกจะแต่งกับฉันเองนี่ คืนคำไม่ได้แล้วล่ะ$13",
  "Marriage.Mateo.Indoor.Night.4.Filtered": "สิ่งเดียวที่ฉันชอบเวลาที่เธอไม่อยู่คือฉันสามารถเปิดเพลงน่าอายๆ ดังลั่นบ้านได้นี่แหละ$32#$b#เดี๋ยว เธอได้ยินเสียงมันออกไปข้างนอกเลยเหรอ?$3#$b#โอ้ ให้ตายสิ ฉันไม่ทันรู้ตัวเลยว่ามันดังขนาดนั้น$11#$b#...ฉันไม่ขอโทษหรอกนะ เธอเลือกจะแต่งกับฉันเองนี่ คืนคำไม่ได้แล้วล่ะ$13",
  "Marriage.Mateo.Indoor.Night.5": "%มาเทโอเอาแขนคล้องคอของนาย แล้วทิ้งน้ำหนักพิงนายมากเกินไปหน่อย#$b#แรงโน้มถ่วงมันเพิ่มขึ้นกับตัวฉันน่ะ ฉันพยุงตัวเองไม่ไหวแล้ว...$18#$b#สงสัยเราคงต้องติดอยู่ด้วยกันท่านี้แหละ ไม่งั้นฉันล้มแน่ๆ$28",
  "Marriage.Mateo.Indoor.Night.6": "ฉันดีใจนะที่ได้ซึมซับแสงสว่างบางส่วนที่เปล่งประกายออกมาจากตัวเธอในวันนี้นะ แสงตะวัน #ทีนี้...เราไปนอนกันเถอะไหม?$31",
  "Marriage.Mateo.Outdoor.0": "มีสัตว์เยอะแยะเลย ฉันประทับใจมากเลยนะที่เธอดูแลพวกมันได้ดีขนาดนี้ ทั้งๆ ที่ต้องจัดการเรื่องไร่นาไปด้วยน่ะ$32#$b#มันเป็นภาพที่น่าทึ่งมากเลย เธอพลิกฟื้นผืนดินที่เคยรกร้างให้กลายเป็นอะไรที่มหัศจรรย์ได้ขนาดนี้$1",
  "Marriage.Mateo.Outdoor.1": "สถานที่ที่สวยงามแห่งนี้ ที่ที่ภูเขาบรรจบกับท้องทะเล... มันเต็มไปด้วยความงดงามจริงๆ เนอะ?$4#$b#ถึงจะมีความวุ่นวายอยู่บ้าง แต่มันก็ยังคุ้มค่ามากที่ได้มีชีวิตอยู่เพื่อเห็นมันนะ$27",
  "Marriage.Mateo.Outdoor.2": "ฉันสงสัยจังว่าเราจะโน้มน้าวโครบุสให้มาอยู่ที่ฟาร์ม %farm ได้ไหมนะ...$37",
  "Marriage.Mateo.Outdoor.3": "อ่ะ เอาอันนี้ไปที ฉันดื่มไปสามแก้วแล้ววันนี้ และฉันรู้ตัวว่ามันเกินลิมิตไปแล้ว เดี๋ยวฉันต้องมีอาการใจสั่นแน่ๆ$6[395]",
  "Marriage.Mateo.Outdoor.4": "หลังจากเธอทำงานเสร็จ เราน่าจะออกไปในเมืองกันนะ อาจจะไปที่ร้านซาลูน หรือไม่ก็ไปที่กิลด์$1#$b#ได้กินอาหารอุ่นๆ, หัวเราะกับมุกแป้กๆ, อยู่กับเพื่อนดีๆ ฟังดูเข้าท่าสำหรับฉันเลยนะ!$32",
  "Marriage.Mateo.Outdoor": "%มาเทโอกำลังเหม่อมองออกไปไกลๆ โดยไม่ทันสังเกตว่านายยืนอยู่ตรงนั้น#$b#ฉันสามารถวางดาบลงข้างๆ ดอกไม้ได้แล้ว... ช่างเป็นตอนจบที่มีความสุขจริงๆ$12.",
  // GENERIC DIALOGUE - KIDS 
  "Marriage.Mateo.OneKid.0": "เมื่อเช้านี้ %kid1 ปีนขึ้นไปบนชั้นหนังสือล่ะ ไม่รู้ทำได้ไง$8#$b#แกตะโกนว่าตัวเองคือ คิงแคงจูเนียร์ (King Kang Jr) แล้วก็ไม่ยอมลงมา แต่ฉันก็ไม่เสียใจหรอกนะที่ให้แกดูหนังเรื่องนั้นน่ะ$32#$b#บางทีรอบหน้าเราอาจจะดู คิงแคง ปะทะ ม็อดซิลล่า (Modzilla) แล้วปั่นหัวแกให้สับสนไปเลยดีกว่า$15",
  "Marriage.Mateo.OneKid.1": "เจ้าไคจูตัวน้อยตัดสินใจแล้วล่ะว่า บอทรา (Bothra) เป็นหนังสัตว์ประหลาดเรื่องใหม่ที่แกชอบที่สุด $14#$b#เมื่อวานยังเป็น หัวกริช (Daggerhead) อยู่เลย ฉันดีใจนะที่แกรสนิยมดี$15",
  "Marriage.Mateo.OneKid.2": "วันนี้ฉันพยายามจะถอดชุดนอนวันพีซของ %kid1 ออกมาซักน่ะ$9#$b#แกตะโกนว่า 'ม่ายยยย อย่าถอดหนังหนู!'$25#$b#ฉันยอมรับเลยว่าเรื่องนี้ไม่ใช่ความผิดใครนอกจากฉันเอง ฉันหวังว่าเธอจะอยากได้ลูกเปปเปอร์เร็กซ์ (Pepper Rexes) ตัวน้อยนะ แสงตะวัน เพราะนั่นคือสิ่งที่เรามีตอนนี้แหละ$25",
  "Marriage.Mateo.OneKid.3": "ฉันปล่อย %kid1 ไว้คนเดียวแค่ห้านาทีเพื่อไปล้างจานมื้อเที่ยง พอกลับมา เมืองบล็อกของเล่นที่เราต่อกันเมื่อเช้าก็พังพินาศไปแล้ว$9#$b#แกเหยียบมันพังยับเยิน แล้วก็กำลังเคี้ยวหัวหุ่นแอคชั่นฟิกเกอร์อยู่ เราควรจะกังวลไหมเนี่ย?$26",
  "Marriage.Mateo.TwoKids.0": "ฉันคิดว่ามันน่าจะน่ารักดีถ้าให้เด็กๆ กินนักเก็ตไก่รูปไดโนเสาร์ เห็นชัดๆ ว่ามันเป็นของโปรดวัยเด็ก แกตะโกนใส่ฉันว่าฉันกำลังสนับสนุนการกินเนื้อเผ่าพันธุ์เดียวกัน$20#$b#ฉันไม่ได้สอนพวกแกแบบนั้นนะ สาบานได้ ฉันว่าฉันควรไปเช็คดูหน่อยแล้วล่ะว่าพวกแกอ่านหนังสืออะไรกันอยู่$11",
  "Marriage.Mateo.TwoKids.1": "ถ้าเธอสงสัยว่าทำไม %kid2 ถึงโดนลงโทษเข้ามุม (time-out) ก็เพราะแกปาหนังสือใส่หัวฉันไง %kid1 ก็โดนลงโทษด้วยเพราะเป็นคนยุให้ทำ อยากรู้ไหมว่าทำไม?$10#$b#เพราะฉันเผลอพูดแทรกฉากโปรดของพวกแกในหนัง ทรีแอสสิค พาร์ค (Triassic Park) ซึ่งแกดูมาสามรอบแล้วในวันนี้$9",
  "Marriage.Mateo.TwoKids.2": "เธอซื้ออูคูเลเล่ให้ %kid1 กับ %kid2 หรือเปล่า? ไม่เหรอ? แล้วพวกแกไปเอามันมาจากไหน-?...มีเรื่องใหม่ๆ ได้ทุกวันเลยนะเด็กพวกนี้$9#$b#เด็กที่คิดว่าตัวเองเป็นไดโนเสาร์ที่เล่นเครื่องดนตรีได้ โอเคนะ นั่นก็ปกติดีแหละ$7",
  "Marriage.Mateo.TwoKids.3": "ฉันเปิดเพลงที่ฉันชอบให้เจ้าพวกไคจูตัวน้อยฟัง ฉันคิดว่ามันน่าจะน่ารักดีไง รู้ไหม จะได้สานสัมพันธ์กับพวกแกน่ะ$8#$b#ฉันไม่ทันคิดเลยว่าพวกแกจะร้องตามบ่อยขนาดไหน ตอนนี้ฉันมีคอนเสิร์ตส่วนตัวที่เป็นเพลงโปรดของฉันร้องให้ฟังอยู่ตลอดเวลาเลย$9#$b#เอาจริงๆ ฉันน่าจะเดาเรื่องแบบนี้ได้ตั้งแต่แรกแล้วล่ะ$1",
  "Marriage.Mateo.TwoKids.4": "%kid1 กับ %kid2 ได้เรียนรู้คำว่า 'กบฏ' แล้ว พวกแกสรุปกันแล้วว่าเธอมีอำนาจเหนือกว่าฉันในฐานะผู้นำ เพราะงั้น โชคดีนะ นี่คือคำเตือนล่วงหน้า$24#$b#ไม่ต้องห่วงนะ ฉันเอาอาวุธส่วนใหญ่ไปซ่อนแล้ว... คิดว่างั้นนะ$37",
  // AFFECTION DIALOGUE
  "Marriage.Mateo.Good.0": "เช้านี้เธอดูงดงามมากเลย แสงตะวัน แค่มองหน้าเธอแวบเดียว ฉันก็รู้ซึ้งเลยว่าฉันเป็นไอ้บ้าที่โชคดีแค่ไหน$30",
  "Marriage.Mateo.Good.1": "วันนี้คนโปรดของฉันเป็นยังไงบ้าง? ฉันมั่นใจว่าเธอคงมีเรื่องให้ยุ่งเยอะแยะเลย แต่ฉันแค่อยากให้เธอรู้ไว้นะว่าฉันรักเธอ$27#$b#ฉันคิดถึงเธอเวลาที่เธอทำงานนะ รู้ไหม มันเหมือนกับการต้องอยู่โดยไม่มีเงาของตัวเองเลยล่ะ$29",
  "Marriage.Mateo.Good.2": "%มาเทโอประคองใบหน้าของนายด้วยสองมือ แล้วประทับจูบลงบนหน้าผาก จมูก และปิดท้ายที่ริมฝีปากของนาย#$b#เธอน่ารักเกินไปแล้วนะ ฉันเลยอดใจไม่ได้ที่จะสาดความรักใส่เธอแบบนี้น่ะ$31",
  "Marriage.Mateo.Good.3": "เธอคือทุกสิ่งทุกอย่างของฉัน แสงตะวัน เวลาที่ฉันมองเธอ ฉันรู้สึกเหมือนฉันสามารถรับมือได้ทั้งโลกเลยล่ะ$28#$b#เธอคือเครื่องเตือนใจของฉัน ว่าสิ่งต่างๆ มันดีขึ้นได้ ว่าสิ่งต่างๆ มันเปลี่ยนแปลงได้$27",
  "Marriage.Mateo.Good.4": "ฉันเริ่มกลับไปติดต่อกับเพื่อนร่วมงานสมัยเรียนมหาลัยบางคนแล้ว ฉันคิดจริงๆ นะว่าฉันจะสามารถเดินหน้าตีพิมพ์งานวิจัยของฉันได้ โดยเฉพาะเมื่อมีโครบุสคอยช่วย$32",
  "Marriage.Mateo.Good.5": "%มาเทโอโน้มตัวมาจูบที่ขมับของนาย#$b#วันนี้รู้สึกเงียบๆ นะ แสงตะวัน ทำไมเธอไม่มานอนกลิ้งเล่นกับฉันล่ะ ถ้าเธอไม่ยุ่งน่ะ? ฉันหมายถึง เราจะ 'ยุ่ง' กันก็ได้นะ แต่มันก็คงจะไม่เงียบหรอกนะ$31",
  "Marriage.Mateo.Good.6": "%มาเทโอสวมกอดนายโดยที่นายไม่ได้ร้องขอ นายรู้สึกปลอดภัยในอ้อมแขนของเขา อบอุ่นเหมือนได้อยู่บ้าน",
  "Marriage.Mateo.Good.7": "ฉันหวังว่าในหุบเขานี้จะมีวงการดนตรีที่คึกคักกว่านี้นะ ฉันคงพาเธอไปดูคอนเสิร์ตบ่อยๆ เลยล่ะ แต่ตอนนี้เราคงต้องทนเต้นไปกับเพลงในวิทยุกันไปก่อนนะ$4",
  "Marriage.Mateo.Good.8": "อ้อ มาร์ลอนบอกว่าเขาภูมิใจมากๆ เลยนะที่เธอพัฒนาตัวเองในฐานะนักผจญภัยมาได้ไกลขนาดนี้$0#$b#เผื่อเขาจะไม่ยอมพูดกับเธอต่อหน้า ฉันเลยคิดว่าเธอควรจะรู้ไว้น่ะ$1",
  "Marriage.Mateo.Neutral.0": "ฉันคิดว่าฉันควรไปเก็บกวาดห้องครัวหรือทำอะไรสักอย่างนะ บางทีอาจจะไปซักผ้าด้วย$34#$b#มีอะไรเป็นพิเศษที่เธออยากให้ฉันช่วยไหม? ไม่ต้องเกรงใจที่จะขอนะ$32",
  "Marriage.Mateo.Neutral.1": "วันนี้ฉันเหนื่อยจัง ฉันเจอปัญหาเยอะเลยเวลาพยายามทำงาน สงสัยฉันเปลี่ยนไปเดินเล่นที่กิลด์กับเอเมริทัสแทนดีกว่า ขอโทษนะ @$8",
  "Marriage.Mateo.Neutral.2": "ตั้งแต่ฉันย้ายมาอยู่กับเธอ ฉันก็ไม่ค่อยกังวลเรื่องฤดูหนาวเหมือนเมื่อก่อนแล้วล่ะ$24#$b#การไม่ต้องลงไปในเหมือง แล้วก็กินวิตามิน มันช่วยได้เยอะเลย$0",
  "Marriage.Mateo.Neutral.3": "ทำไมฉันถึงเหนื่อยขนาดนี้นะ? เธอเหนื่อยไหม?$16#$b#บางทีฉันน่าจะงีบสักหน่อยนะ$17",
  "Marriage.Mateo.Neutral.4": "ฉันน่าจะไปหยิบไวโอลินมานะ ตอนนี้มันอยู่ที่กิลด์น่ะ$4#$b#ฉันเล่นเพลงโฟล์คคาวบอยได้เจ๋งเอาเรื่องเลยนะ ถ้าเธอชอบแนวๆ นั้นน่ะ ฉันจะเล่นเพลงจีบเธอให้ตายไปเลย แสงตะวัน$80",
  "Marriage.Mateo.Neutral.5": "%มาเทโอโน้มตัวมาขบที่ริมฝีปากล่างของนาย แล้วยิ้มกริ่มก่อนจะเดินไปทำธุระของเขาต่อ",
  "Marriage.Mateo.Neutral.6": "ฟาร์ม %farm ดูน่าทึ่งมากเลยนะวันนี้ แสงตะวัน ฉันไม่รู้หรอกนะว่าเธอจัดการให้ทุกอย่างมันเป็นระเบียบได้ยังไง แต่เธอไม่เคยหยุดทำให้ฉันประทับใจเลยล่ะ$32",
  "Marriage.Mateo.Neutral.7": "คืนนี้เราน่าจะแค่ทิ้งตัวลงบนโซฟา แล้วก็เปิดหนังมอนสเตอร์ดูชิลล์ๆ กันนะ ฟังดูดีไหม?$31",
  "Marriage.Mateo.Bad.0": "ขอโทษนะ แสงตะวัน โดนอัดมานิดหน่อยในเหมืองน่ะ ความเครียดเลยทำให้ฉันรู้สึกอยากจะกัดคนสักหน่อย$8#$b#ไม่ ไม่ใช่กัดในความหมายดีๆ หรอกนะ$16",
  "Marriage.Mateo.Bad.1": "%มาเทโอดูเศร้าๆ เหมือนไม่ได้กำลังจดจ่ออยู่กับอะไรเลย",
  "Marriage.Mateo.Bad.2": "ถ้าเธอมีอะไรจะพูดกับฉัน @ ก็พูดมาเลย ฉันไม่อยากเล่นเกมกับเธอนะ เรามาคุยกันแบบผู้ใหญ่ดีกว่า$17",
  "Marriage.Mateo.Bad.3": "แสงตะวัน ฉันรับมือกับการถูกเมินไม่ค่อยเก่งนะ ขอร้องล่ะ เรามาคุยกันดีกว่าว่ามีอะไรกวนใจเธออยู่$21",
  "Marriage.Mateo.Bad.4": "%มาเทโอกำลังเลื่อนดูโทรศัพท์ ดูรูปที่ถ่ายคู่กับนาย",
  "Marriage.Mateo.Bad.5": "ฉันทำอะไรผิดหรือเปล่า? ถ้าฉันทำผิด เธอคงบอกฉันใช่ไหม?...ใช่ไหม?$21",
  "Marriage.Mateo.Bad.6": "บางทีไวแอตต์อาจจะพูดถูก ฉันมันเป็นคนที่มองคนไม่ขาด...$18",
  "Marriage.Mateo.Bad.7": "ฉันไม่อยากทะเลาะนะ แสงตะวัน$19",
  "Marriage.Mateo.Bad.8": "@ ฉันเริ่มรู้สึกว่าตัวเองไม่เป็นที่ต้อนรับที่นี่แล้ว เธออยากให้ฉันกลับไปพักที่กิลด์ไหม?$16",
  // ENGAGEMENT DIALOGUE 
  "Marriage.Mateo.Engagement.Mateo0": "ฉันไม่อยากจะเชื่อเลยว่ามันกำลังจะเกิดขึ้น แสงตะวัน มันเหมือนกับว่าความฝันทุกอย่างที่ฉันเคยมีมันกลายเป็นจริงขึ้นมาพร้อมๆ กัน และฉันคงไม่มีความสุขไปมากกว่านี้แล้วล่ะ$76",
  "Marriage.Mateo.Engagement.Mateo1": "เรากำลังจะทำสิ่งนี้แล้ว แสงตะวัน... ฉันกำลังจะได้ตื่นมาแล้วเห็นเพดานห้องเธอแทนที่จะเป็นเพดานห้องฉันในทุกๆ เช้าแล้ว...$78",
  "Marriage.Mateo.Engagement.Mateo2": "พรุ่งนี้เป็นวันสำคัญแล้วสินะ? มันคือจุดเริ่มต้นของสิ่งใหม่ สิ่งที่งดงาม ฉันแทบรอไม่ไหวแล้ว$80",
