  // NAME & INTRO 
  // NAME & INTRO 
  "Core.Cirrus.Name": "ซีร์รัส",
  "Core.Cirrus.Introduction": "ขอบใจนะที่ช่วยฉันไว้ที่ซาลูนน่ะ @ บางทีฉันก็รู้สึกอึดอัดเวลาคนเยอะๆ น่ะ ถึงจะรู้ว่าพวกเขาไม่ได้มีเจตนาร้ายก็เถอะ",
  // COMMUNITY CENTER BUNDLES  
  "Core.Cirrus.JojaBegin": "แย่จังเลยนะเรื่องโจจ้าน่ะ พวกเขาเคยพยายามจะมาเปิดสาขาที่พอร์ตเดรก (Port Drake) เหมือนกัน แต่คนที่นั่นต่อต้านกันหนักกว่านี้เยอะเลยล่ะ...$3",
  "Core.Cirrus.CCBegin": "อาคารเก่าๆ หลังนั้นคงจะสำคัญกับคนในชุมชนมากแน่ๆ พวกเขาถึงได้มอบหมายให้เธอเป็นคนซ่อมแซมน่ะ โชคดีนะ!$17",
  "Core.Cirrus.CCBus": "ฉันก็รู้สึกขอบคุณนะที่มีรถส่วนตัวใช้ แต่การนั่งรถบัสเข้าเมืองมันคงจะง่ายกว่านี้เยอะเลย ถ้าไม่มีคนจำฉันได้ตลอดเวลาน่ะ#3",
  "Core.Cirrus.CCMinecart": "อะไรนะ? เธอสามารถกระโดดขึ้นรถรางแล้วนั่งไปไหนมาไหนได้เลยงั้นเหรอ? บ้าไปแล้ว! ฉันอยากลองนั่งบ้างจัง!$14",
  "Core.Cirrus.CCComplete": "ยินดีด้วยนะที่ซ่อมแซมอาคารเสร็จแล้ว @! ดูเหมือนว่ามันจะมีความหมายกับคนในพื้นที่มากๆ เลยล่ะ เธอเจ๋งมากเลยที่ทำแบบนั้นได้$4",
  "Core.Cirrus.MovieTheater": "โอ๊ะ! ฉันชอบดูหนังนะ เราไปดูกันเถอะ! ฉันเลี้ยงเอง! [809]",
  // BIRTHDAYS
  "Core.Cirrus.Fall25": "วันนี้วันเกิดมาเทโอนี่นา! อาหารฝีมือฉันน่าจะช่วยให้พวกเขาชื่นใจได้นะ เดี๋ยวฉันรีบไปทำเลยดีกว่า!$1",
  "Core.Cirrus.Winter21": "วันนี้วันเกิดบิร็อก (Biróg) ล่ะ! ฉันพนันได้เลยว่า{{HPN1}}คงจะดีใจที่มีคนใส่ใจในวันนี้แน่ๆ ถึงแม้{{HPN1}}จะแกล้งทำเป็นไม่สนใจก็เถอะ$1",
  // END OF SEASON
  "Core.Cirrus.SpringEnd": "ฉันจะไม่แกล้งทำเป็นรู้เรื่องการทำฟาร์มก็แล้วกันนะ แต่ฉันพูดได้เลยว่า ฉันตั้งตารอที่จะได้ทำอาหารจากวัตถุดิบช่วงฤดูร้อนของเธออยู่นะ$4",
  "Core.Cirrus.SummerEnd": "ฉันคงคิดถึงอากาศริมชายหาดแย่เลย แต่ก็ไม่เป็นไรหรอก ได้เวลาหยิบเสื้อกันหนาวมาใส่แล้ว!$1",
  "Core.Cirrus.FallEnd": "เตรียมตัวรับมือกับความหนาวหรือยัง @? หวังว่าเธอจะมีเสื้อกันหนาวดีๆ นะ ช่วงฤดูหนาวนี่เธอได้พักผ่อนบ้างไหม?$17",
  "Core.Cirrus.WinterEnd": "ในที่สุดก็เกือบจะถึงฤดูใบไม้ผลิอีกแล้ว! ฉันไม่ได้เกลียดความหนาวหรอกนะ แต่ฉัน *รัก* ช่วงฤดูใบไม้ผลิมากๆ เลยล่ะ$1",
  // SVE COMMUNITY DAY
  "Core.Cirrus.CommunityCenter4": "ดีจังเลยนะที่ได้เห็นทุกคนมารวมตัวกันแบบนี้! ขอบใจอีกครั้งนะที่ทำให้มันเกิดขึ้นน่ะ @ ชีวิตในเมืองเล็กๆ แบบนี้มันเป็นเรื่องใหม่สำหรับฉันจริงๆ$1",
  "Core.Cirrus.CommunityCenter6": "คราวหน้าฉันว่าฉันจะทำอาหารมาบ้างดีกว่า ห้องครัวที่นั่นกว้างมากแถมยังมีของครบครันสุดๆ เลย!$1",
  "Core.Cirrus.CommunityCenter8": "สิ่งเดียวที่ที่นี่ - แล้วก็ที่ซาลูน - ยังขาดไป ก็คือเวทีเล็กๆ สักเวทีนี่แหละ$14",
  "Core.Cirrus.CommunityCenter10": "อบิเกล (Abigail) บ่นว่ากว่าจะลากเซบาสเตียน (Sebastian) มาที่นี่ได้นี่เหนื่อยแทบแย่ แต่ฉันว่าเขาก็ดูชอบนะ ตราบใดที่ยังได้อยู่กับเธอแล้วก็แซม (Sam) น่ะ$4",
  // FESTIVALS
  "Core.Cirrus.EggFestival": "พูดตามตรงนะ ฉันไม่ได้สนใจเทศกาลไข่นี่เลย จนกระทั่งกัส (Gus) บอกว่าเขาจะเป็นคนจัดเตรียมอาหารให้น่ะ ปล่อยให้เด็กๆ สนุกกับการหาไข่ไปเถอะ$17",
  "Core.Cirrus.FlowerDance": "ฉันตื่นเต้นกับงานพรุ่งนี้จัง! เธอจะชวนใครเต้นรำด้วยไหม @?$4",
  "Core.Cirrus.Luau": "ฉันไม่ค่อยแน่ใจเลยว่าจะเอาอะไรไปใส่ในซุปที่ใส่ได้แทบจะทุกอย่างบนโลกนี้ดี...$16",
  "Core.Cirrus.MoonlightJelly": "ที่พอร์ตเดรกเราไม่มีแมงกะพรุนพระจันทร์ (Lunaloos) หรอกนะ แต่เรามี... อืม พวกมังกร (Drakes) ล่ะมั้ง เขาว่ากันน่ะ$1",
  "Core.Cirrus.SDVFair": "ฉันว่ามันคงสนุกดีนะถ้าได้ขึ้นไปแสดงโชว์ในงานแฟร์ หรือไม่ก็ไปเปิดซุ้มขายอาหาร แต่ก็ไม่อยากโดนตัดสินล่ะนะ$1",
  "Core.Cirrus.SpiritsEve": "มาเทโอตื่นเต้นกับงานพรุ่งนี้แบบไม่หยุดเลย น่าเอ็นดูจัง$0",
  "Core.Cirrus.IceFestival": "ดูเหมือนบิร็อกพร้อมจะจับลูอิสโยนทะลุหน้าต่างเพราะเรื่องงานเทศกาลพรุ่งนี้แล้วล่ะ...$16",
  "Core.Cirrus.NightMarket": "ฉันสงสัยจังว่าจะพอหาของจุกจิกจากซูซู (ZuZu) หรือพอร์ตเดรกที่ตลาดกลางคืนได้ไหมนะ ฉันชอบพวกเครื่องประดับเล็กๆ น้อยๆ น่ะ$1",
  "Core.Cirrus.WinterStar": "ฉันอาจจะบ้าเห่อเรื่องของขวัญมากไปหน่อยล่ะมั้ง ช่วงนี้ฉันทำอาหาร *ไม่หยุดเลย* จริงๆ$15",
  // ROMANTIC (POSITIVE) 
  "Core.Cirrus.GiveFlowersA": "โอ้ @! ดอกไม้นี่น่ารักจัง มันเป็นธรรมเนียมของเมืองเพลิแกนเหรอ?$1",
  "Core.Cirrus.GiveFlowersB": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราทำกันคนละแบบเลย ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.GivePendant": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราจะขอแต่งงานด้วยขนของ 'ฟีนิกซ์' (Phoenix) น่ะ ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.StardropGiftA": "ฉันเจอมันมาให้เธอน่ะ @ - ฉันอยากจะแสดงความรักด้วยของที่มันดูยิ่งใหญ่สักหน่อย ฉันหวังว่าเธอจะรับมันไว้นะ!$23",
  "Core.Cirrus.StardropGiftB": "ฉันเก็บมันไว้ตั้งนานแล้วล่ะ @ - แต่ฉันคิดว่าเธอแล้วก็ฟาร์มของเธอน่าจะต้องการมันมากกว่าฉันนะ$23",
  // ROMANTIC (NEGATIVE)
  "Core.Cirrus.DanceRejection": "ดีใจนะที่ชวน แต่ไม่ล่ะ ขอบใจ! ฉันว่ารอบนี้ฉันขอนั่งดูเฉยๆ ดีกว่า$1",
  "Core.Cirrus.Divorced": "ปล่อยฉันไว้คนเดียวเถอะ @ ถ้าฉันตัดขาดกับแม่แท้ๆ ของตัวเองได้ ฉันก็ตัดขาดกับเธอได้เหมือนกัน$5#$b#ฉันอาจจะเป็นแค่ผู้หญิงคนนึงที่เคยนอนกับเธอ แต่สำหรับฉัน เธอเป็นแค่เนื้อเพลงท่อนนึงในเพลงของฉันเท่านั้นแหละ ",
  "Core.Cirrus.BreakUp": "โอ้ - เอ่อ อืม ขะ-ขอบใจสำหรับทุกอย่างนะ @... ฉัน เอ่อ... ฉันจะ... ฉันขอตัวก่อนนะ โอเคไหม? ขอไปจัดการความรู้สึกตัวเองหน่อย นี่เป็นความสัมพันธ์ที่ฉันต้องใช้เวลาทำใจจริงๆ$13",
  "Core.Cirrus.DumpedGirls": "...ไม่อยากจะเชื่อเลยว่าฉันจะไว้ใจให้เธอปฏิบัติต่อฉันแตกต่างจากคนนับแสนที่ฉันเคยแสดงดนตรีให้ดู ทั้งหมดนี้มันก็แค่การแสดงฉากนึงสำหรับเธอสินะ?$12",
  "Core.Cirrus.SecondChanceGirls": "ฉันก็ไม่ค่อยแน่ใจเรื่องนี้เท่าไหร่หรอกนะ แต่... ฉันว่าเรื่องบางเรื่องมันก็คุ้มค่าที่จะลองดูอีกครั้งนึงใช่ไหมล่ะ?$16",
  "Core.Cirrus.Reject2HA": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราทำกันคนละแบบเลย ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.Reject2HB": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราทำกันคนละแบบเลย ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.Reject4HA": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราทำกันคนละแบบเลย ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.Reject4HB": "โอ้ น่าสนใจจัง! ที่พอร์ตเดรกน่ะ เราทำกันคนละแบบเลย ขอให้โชคดีกับความตั้งใจของเธอนะ @!",
  "Core.Cirrus.EngageA": "นี่ มัน... ค่อนข้างจะอึดอัดนะที่เธอทำแบบนี้ ทั้งๆ ที่เธอหมั้นแล้วน่ะ ฉันมีขอบเขตและมาตรฐานของฉันนะ เสียใจด้วยที่ฉันไม่รู้สึกผิดที่ปฏิเสธเธอ$2",
  "Core.Cirrus.EngageB": "ขอพูดตรงๆ เลยนะ แบบนี้มันแปลกแล้วก็น่าเกลียดมากเลยนะในเมื่อเธอหมั้นแล้วน่ะ ไม่ล่ะ ฉันไม่ได้สนใจ$5",
  "Core.Cirrus.MarriedA": "ไม่ล่ะ ไม่มีทาง ฉันควรจะไปบอกแฟนเธอนะ$5",
  "Core.Cirrus.MarriedB": "อีกแค่นิดเดียวฉันจะตัดขาดกับเธอแล้วนะ @$5",
  "Core.Cirrus.RefusalNoHeartsA": "นี่ไม่ใช่หนังเด็กนะ @ - เราเพิ่งเจอกันเอง!$3",
  "Core.Cirrus.RefusalNoHeartsB": "เอ่อ ขอบใจนะ? แต่แบบ ไม่ล่ะ ขอบใจ!$3",
  "Core.Cirrus.RefusalKnownA": "ฉัน ...รู้สึกดีใจนะ? มั้ง? แต่ ไม่ล่ะ?$17",
  "Core.Cirrus.RefusalKnownB": "เรื่องแบบนี้เกิดขึ้นกับฉันบ่อยมาก แต่มันก็ยังแปลกอยู่ดีนั่นแหละ$20",
  "Core.Cirrus.RefusalBotherA": "ฉันคงต้องขีดเส้นแบ่งกับเธอบ้างแล้วล่ะ ถ้าเธอยังไม่หยุดทำแบบนี้น่ะ @ ได้โปรดเถอะ$18",
  "Core.Cirrus.RefusalBotherB": "หยุดเถอะ @ ฉันไม่อยากจะต้องตัดขาดกับเธอเหมือนที่ฉันทำกับคนอื่นๆ อีกหลายคนหรอกนะ$18",
  // RESORT
  "Core.Cirrus.ResortEntering": "ได้เวลามาทะเลแล้วววว!$15",
  "Core.Cirrus.ResortLeaving": "มัน *สนุกมากๆ* เลย หวังว่าฉันจะได้กลับมาที่นี่อีกเร็วๆ นี้นะ$15",
  "Core.Cirrus.ResortShore": "มองไม่เห็นอะไรที่เส้นขอบฟ้าเลย! เราอยู่ไกลจากบ้านมากเลยนะเนี่ย!$1",
  "Core.Cirrus.ResortUmbrella": "ฉันคงเผลอหลับตรงนี้ได้เลยนะเนี่ย มันสบายสุดๆ ไปเลย!$1",
  "Core.Cirrus.ResortWander": "ฉันสงสัยจังว่าบนเกาะส่วนที่เหลือจะมีอะไรอยู่บ้าง เธอได้ไปสำรวจมาเยอะไหม @?$1",
  "Core.Cirrus.ResortWander.2": "ฉันต้องบ้าไปแล้วแน่ๆ ฉันนึกว่าเห็นเรือโจรสลัดอยู่ตรงเส้นขอบฟ้าซะอีก$20",
  "Core.Cirrus.ResortChair": "ถ้าเป็นไปได้ฉันอยากมาที่นี่ทุกวันเลยล่ะ บรรยากาศมันต่างจากชายหาดแถวบ้านเราเลยนะ$28",
  "Core.Cirrus.ResortBar": "ฉันเลิกดื่มแอลกอฮอล์แล้วล่ะ แต่กัสชงม็อกเทลอร่อยมากเลยนะ$22",
  "Core.Cirrus.ResortTowel": "ต่อให้ฉันอาบครีมกันแดด ผิวฉันก็คงจะไหม้อยู่ดีล่ะมั้ง...$20",
  "Core.Cirrus.ResortTowel.2": "โอ้ นี่มัน *สุดยอด* ไปเลย เธอจะมานั่งชิลกับฉันสักพักไหม @?$15",
  "Core.Cirrus.Resort_Towel.3": "ฉันสงสัยจังว่าฉันจะเรียนเซิร์ฟได้ไหมนะ มันจะยากหรือเปล่า? อาจจะนะ ฉันคงจะตั้งใจเรียนมากๆ ได้สักเดือนนึง แล้วก็ลืมไปเลยว่าเคยอยากเรียนน่ะ$15",
  "Core.Cirrus.Resort": "ตรงนั้นมันภูเขาหรือเปล่านะ? หรือว่าภูเขาไฟ? ฉันสงสัยจังว่ามันจะปลอดภัยพอให้ไปสำรวจไหม ฉันแอบอยากเข้าไปดูใกล้ๆ จัง...$14",
  // PLAYER DEATH
  "Core.Cirrus.PlayerKilled.Mines.01": "@!",
  "Core.Cirrus.PlayerKilled.Mines.02": "ไม่ๆๆๆๆ ไม่นะ-!$12",
  "Core.Cirrus.PlayerKilled.Mines.03": "ขอร้องล่ะ ปลอดภัยทีเถอะ @! ขอให้ปลอดภัยที!!!$21",
  "Core.Cirrus.PlayerKilled.Skull.01": " ... @?",
  "Core.Cirrus.PlayerKilled.Skull.02": "ใจเย็นๆ นะ... ค่อยๆ เป็นค่อยๆ ไป",
  "Core.Cirrus.PlayerKilled.Skull.03": "เธอฟื้นแล้ว! ขอบคุณสวรรค์ บิร็อกไปเจอเธอนอนเจ็บหนักอยู่ในถ้ำกะโหลก (Skull Cave) น่ะ!$2",
  "Core.Cirrus.PlayerKilled.Skull.04": "ฉันกลัวมากเลยนะ @ ให้ตายเถอะ...$21",
  "Core.Cirrus.PlayerKilled.Skull.04.Filtered": "ฉันกลัวมากเลยนะ @ แย่ที่สุดเลย...$21",
  "Core.Cirrus.PlayerKilled.Skull.05": "อย่าทำแบบนี้กับฉันอีกนะ @! ถ้าเธอทำอีกล่ะก็ ฉันจะทำให้ *เธอ* เป็นฝ่ายต้องกลัวบ้างแล้วนะ!#@21",
  "Core.Cirrus.PlayerKilled.Skull.06": "{{CPPN1}}จะไม่เป็นไร แต่คราวหน้า{{LPPN1}}ต้องระวังตัวให้มากกว่านี้นะ",
  "Core.Cirrus.PlayerKilled.Skull.07": "ฉันจะปล่อยให้พวกเธอสองคนคุยกันนะ มีอะไรให้ช่วยก็บอกได้เลย$2",
  "Core.Cirrus.PlayerKilled.Skull.08": "อย่าทำให้ฉันต้องมีชีวิตอยู่ต่อไปโดยไม่มีเธอนะ @ อย่าแม้แต่จะคิดเชียวนะ$21",
  "Core.Cirrus.GreenRain": "แค่ฝนตกปกติฉันก็มีปัญหามากพออยู่แล้ว ทำไมตอนนี้มันถึงเป็นสีเขียวล่ะเนี่ย?$19",
  "Core.Cirrus.GreenRainFinished": "โอ้ ขอบคุณพระเจ้า มันจบลงแล้ว อย่างน้อยก็ไม่มีฟ้าร้องล่ะนะ...$18",
  "Core.Cirrus.GreenRain2": "ฉันว่าพอไม่มีฟ้าร้อง อากาศแปลกๆ นี่ก็ไม่ได้แย่เท่าไหร่นะ แล้วพวกต้นไม้ก็ดูสวยมากเลยหลังจากนั้น$17",
  // POLYAMORY 
  "Core.Cirrus.MarriedMonogamousNPC": "แฟนของเธอเป็นคนที่รักเดียวใจเดียวนะ @ เพราะงั้นฉันก็เลยรู้สึกไม่ค่อยสะดวกใจที่จะมีความสัมพันธ์แบบคนรักกับเธอน่ะ$16",
  // EPILOGUE 
  "Core.Cirrus.Epilogue.1": "แม่ฉันสบายดี ขอบใจที่ถามนะ! เธอค่อนข้างลำบากเลยล่ะ แต่มันก็เหมือนฉากตัดต่อในหนังเก่าๆ นั่นแหละ ฉันเชื่อมั่นในตัวเธอนะ$1",
  "Core.Cirrus.Epilogue.2": "ตอนนี้ฉันกับแม่คุยโทรศัพท์กันอาทิตย์ละครั้งน่ะ ฉันยังไม่แน่ใจว่าฉันพร้อมที่จะเจอเธอตัวเป็นๆ หรือยัง คงต้องรอให้เธอเลิกเหล้าได้สักพักก่อนล่ะมั้ง$17",
  "Core.Cirrus.Epilogue.3": "ฉันเริ่มแต่งเพลงแล้วล่ะ! ซึ่งเอาจริงๆ ฉันไม่ได้ทำมานานมากๆ แล้ว... แต่ฉันได้รับแรงบันดาลใจจากทุกๆ เรื่องที่เกิดขึ้นนี่แหละ$1",
  "Core.Cirrus.Epilogue.4": "พูดตามตรงนะ ช่วงนี้ฉันเล่นเปียโนบ่อยมาก ไม่ใช่คีย์ทาร์นะ มันแค่... ให้ความรู้สึกต่างออกไปน่ะ มันสื่อถึงการก้าวไปข้างหน้าของฉันได้ดีกว่า$4",
  "Core.Cirrus.Epilogue.5": "ทุกๆ วันที่แม่ฉันผ่านไปได้โดยไม่แตะเหล้าเลย มันถือเป็นพรเล็กๆ สำหรับฉันเลยล่ะ ฉันภูมิใจในตัวเธอมากๆ$1",
  "Core.Cirrus.Epilogue.6": "มันคงจะดีมากๆ เลยนะที่จะได้ทำความรู้จักกับแม่ในแบบที่เธอเคยเป็นก่อนที่จะติดเหล้า และในแบบที่เธอจะเป็นหลังจากที่เลิกมันได้แล้ว$1",
  "Core.Cirrus.Epilogue.7": "ฉันจะไป ไป ไป ไม่มีใครหยุดฉันได้หรอก! ฉันจะพุ่งทะยานผ่านท้องฟ้า ใช่แล้ว ร้อนแรงถึง 200 องศา นั่นแหละเหตุผลที่เขาเรียกฉันว่ามิสเตอร์ฟาเรนไฮต์ (Mister Fahrenheit)!$29",
  "Core.Cirrus.Epilogue.8": "ดวงอาทิตย์สาดส่องบนท้องฟ้า ไม่มีเมฆสักก้อนเลย! ฝนหยุดตกแล้ว ทุกคนกำลังสนุกสนาน... และเธอรู้ไหม นี่มันเป็นวันใหม่ที่สวยงามจริงๆ!$29",
  "Core.Cirrus.Epilogue.9": "เกิดอะไรขึ้น? เธอรู้สึกไม่ดีเหรอ? รู้สึกไม่ดีใช่ไหม ที่รัก? จัดไป โอ้ใช่เลย รับมันมาจากเถาวัลย์หลักเลย เอาล่ะ...$29",
  "Core.Cirrus.Epilogue.10": "อย่าลืมฉันนะ อย่า อย่า อย่า อย่า...$29",
