  // EGG FESTIVAL 
  "Festivals.Hector.spring13.False.1": "ฉันพนันได้เลยว่าฉันสามารถเตะก้นเด็กพวกนี้ได้สบายๆ ถ้าเกิดว่านายกเทศมนตรีงี่เง่าของเธอยอมให้ฉันเล่นด้วยอ่ะนะ$9",
  "Festivals.Hector.spring13.False.2": "คนสติดีๆ ที่ไหนเขากินไข่ *เยอะ* ขนาดนี้กันเนี่ย? เดี๋ยวทั้งเมืองก็เหม็นตลบอบอวลกันพอดี!$16",
  "Festivals.Hector.spring13.False.3": "ก็ได้ๆ ฉันจะลองกินอาหารพวกนี้ดูก็ได้ แต่ฉันจะบ่นไปตลอดทางเลยล่ะ$23",
  "Festivals.Hector.spring13.True.1": "ฉันไม่ค่อยคุ้นเคยกับชาวเมืองเพลิแกนเท่าไหร่น่ะ ฉันไม่ค่อยได้ออกจากสคาร์ป (The Scarp) บ่อยนักหรอก เลยไม่ค่อยมีโอกาสทำความรู้จักพวกเขาน่ะ$24",
  "Festivals.Hector.spring13.True.2": "ฉันว่าเธอพูดไม่ได้หรอกนะว่าเธอลากฉันมาที่นี่ตอนที่ฉันกำลังร้องห่มร้องไห้น่ะ! ฉันมาที่นี่ด้วยความเต็มใจซะส่วนใหญ่ต่างหากล่ะ$14",
  "Festivals.Hector.spring13.True.3": "...เธอ *แน่ใจ* เหรอว่าฉันลงแข่งไม่ได้น่ะ? ฉันจะชนะการแข่งขันครั้งนี้เพื่อเป็นเกียรติแก่การแต่งงานของเราเลยนะ$15",
  // FLOWER DANCE 
  "Festivals.Hector.spring24.False.1": "อี๋ น่าขยะแขยงชะมัด ดูทุกคนสิ ดูสนุกสนานกันจัง แต่งตัวกันซะเต็มยศเชียว ...ฉันโกหกน่ะ จริงๆ แล้วฉันรักมันเลยล่ะ$8",
  "Festivals.Hector.spring24.False.2": "ฉันรู้ว่าฉัน *ไม่จำเป็น* ต้องเต้นรำ หรือมีส่วนร่วม หรืออะไรก็ตาม... แต่ฉันก็อยากทำนะ ฉันแค่ขอสงวนสิทธิ์ในการบ่นเรื่องนี้ไปด้วยเท่านั้นเอง$24",
  "Festivals.Hector.spring24.False.3": "ไม่แน่ใจแฮะว่าจะไปหาทักซิโด้สีฟ้าพวกนั้นได้จากที่ไหน ชุดดรูอิดของฉันนี่ก็หรูพอแล้วใช่ไหมล่ะ? ไม่ต้องไปสนใจเรื่องตะไคร่น้ำหรอกน่า$12",
  "Festivals.Hector.spring24.True.1": "เรากลับไปเต้นกันที่บ้านก็ได้นะ รู้ไหม เต้นทูสเต็ป (Two-step) เบาๆ หรือจะชาร์ลสตัน (Charleston) ดีล่ะ หรือว่าเธอชอบแนวเดวิลส์แทงโก้ (Devil's Tango) มากกว่าล่ะ?$13",
  "Festivals.Hector.spring24.True.2": "ฉันมีอุ้งเท้าซ้ายตั้งสองข้างเลยนะ แค่บอกให้รู้ไว้น่ะ เออ ในทางเทคนิคแล้วฉัน - เธอเข้าใจที่ฉันจะสื่อใช่ไหม$10",
  "Festivals.Hector.spring24.True.3": "ฉันไม่ค่อยอินกับงานรวมญาติใหญ่ๆ แบบนี้หรอกนะ *แต่*... แค่ได้เห็นเธอมีความสุขก็พอแล้วล่ะ$11",
  "Festivals.Hector.spring24.Accept": "เอาสิ แต่แบบ น่าขยะแขยงชะมัด$1",
  // LUAU 
  "Festivals.Hector.summer11.False.1": "พวกนกคงไม่เป็นไรหรอกมั้ง เอลัวส์ แต่ฉันมั่นใจว่าพวกมันต้องซาบซึ้งใจแน่ๆ ที่เธอเป็นห่วงพวกมันน่ะ$0",
  "Festivals.Hector.summer11.False.2": "ไม่ต้องห่วงนะ เอลัวส์ เดี๋ยวพอจบงานแล้วเราจะช่วยกันเก็บขยะให้หมดเลย ไม่ล่ะ ฉันก็ไม่ไว้ใจให้ใครมาเก็บกวาดเหมือนกันนั่นแหละ$0",
  "Festivals.Hector.summer11.False.3": "ถ้ามีเศษขยะกองโตเหลือทิ้งไว้นะ ฉันจะเริ่มไล่กินคนซะเลย แบบ ไม่ได้กิน *จริงๆ* หรอกนะ แต่ฉันจะเขียนจดหมายไปด่าแบบ *รุนแรง* สุดๆ ไปเลย$22",
  "Festivals.Hector.summer11.True.1": "ฉันเคยบอกเธอหรือยังว่าเธอดูน่าดึงดูดมากๆ เลยนะ ตอนที่อยู่ท่ามกลางแสงแดด ทะเลทราย แล้วก็อะไรพวกนี้น่ะ?$10",
  "Festivals.Hector.summer11.True.2": "รู้ไหม เธอไม่เห็นจำเป็นต้องพาฉันมางานเทศกาลเพื่อจะเปียกเลยนะ @",
  "Festivals.Hector.summer11.True.3": "ฉันเกลียดอากาศแบบนี้ ฉันเกลียดอากาศแบบนี้ ฉันเกลียดอากาศแบบนี้... แต่เอาเถอะ ฉันเดาว่ามันก็น่าจะมีเรื่องดีๆ ให้สนุกอยู่บ้างล่ะนะ$16",
  // MOONLIGHT JELLIES
  "Festivals.Hector.summer28.False.1": "...จริงๆ แล้ว ภาพนี้มันสวยงามมากเลยล่ะ...$13",
  "Festivals.Hector.summer28.False.2": "ฉันเดาว่าเธอคงอธิบายเรื่องของลูนาลูส์ (Lunaloos) ด้วยวิทยาศาสตร์ได้ล่ะนะ แต่มันจะสนุกกว่านะถ้าอธิบายพวกมันด้วยเวทมนตร์น่ะ$13",
  "Festivals.Hector.summer28.False.3": "ความงามของธรรมชาติช่างไม่มีสิ่งใดเทียบได้จริงๆ$13",
  "Festivals.Hector.summer28.True.1": "โย่ ฉันได้ยินมาว่าแมงกะพรุนตัวนั้นมันปากดีแฮะ อยากให้ฉันไปจัดการมันให้เธอไหม?$11",
  "Festivals.Hector.summer28.True.1.Filtered": "โย่ ฉันได้ยินมาว่าแมงกะพรุนตัวนั้นมันปากดีแฮะ อยากให้ฉันไปจัดการมันให้เธอไหม?$11",
  "Festivals.Hector.summer28.True.2": "จับมือฉันไว้สิ @$10",
  "Festivals.Hector.summer28.True.3": "บางทีเราอาจจะลงไปแช่น้ำเล่นกันได้นะ หลังจากที่พวกแมงกะพรุนกลับไปแล้วน่ะ$15",
  // SDV FAIR
  "Festivals.Hector.fall16.False.1": "สงสัยจังว่าฉันจะใช้เวทมนตร์แทนไอ้ตัวตลกกระจอกๆ ที่นายกเทศมนตรีของเธอจ้างมาด้วยค่าแรงถูกๆ ได้ไหมนะ$16",
  "Festivals.Hector.fall16.False.2": "เธอคิดว่าหมอดูคนนั้นของจริงป่ะ?$29",
  "Festivals.Hector.fall16.False.3": "มันเจ๋งมากเลยนะที่คนทั้งเมืองมารวมตัวกันพร้อมกับของที่พวกเขาสร้างขึ้นมาน่ะ แต่อีกอย่างคือ เกมล่ะ!$12",
  "Festivals.Hector.fall16.True.1": "โอเค สรุปว่าการขู่นายกเทศมนตรีเรื่องการก่ออาชญากรรมเนี่ย ถือเป็นอาชญากรรมไหม? เธอจะร่วมมือก่ออาชญากรรมกับฉันใช่ไหม? ชีวิตคู่มันต้องทำงานกันแบบนี้ใช่ไหม?$17",
  "Festivals.Hector.fall16.True.2": "ฉันอ่านดวงให้เธอได้แม่นพอๆ กับเวลวิค (Welwick) เลยนะ ขอดูเส้นลายมือของเธอหน่อยสิ ขอดูร่องรอยอื่นๆ บนร่างกายเธอด้วยสิ$11",
  "Festivals.Hector.fall16.True.3": "ฉันจะชนะการแข่งทดสอบพลังนั่นได้ไหมน่ะเหรอ? ไม่ล่ะ ไม่จำเป็นหรอก ฉันแค่ต้องแข็งแรงพอที่จะผลัก *เธอ* ไปมาก็พอแล้ว$15",
  // SPIRIT'S EVE
  "Festivals.Hector.fall27.False.1": "ถึงเวลาจุดเทียนแล้วก็สวดมนต์พึมพำอย่างน่าขนลุกในยามค่ำคืนแล้วสินะ!$9",
  "Festivals.Hector.fall27.False.2": "มันยากจริงๆ นะที่จะไม่ตื่นเต้นไปกับเรื่องนี้ ตอนที่มาเทโอเองก็กำลังตื่นเต้นสุดๆ แบบนี้น่ะ$13",
  "Festivals.Hector.fall27.False.3": "ระวังตัวด้วยนะ @ เมืองนี้ก็เต็มไปด้วยคนแปลกๆ อยู่แล้ว แล้วตอนนี้มันยิ่งดูยากเข้าไปใหญ่เลยว่าใครเป็นใครน่ะ$9",
  "Festivals.Hector.fall27.True.1": "แน่นอนๆ แต่งตัวจัดเต็ม อะไรก็ว่าไป แล้วถ้าเปลี่ยนมาถอดเสื้อผ้าออกบ้างล่ะเป็นไง?$11",
  "Festivals.Hector.fall27.True.2": "มันคงง่ายมากเลยนะที่เราจะแกล้งหลงทางด้วยกันในเขาวงกตนั้นน่ะ แต่ฉันพนันได้เลยว่าเราไม่ใช่คู่เดียวที่มีความคิดแบบนั้นหรอก$10",
  "Festivals.Hector.fall27.True.3": "คืนนี้เธออยากลองเล่นเวทมนตร์ดูบ้างไหมล่ะ? เดี๋ยวฉันจะโชว์ 'เวทมนตร์' ให้ดูเอง$11",
  // ICE FESTIVAL 
  "Festivals.Hector.winter8.False.1": "นี่มันงี่เง่าชะมัด แล้วฉันก็เกลียดมันด้วย มันเป็นแค่การตกปลาแบบเกินพอดี ซึ่งมันไม่ถูกต้องเลยนะ$16#$b#เดี๋ยวนายกเทศมนตรีของเธอจะได้โดนบอลหิมะปาอัดหน้าข้อหานี้แหละ$9",
  "Festivals.Hector.winter8.False.2": "ฉันจะก่อกบฏ หรือไม่ก็ประท้วง หรืออาจจะแค่ปาระเบิดตดใส่บ้านนายกเทศมนตรีเพื่อเป็นการตอบโต้เรื่องนี้ล่ะนะ$9",
  "Festivals.Hector.winter8.False.3": "ฉันรู้แหละว่าทุกคนกำลังสนุกกันน่ะ แต่แบบ อย่างน้อยก็ *เอาปลาพวกนี้ไปทำอะไรสักอย่าง* ทีเถอะ$9",
  "Festivals.Hector.winter8.True.1": "อย่างน้อยการออกมาข้างนอกท่ามกลางอากาศหนาวๆ แบบนี้ ก็เป็นข้ออ้างที่ดีในการได้นอนขดตัวซุกอยู่กับเธอในตอนหลังล่ะนะ - ไม่ใช่ว่าฉันต้องการข้ออ้างอะไรหรอกนะ จริงๆ แล้ว$10",
  "Festivals.Hector.winter8.True.2": "ฉันหนาวจัง เธอจะกอดฉันไว้เพื่อให้หายหนาวได้ไหม?$10",
  "Festivals.Hector.winter8.True.3": "ถ้าฉันไปขัดขวางการตกปลาในงานเทศกาลนี้ล่ะก็ เธอจะโกรธ *มาก* หรือโกรธ *นิดหน่อย* กันนะ?$23",
  // WINTER STAR 
  "Festivals.Hector.winter25.False.1": "ฉันไม่รู้จริงๆ ว่าควรจะซื้ออะไรให้ใครดี เพราะงั้น การที่ฉันมาปรากฏตัวที่นี่ก็ถือว่าเป็นของขวัญแล้วล่ะกันนะ$1",
  "Festivals.Hector.winter25.False.2": "ฉันทำเครื่องรางไล่โชคร้ายจากกิ่งไม้ให้มาเทโอน่ะ ตอนแรกนึกว่าพวกเขาจะเอาไปล้อเลียนซะอีก แต่ตอนนี้มันถูกแขวนไว้เหนือเตียงพวกเขาแล้วล่ะ...$15",
  "Festivals.Hector.winter25.False.3": "ฉันให้สารานุกรมนกเป็นของขวัญเอลัวส์ล่ะ เราแค่จะไม่บอกเธอว่าฉันแอบขโมยมาจากกุนเธอร์ (Gunther) น่ะนะ อย่าไปบอกมาเทโอด้วยล่ะ ไม่งั้นเป็นเรื่องใหญ่แน่$8",
  "Festivals.Hector.winter25.True.1": "@? ขอบใจนะที่ เอ่อม เป็นคู่ของฉันน่ะ ฉันรักเธอมากจริงๆ นะ แล้วก็ ซาบซึ้งใจด้วย แล้วก็ อะไรพวกนั้นน่ะ โอเคไหม?$15",
  "Festivals.Hector.winter25.True.2": "ฉันรักเธอมาก จนฉันยอมดึงเอาท้องฟ้าลงมาเพื่อมอบดวงดาวให้เธอเป็นของขวัญเลยล่ะ$15",
  "Festivals.Hector.winter25.True.3": "ฉันตั้งตารอที่จะได้กลับบ้านนะ ไม่ใช่แค่เพราะเรื่องเผ็ดร้อนอะไรนั่นหรอก แต่เพราะว่า ไม่รู้สิ ฉันแค่ตั้งตารอที่จะได้ใช้เวลาอยู่กับเธอน่ะ @$15",
  // RSV GATHERING 
  "Festivals.Hector.fall20.False.1": "ทำไมการแข่งขันถึงต้องแบ่งแยกเพศด้วยล่ะ? ฉันรู้ว่ามาเทโอรู้สึกเหมือนถูกทอดทิ้ง และเอลัวส์ก็ไม่ชอบเรื่องนี้ด้วย ดูเหมือนจะเป็นความผิดพลาดนะเนี่ย$16",
  "Festivals.Hector.fall20.False.2": "ฉันสัมผัสได้ถึงการเชื่อมต่อกับพงไพรที่อ่อนแรงลงล่ะ ฉันควรจะรีบกลับบ้านนะ$17",
  "Festivals.Hector.fall20.False.3": "ฉันอยากจะอยู่เป็นเพื่อนเอลัวส์นะ แต่ให้ตายสิ ฉันรู้สึกอึดอัดสุดๆ ไปเลย$16",
  "Festivals.Hector.fall20.True.1": "ฉันไม่อยากจะขอเลย แต่เราช่วยพักผ่อนกันหน่อยได้ไหมตอนกลับถึงบ้านน่ะ? ฉันรู้สึกอ่อนแรงมากเลยทุกครั้งที่มาที่นี่$13",
  "Festivals.Hector.fall20.True.2": "ฉันไม่ชอบการแข่งขัน แถมดนตรีก็ดังเกินไป และฉันก็กังวลเรื่องพงไพรเสมอเลยเวลาที่ต้องอยู่ห่างจากมันมากเกินไปน่ะ...$22",
  "Festivals.Hector.fall20.True.3": "ขอโทษนะที่บ่นซะเยอะเลย @ มันแค่ยากนิดหน่อยน่ะที่ต้องอยู่ห่างบ้านขนาดนี้ แต่ฉันก็อยากจะทำสิ่งที่เธอชอบไปพร้อมกับเธอนี่นา$17",
  // RSV EMBER OF RESOLUTIONS 
  "Festivals.Hector.winter28.False.1": "ฉันเข้าใจเจตนารมณ์นะ แต่นั่นมันไม้เยอะเกินไปที่จะเอามาเผาเล่นเพื่อการนี้เฉยๆ อ่ะ$16",
  "Festivals.Hector.winter28.False.2": "มันมีโอกาสสูงมากเลยนะที่อะไรๆ จะติดไฟขึ้นมาได้น่ะ$16",
  "Festivals.Hector.winter28.False.3": "ฉันอยู่ห่างจากพงไพรมากเลย และฉันก็รู้สึกไม่ค่อยดีกับเรื่องนี้เท่าไหร่แฮะ$16",
  "Festivals.Hector.winter28.True.1": "ฉันเข้าใจเจตนารมณ์นะ แต่นั่นมันไม้เยอะเกินไปที่จะเอามาเผาเล่นเพื่อการนี้เฉยๆ อ่ะ$16",
  "Festivals.Hector.winter28.True.2": "น่าจะเรียกฝนให้ตกลงมาซะหน่อยนะ ไม้จะได้ไม่ติดไฟ สำหรับฉันแล้ว แบบนี้มันอันตรายเกินไปนะ...$23",
  "Festivals.Hector.winter28.True.3": "ขอโทษนะที่บ่นซะเยอะเลย @ มันแค่ยากนิดหน่อยน่ะที่ต้องอยู่ห่างบ้านขนาดนี้ แต่ฉันก็อยากจะทำสิ่งที่เธอชอบไปพร้อมกับเธอนี่นา$17",
