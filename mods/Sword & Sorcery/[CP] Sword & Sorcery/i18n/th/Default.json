  // NAME & INTRO 
  "Core.Hector.Name": "เฮกเตอร์",
  "Core.Biróg.Name": "บิร็อก",
  "Core.Hector.Introduction": "เธอไม่มีทางรู้หรอกว่าฉันทำอะไรได้บ้าง ชาวไร่ และไม่มีทางรู้ด้วยว่าฉันมีแผนอะไรเตรียมไว้ให้เธอ",
  // DYNAMIC PRONOUNS 
  "Core.HectorPN.M.1": "เขา",
  "Core.HectorPN.M.2": "เขา",
  "Core.HectorPN.M.3": "ของเขา",
  "Core.HectorPN.M.4": "ด้วยตัวเขาเอง",
  "Core.HectorPN.F.1": "เธอ",
  "Core.HectorPN.F.2": "เธอ",
  "Core.HectorPN.F.3": "ของเธอ",
  "Core.HectorPN.F.4": "ด้วยตัวเธอเอง",
  // COMMUNITY CENTER BUNDLES  
  "Core.Hector.JojaBegin": "ไอ้คนทรยศ! ฉันต้องการเธอนะ แล้วนี่เธอไปยอมจำนนให้มอร์ริส (Morris) งั้นเหรอ? แหงล่ะ ฉันรู้อยู่แล้วว่าเป็นเธอ ก็ใครล่ะจะไปยอมซื้อบัตรสมาชิกนั่นกัน!$27#$b#เธอไม่ได้เป็นอย่างที่ฉันคิดเลย! ฉันเชื่อใจเธอไม่ได้อีกแล้ว ไปให้พ้นหน้าฉันเลยนะ$21",
  "Core.Hector.CCBegin": "ทำได้ดีมาก @! ปล่อยให้มอร์ริสกับโกดังของเขานั่งกินก้อนกรวดไปก็แล้วกัน$1#$b#อะไรนะ? อยากให้ช่วยซ่อมศาลาว่าการ (Community Center) งั้นเหรอ? ไม่อะ ฉันมั่นใจว่าเธอจัดการเองได้$8#$b#อีกอย่าง ฉันมีแผน *อื่น* สำหรับพวกเราแล้วล่ะ$9",
  "Core.Hector.CCBus": "ระบบขนส่งสาธารณะที่เข้าถึงได้น่ะ ถือเป็นสิ่งล้ำค่าในการรักษาสภาพแวดล้อมและสังคมที่ใส่ใจกันและกันนะ ทำได้ดีมาก @$7#$b#และเป็นโบนัสด้วยนะ เธอมีแพมเป็นคนขับ รับรองว่าอะไรๆ คงน่าตื่นเต้นขึ้นเยอะเลย ฮึ!?$9",
  "Core.Hector.CCMinecart": "ฉันจะเอาเจ้ารถรางนั่นไปสร้างเรื่องวุ่นวายซะให้เข็ดเลย ขอบใจนะ @!$9",
  "Core.Hector.CCComplete": "ศาลาว่าการดูดีมากเลยนะ @ แล้วเธอก็ทำทั้งหมดนี่ด้วยตัวเอง เธอทำงานหนักมากจริงๆ$7#$b#...ฉันภูมิใจในตัวเธอและการตัดสินใจของเธอจริงๆ นะ$12",
  "Core.Hector.MovieTheater": "โรงหนังเหรอ!? โคตรเจ๋งเลย ไปกันเถอะ!$9#$b#ฉันสัญญาว่าจะไม่พูดแทรกตลอดทั้งเรื่อง ฉัน *รัก* การดูหนังที่สุดเลย$17",
  // BIRTHDAYS
  "Core.Hector.Fall25": "วันนี้เป็นวันเกิดของมาเทโอล่ะ$14#$b#ไปแกล้งไอ้บ้านั่นให้หนักๆ เลยนะ!$9",
  // END OF SEASON
  "Core.Hector.SpringEnd": "ในฤดูใบไม้ผลิ ช่วงเวลาที่งดงามแห่งการสวมแหวน ยามเหล่านกน้อยเริงร่าร้องเพลง เฮ้ ดิง! ดิง อะ ดิง คู่รักแสนหวานต่างชื่นชอบ... ฤดูใบไม้ผลิ!$3",
  "Core.Hector.SummerEnd": "ฉันได้รับความเศร้าในฤดูร้อน ความเศร้าในฤดูร้อนแล้วสิ! ความเศร้าในฤดู-ฤดูร้อน ฤดูร้อน ความเศร้าในฤดูร้อน-$3",
  "Core.Hector.FallEnd": "หลบซ่อนตัวจากสภาพอากาศ ดื่มชาและขนมปังปิ้ง! ขนมปังลูกเกดทาเนย ก็ชดเชยการขาดแสงแดดไม่ได้หรอก เพราะฤดูร้อนผ่านพ้นไปหมดแล้ว...!$3",
  "Core.Hector.WinterEnd": "และท้องฟ้าก็กลายเป็นสีหม่นหมองแห่งฤดูหนาว! ยึดมั่นในความหวังของเธอไว้นะ เพื่อนเอ๋ย พูดน่ะมันง่าย แต่ถ้าหากความหวังของเธอต้องมลายหายไป - ก็แค่แสร้งทำเป็นว่าเธอสร้างมันขึ้นมาใหม่ได้ก็พอ!$3",
  // SVE COMMUNITY DAY
  "Core.Hector.CommunityCenter4": "มาเทโอบอกว่านี่เป็นความคิดที่ดี ฉันไม่เห็นด้วยเลยสักนิด$24",
  "Core.Hector.CommunityCenter6": "การมาอยู่ที่นี่ทำให้ฉันรู้สึกอยากจะอ้วก แต่ในขณะเดียวกันมันก็รู้สึกดีนิดๆ นะ ฉันเดาว่างั้นมั้ง$8",
  "Core.Hector.CommunityCenter8": "ทุกคนต่างก็หมกมุ่นอยู่กับกิจกรรมมากมายหลายอย่างเหลือเกิน งานศิลปะของลีอาห์ (Leah) เยี่ยมมากเลย แล้วฉันก็รู้สึกว่าความเก่งกาจของมารุ (Maru) กำลังถูกมองข้ามไปอยู่นะ-$6#$b#อะไรนะ? ไม่หรอก ฉันกำลังรู้สึกแย่สุดๆ เลยล่ะ แน่นอนสิ!$5",
  "Core.Hector.CommunityCenter10": "เอาล่ะๆ ยอมรับก็ได้ นี่ก็รู้สึกดีนะ โอเคไหม? รู้สึกดีน่ะแหละ$14#$b#ฉันก็แค่หมาแก่ที่กำลังเรียนรู้กลไกใหม่ๆ เท่านั้นเอง โอเคไหมล่ะ?$13",
  // FESTIVALS
  "Core.Hector.EggFestival": "อะไรนะ? เธอคิดว่าฉันมาที่นี่เพื่อก่อเรื่องวุ่นวายงั้นเหรอ? ฉันดูเหมือนพวกมือสมัครเล่นสำหรับเธอเหรอไง? เปล่าหรอก ฉันมาเพื่อกินของฟรีต่างหาก$6#$b#ฉันจัดการเรื่องนั้นไปตั้งแต่ปลายฤดูใบไม้ร่วงปีที่แล้ว เพื่อให้ได้กลิ่นเหม็นขั้นสุดยอดแล้วล่ะ!$9",
  "Core.Hector.FlowerDance": "โอ้ ฉันเกลียดงานเต้นรำดอกไม้ (Flower Dance) ชะมัด สิ่งเดียวที่ฉันเกลียดยิ่งกว่าการโดนสั่งให้ใส่ชุดอะไรสักอย่าง ก็คือการต้องมาเต้นรำโง่ๆ ทั้งๆ ที่ท้องอิ่มแปล้นี่แหละ$16",
  "Core.Hector.Luau": "ความจริงฉันก็ปลูกของไว้สำหรับพรุ่งนี้เหมือนกันนะ มั่นใจเลยว่าเธอคงคิดว่ามันต้องแย่แน่ๆ$0#$b#แต่สิ่งเดียวที่ฉันรักมากกว่าการสร้างเรื่องวุ่นวายก็คือการกินนี่แหละ เพราะงั้นมันต้องออกมาดีแน่ๆ$1",
  "Core.Hector.MoonlightJelly": "เอาจริงๆ ฉันชอบนะเวลาพวกแมงกะพรุน (Jellies) แวะมาน่ะ ไม่มีปรากฏการณ์ธรรมชาติไหนที่ฉันไม่ชื่นชมหรอก$8#$b#แต่มันก็รู้สึกแปลกไปจริงๆ นะ ที่ไม่ได้มานั่งดูพวกมันคนเดียวน่ะ...$24",
  "Core.Hector.SDVFair": "โอ้ มีการแข่งขันด้วย! อยากให้ฉันช่วยโกงไหม?$9#$b#อ้าว เอาจริงๆ เธอคงไม่ต้องโกงหรอก ฉันเห็นมาแล้วล่ะว่าเธอทำอะไรได้บ้าง โชคดีนะ$0",
  "Core.Hector.SpiritsEve": "ฉันมั่นใจว่าป่านนี้มาเทโอคงบ่นเรื่อง 'กฎ' ของเทศกาลสปิริตส์อีฟ (Spirit's Eve) ให้เธอฟังจนหูชาแล้วล่ะ ซึ่งนั่นก็ดีนะ แต่...$24#$b#กฎที่แท้จริงคือการป่วน ไม่ใช่การทำร้ายต่างหากล่ะ การแกล้งกันมันไม่สนุกหรอกนะถ้าทำให้ใครต้องเจ็บตัวหรือเสียใจน่ะ$14#$b#แต่พูดก็พูดเถอะ ฉันมีแผนป่วนเตรียมไว้เพียบเลยนะ! ระวังตัวไว้ให้ดีล่ะ!$9",
  "Core.Hector.IceFestival": "การจับปลาขึ้นมาทำอาหารเลย น่าจะมีจริยธรรมและคำนึงถึงสิ่งแวดล้อมมากกว่าการเอาเบ็ดไปเกี่ยวแล้วโยนมันกลับลงน้ำนะ$26#$b#มันทำให้ปลาเครียด ผิวหนังเป็นแผล แล้วก็ทำให้พวกมันหมดแรงด้วย! แค่กินมันไปซะดีกว่ามาทำเป็นอ้าง 'ศีลธรรม' ทั้งที่มันไม่ได้มีศีลธรรมเอาซะเลย! ช่างเป็นเทศกาลที่งี่เง่าจริงๆ$27",
  "Core.Hector.NightMarket": "เธอจะไปงานตลาดกลางคืน (Night Market) ไหม? ฉันว่าจะไปยืนดูเรืออยู่แถวๆ แนวป่าน่ะ$7",
  "Core.Hector.WinterStar": "เทศกาลวินเทอร์สตาร์ (Winter Star) ก็เป็นเทศกาลที่งี่เง่าอีกงานนึงใช่ไหมล่ะ? แต่ก็นะ ฉันหาหนังสัตว์ไปให้มาเทโอเพื่อที่พวกเขาจะได้เอาไปซ่อมชุดเกราะได้น่ะ หวังว่าจะชอบนะ$13#$b#ไม่มีใครมาหาว่าฉันไม่พยายามไม่ได้หรอกนะ$14",
  // ROMANTIC (POSITIVE)
  "Core.Hector.GiveFlowersA": "ดอกไม้พวกนี้ดูสวยเกินกว่าที่เธอจะปลูกเองนะ เอดีน (Aideen) ทำให้เธอเหรอ?$9#$b#โอ้ ให้ตายสิ มันสำหรับฉันเหรอ? เอ้อ คือ-$4#$b#ขอบใจนะ ฉัน เอ่อ รู้สึกแบบเดียวกันนะ ฉันคิดว่างั้นนะ ใช่$11",
