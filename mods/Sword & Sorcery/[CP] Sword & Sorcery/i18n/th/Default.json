*/
  // SEASONAL EARLY HEART 
  // SPRING
  "Core.Mateo.Spring.EarlyHeart.1": "ไง ชาวไร่ รู้ไหมว่าเรื่องฉุกเฉินในฤดูใบไม้ผลิเขาเรียกว่าอะไร? 'May Day' (เมย์เดย์) ไงล่ะ$14",
  "Core.Mateo.Spring.EarlyHeart.2": "อากาศเริ่มอุ่นขึ้นแล้วนะ สังเกตได้จาก 'ฤดูใบไม้ผลิ' (Spring) ในจังหวะก้าวเดินของผู้คนไงล่ะ$14",
  "Core.Mateo.Spring.EarlyHeart.3": "นายปลูกอะไรบ้างเนี่ย? พาร์สนิป มันฝรั่ง แล้วมีอะไรอีกไหม? ฉันไม่ใช่พวกถนัดงานเกษตรกรรมซะด้วยสิ$0",
  "Core.Mateo.Spring.EarlyHeart.4": "คนขายดอกไม้จะพูดว่าอะไรในช่วงฤดูใบไม้ผลิล่ะ @? $1#$b#ธุรกิจกำลังเบ่งบานไงล่ะ$32",
  "Core.Mateo.Spring.EarlyHeart.5": "ระวังตัวด้วยนะชาวไร่ พวกโกเลมป่าเถื่อน (Wilderness Golem) มักจะอารมณ์ร้ายเป็นพิเศษในฤดูใบไม้ผลิ เผื่อว่าพวกมันโผล่มาในที่ดินของนาย$34#$b#อย่างน้อยพวกมันก็จัดการง่ายกว่าโกเลมหิน (Stone Golem) นะ - มันมีสองแบบ คอยระวังพวกที่อึดกว่าเอาไว้ด้วยล่ะ ตัวมันจะใหญ่กว่าและมีเขา$9",
  "Core.Mateo.Spring.EarlyHeart.6": "ฤดูใบไม้ผลิน่าจะยุ่งมากสำหรับนายเลยนะ มีงานให้ทำเพียบเลย หาเวลาพักผ่อนบ้างล่ะ นายควรให้รางวัลตัวเองนะ$24",
  "Core.Mateo.Spring.EarlyHeart.7": "นายเป็นพวกถนัดใช้ดาบ ค้อน หรือมีดสั้นล่ะ?$0#$b#ฉันถนัดใช้ดาบยาวนะ แต่จะเก่งกว่าถ้าใช้มีดสั้นคู่ อย่าลืมบำรุงรักษาอาวุธที่นายใช้มาตลอดฤดูหนาวด้วยล่ะ$1",
  "Core.Mateo.Spring.EarlyHeart.8": "เป็นช่วงเวลาที่ดีของปีเลยนะที่จะหาพวกฟอสซิล ถ้านายสนใจเรื่องพวกนี้น่ะ พวกปูกับกบดูเหมือนจะเจอบ่อยมากแถวๆ นี้$36",
  "Core.Mateo.Spring.EarlyHeart.9": "ไง @! ฉันเจอเจ้านี่อยู่ข้างล่างน่ะ นายช่วยเอาไปให้กุนเธอร์ (Gunther) แทนฉันทีได้ไหม? ขอบใจนะ! [117 118 119 120 110 111 112]$14",
  "Core.Mateo.Spring.EarlyHeart.10": "ถ้าได้ช็อกโกแลตร้อนๆ สักแก้วตอนนี้คงจะดีมากเลย สิ่งที่ดีที่สุดที่ฉันทำได้ในเต็นท์ก็คือเตาแม่เหล็กไฟฟ้านี่แหละ ขืนใช้อย่างอื่นมีหวังไฟไหม้แน่ๆ$16#$b#ฉันไม่ค่อยเก็บอาหารไว้ในนั้นทีละเยอะๆ หรอกนะ เผื่อมีสัตว์ป่าบุกเข้ามา$8",
  "Core.Mateo.Spring.EarlyHeart.11": "ไง ชาวไร่ ขอให้วันนี้เป็นวันที่ดีนะ เข้าใจไหม? เชิดหน้าเข้าไว้$0",
  "Core.Mateo.Spring.EarlyHeart.12": "ช่วงนี้เจออะไรน่าสนใจตอนไปผจญภัยบ้างไหม @? ฉันอยากฟังเรื่องที่นายไปเจอมาจัง$0",
  "Core.Mateo.Spring.EarlyHeart.13": "ขอโทษด้วยนะที่หน้าฉันดูนิ่งๆ เหมือนคนเบื่อโลกน่ะชาวไร่$15",
  "Core.Mateo.Spring.EarlyHeart.14": "ไง ชาวไร่ หวังว่านายจะสบายดีนะ ตั้งใจทำงานต่อไปล่ะ แต่อย่าหักโหมเกินไปนะ$1",
  "Core.Mateo.Spring.EarlyHeart.15": "พ่อค้าที่ทะเลทรายมีพวกกล่องสมบัติโบราณอยู่ ข้างในมีของอย่างพวกอุปกรณ์คนแคระ (Dwarven Gadget) และวัตถุโบราณอื่นๆ ด้วยล่ะ$34#$b#แต่ฉันก็ไม่ค่อยแน่ใจหรอกนะว่าเขาไปเอาของพวกนี้มาจากไหน ฉันรู้แค่ว่าผู้หญิงที่อยู่บนรถเข็นเร่ร่อนรับของมาจากโกโตโร่ (Gotoro) ซึ่งมัน... เสี่ยงมากๆ เลยล่ะ$37",
  "Core.Mateo.Spring.EarlyHeart.16": "หวังว่านายจะโอเคนะ ตั้งแต่ที่ไปเจอพวกสไลม์นั่นน่ะ$32",
  // SUMMER
  "Core.Mateo.Summer.EarlyHeart.1": "ไง ชาวไร่ ข้างนอกอากาศชื้นมากเลยนะ... ระวังตัวด้วยล่ะ ดื่มน้ำเยอะๆ นะ$0",
  "Core.Mateo.Summer.EarlyHeart.2": "ตอนที่แสงแดดส่องผ่านเต็นท์เข้ามาในตอนเช้า มันคุ้มค่าเสมอที่จะตื่นขึ้นมาดูพระอาทิตย์ขึ้น มันมีบางอย่างในฤดูร้อนที่วิเศษมากจริงๆ - อาจจะเป็นวิธีที่แสงสะท้อนกับผิวน้ำล่ะมั้ง$4",
  "Core.Mateo.Summer.EarlyHeart.3": "ว่าไง ชาวไร่ ฤดูกาลนี้ฉันจะได้เจอนายที่ชายหาดไหมเนี่ย?$14",
  "Core.Mateo.Summer.EarlyHeart.4": "นี่เป็นช่วงเวลาที่ดีที่สุดของปีในการไปว่ายน้ำเลยล่ะ แต่ระวังด้วยนะ ถ้านายโดนอะไรข่วนมาจากในถ้ำ น้ำทะเลมันจะยิ่งทำให้แผลแสบเอาได้$24",
  "Core.Mateo.Summer.EarlyHeart.5": "ค้างคาวน้ำแข็ง (Frost Bat) เอาชีวิตรอดในสภาพอากาศชื้นๆ ได้ยากมาก นายเลยไม่น่าจะเจอมันบนพื้นดินหรอก แต่ในหุบเขานี้มีฝูงค้างคาวผลไม้ (Fruit Bat) ธรรมดาอยู่หลายฝูงเลยนะ$12",
  "Core.Mateo.Summer.EarlyHeart.6": "รู้ไหมว่าเครื่องปรับอากาศถูกใช้ครั้งแรกในโรงภาพยนตร์? มันเป็นส่วนหนึ่งของเหตุผลที่เรามีหนังฟอร์มยักษ์ช่วงซัมเมอร์ไงล่ะ - ผู้คนแห่กันไปตากแอร์คลายร้อนกันน่ะ$1",
  "Core.Mateo.Summer.EarlyHeart.7": "ฉันแกะสะเก็ดแผลที่ได้มาจากการสู้กับมอนสเตอร์ออกน่ะ คงเป็นข้อเสียอย่างหนึ่งของการใส่เสื้อปลดกระดุมล่ะมั้ง ใครๆ ก็เลยเห็นว่าฉันทำตัวเองสะบักสะบอมแค่ไหน$8#$b#บางวันมันก็กวนใจฉันนะ แต่บางวันก็ไม่ แต่ก็ไม่เคยถึงขั้นทำให้ฉันอยากใส่เสื้อแขนยาวหรือเสื้อปิดคอมิดชิดในฤดูร้อนหรอกนะ$13",
  "Core.Mateo.Summer.EarlyHeart.8": "พวกหัวเหล็ก (Metal Head) ที่อาศัยอยู่ในเหมืองโชคดีนะ ขืนพวกมันขึ้นมาบนพื้นดินในช่วงฤดูร้อนของหุบเขา คงได้สุกคาหมวกเหล็กใบเล็กๆ นั่นแน่ๆ$9",
  "Core.Mateo.Summer.EarlyHeart.9": "ตอนนี้ในเหมืองอากาศเย็นกว่าบนพื้นดินอีกนะ ช่วยเอาเจ้านี่ไปส่งให้ฉันหน่อยได้ไหม? [96 97 98 99]$14",
  "Core.Mateo.Summer.EarlyHeart.10": "ตอนนี้ในเหมืองอากาศเย็นกว่าบนพื้นดินอีกนะ ช่วยเอาเจ้านี่ไปส่งให้ฉันหน่อยได้ไหม? [100 101 103]$14",
  "Core.Mateo.Summer.EarlyHeart.11": "ผ่าหินแล้วเจอเจ้านี่น่ะ - เอ้านี่ @! ขอบใจนะที่เอาไปให้กุนเธอร์แทนฉัน [110 111 112 117 118 119 120]$14",
  "Core.Mateo.Summer.EarlyHeart.12": "ไง ชาวไร่ นายจะพูดว่าอะไรเวลาสายเบ็ดพันกัน? ดูเหมือนว่าจะมีปัญหาบางอย่าง 'ผูกมัด' เราอยู่สินะ$15",
  "Core.Mateo.Summer.EarlyHeart.13": "ตอนที่ฉันเพิ่งเริ่มลงเหมืองตอนเด็กๆ ฉันหลงใหลพวกภูตฝุ่น (Dust Sprite) เป็นพิเศษเลยล่ะ ตัวเล็กๆ น่ารักดีเนอะ ว่าไหม?$12",
  "Core.Mateo.Summer.EarlyHeart.14": "ไง @ นี่ของใหม่ที่ฉันเพิ่งเจอ บางทีมอนสเตอร์ก็ดรอปของแปลกๆ ออกมาเหมือนกันเนอะ ว่าไหม? [113 115 116]$14",
  "Core.Mateo.Summer.EarlyHeart.15": "ไง @ นี่ของใหม่ที่ฉันเพิ่งเจอ บางทีมอนสเตอร์ก็ดรอปของแปลกๆ ออกมาเหมือนกันเนอะ ว่าไหม? [104 105 106]$14",
  "Core.Mateo.Summer.EarlyHeart.16": "ฉันอยากจะมีส่วนร่วมกับชุมชนมากกว่านี้นะ แต่ยังคิดไม่ออกว่าจะทำยังไงดี บางทีมาร์นี่อาจจะต้องการคนช่วยงานในฟาร์มปศุสัตว์บ้างก็ได้$8",
  // FALL
  "Core.Mateo.Fall.EarlyHeart.1": "ไม่มีอะไรจะสู้การเดินเล่นรับลมเย็นๆ บนภูเขาในฤดูใบไม้ร่วงได้อีกแล้วล่ะ นายไม่ชอบความสดชื่นในอากาศแบบนี้เหรอ?$4",
  "Core.Mateo.Fall.EarlyHeart.2": "ฉันต้องการฟักทองเพิ่มอีกสักสองสามลูกสำหรับเต็นท์น่ะ... ถ้านายเก็บเกี่ยวแล้ว ฉันอาจจะขอซื้อสักพวงนึงนะ$13",
  "Core.Mateo.Fall.EarlyHeart.3": "ช่วงเวลานี้ของปี ฉันพยายามจะใช้เวลาอยู่ข้างล่างนั่นให้น้อยที่สุด แต่ฉันก็เจอเจ้านี่มาน่ะ [96 97 98 99 100 101 103]$14",
  "Core.Mateo.Fall.EarlyHeart.4": "ฟาร์มคงจะดูสวยมากแน่ๆ เลยช่วงเวลานี้ของปี ดอกทานตะวันกับฟักทองคงจะเต็มไปหมดเลยใช่ไหมล่ะ?$12",
  "Core.Mateo.Fall.EarlyHeart.5": "ฉันชอบมากเลยที่ทุกอย่างกลายเป็นสีทองในช่วงเวลานี้ของปี แค่ได้เดินเล่นรอบๆ ก็รู้สึกดีแล้ว$32",
  "Core.Mateo.Fall.EarlyHeart.6": "ตอนนี้อยากดื่มไซเดอร์อุ่นๆ จัง หรือไม่ก็พวกขนมรสฟักทอง หรือพายแอปเปิ้ลกินคู่กับไอศกรีมก็ดีนะ...$36",
  "Core.Mateo.Fall.EarlyHeart.7": "นายปลูกดอกทานตะวันบ้างไหม? นายเอาเมล็ดมันไปทำอาหารหรือเปล่า? อ้อ! ว่าแต่ ฉันเจอเจ้านี่น่ะ เผื่อนายจะเอาไปบริจาคได้ [117 118 119 120]$15",
  "Core.Mateo.Fall.EarlyHeart.8": "มันเป็นแค่ข้อสันนิษฐานนะ แต่ฉันมั่นใจเลยว่ามันต้องมีความเชื่อมโยงกันระหว่างเทศกาล Spirit's Eve กับพวกผีต่างๆ ที่สิงสู่อยู่ในเหมืองแน่ๆ บางทีพวกมันอาจจะขึ้นมาบนพื้นดินแล้วก่อเรื่องวุ่นวายก็ได้...$35",
  "Core.Mateo.Fall.EarlyHeart.9": "นายเอาฟักทองทั้งหมดที่ปลูกไปทำอะไรเหรอ...? อ้อ! ว่าแต่ ฉันเจอเจ้านี่น่ะ เผื่อนายจะเอาไปบริจาคได้ [110 111 112]$14",
  "Core.Mateo.Fall.EarlyHeart.10": "นายเป็นทีมแอปเปิ้ลไซเดอร์ ทีมเครื่องเทศฟักทอง หรือทีมช็อกโกแลตร้อนล่ะ? เครื่องดื่มประจำฤดูใบไม้ร่วงของนายคืออะไร แล้วทำไมถึงเป็นเครื่องเทศฟักทองล่ะ?$36",
  "Core.Mateo.Fall.EarlyHeart.11": "ฉันเดินทางมาเยอะนะ แต่การเปลี่ยนฤดูกาลที่อื่นมันไม่ได้ดูยิ่งใหญ่เท่าในหุบเขานี้เลย มันเป็นหนึ่งในสิ่งที่ฉันรักเกี่ยวกับการอาศัยอยู่ที่นี่ เวลาเดินไปข้างหน้าเสมอแม้ในตอนที่นายรู้สึกติดขัด และทิวทัศน์ที่เปลี่ยนไปก็ช่วยเตือนใจเรื่องนั้นได้ดีเลยล่ะ$1",
  "Core.Mateo.Fall.EarlyHeart.12": "นายเคยเห็นพวกเด็กปลาหมึก (Squid Kid) บ้างไหม? ฉันก็ไม่ค่อยแน่ใจหรอกนะว่าทำไมพวกเขาถึงเรียกมันแบบนั้น ไอ้พวกตัวแสบนั่นมันยิงลูกไฟได้ด้วยนะ ระวังตัวด้วยล่ะถ้าเจอมัน ดูแลตัวเองดีๆ ตอนไปผจญภัยล่ะ @$32",
  "Core.Mateo.Fall.EarlyHeart.13": "ฉันคิดว่าพวกหน้ากากทองคำ (Golden Mask) ที่นายบังเอิญเจอในทะเลทราย น่าจะเป็นเวอร์ชั่นสำหรับพิธีกรรมที่คล้ายๆ กับที่พวกหมอผีเงา (Shadow Shaman) ใส่นั่นแหละ สงสัยจังว่าพวกเขาเคยอาศัยอยู่ที่นั่นในอดีต หรือมันเป็นแค่ความบังเอิญแปลกๆ กันแน่นะ$37",
  "Core.Mateo.Fall.EarlyHeart.14": "ถ้านายต้องการดูแลดาบของนายสักหน่อยล่ะก็ ลองใช้น้ำมันแร่ (Mineral Oil) ดูสิ น้ำมันหล่อลื่น (Rem oil) ที่ใช้กับจักรเย็บผ้าก็ใช้ได้เหมือนกันนะ น่าจะหาซื้อได้ง่ายกว่าในพื้นที่นี้ด้วย ปลอดภัยไว้ก่อนล่ะเวลาไปผจญภัย @$0",
  "Core.Mateo.Fall.EarlyHeart.15": "ฉันดึงเจ้านี่ขึ้นมาจากรังของพวกดั๊กกี้ (Duggy) น่ะ และตอนนี้มันเป็นของนายแล้ว! [104 105 106]$15",
  "Core.Mateo.Fall.EarlyHeart.16": "ฉันดึงเจ้านี่ขึ้นมาจากรังของพวกดั๊กกี้ (Duggy) น่ะ และตอนนี้มันเป็นของนายแล้ว! [113 115 116]$15",
  // WINTER
  "Core.Mateo.Winter.EarlyHeart.1": "ฤดูหนาวเป็นฤดูที่แย่ที่สุดเลย แต่ก็อย่าเพิ่งเอาคำพูดนี้ไปตัดสินฉันซะล่ะ$23",
  "Core.Mateo.Winter.EarlyHeart.2": "เป็นช่วงเวลาที่ดีของปีในการไปผจญภัยนะชาวไร่ ฉันเจอเจ้านี่น่ะ ช่วยเอาไปส่งต่อทีได้ไหม? [96 97 98 99 100 101 103]$14",
  "Core.Mateo.Winter.EarlyHeart.3": "นายใช้เวลาอยู่ข้างล่างนั่นเยอะไหมช่วงฤดูหนาว? มีสติอยู่ตลอดเวลาล่ะชาวไร่$10",
  "Core.Mateo.Winter.EarlyHeart.4": "พออากาศเริ่มเย็นลงและมืดเร็วขึ้น ฉันก็รู้สึกเหนื่อยจัง... แค่ต้องมองไปข้างหน้า อีกเดี๋ยวฤดูใบไม้ผลิก็จะมาถึงแล้ว$37",
  "Core.Mateo.Winter.EarlyHeart.5": "ดีใจจังที่นายไม่ต้องทำงานในไร่ตอนที่อากาศหนาวเหน็บขนาดนี้ บางทีนอนอ่านหนังสืออยู่บ้านน่าจะดีกว่านะ$7",
  "Core.Mateo.Winter.EarlyHeart.6": "เมื่อไหร่จะสิ้นปีสักทีนะ คิดถึงแสงแดดจังเลย$6",
  "Core.Mateo.Winter.EarlyHeart.7": "นายจะเรียนรู้ที่จะเห็นคุณค่าของแสงแดดได้เร็วมากๆ เลยล่ะ พอท้องฟ้ามันเริ่มมืดตั้งแต่ก่อนมื้อค่ำน่ะ...$16",
  "Core.Mateo.Winter.EarlyHeart.8": "วันนี้ความหนาวมันบาดลึกถึงกระดูกเลยเนอะ ว่าไหม? อ่า ก็นะ มีนายอยู่ด้วยก็ดีขึ้นเยอะ เอ้านี่ @ [110 111 112 117 118 119 120]$0",
  "Core.Mateo.Winter.EarlyHeart.9": "นอกจากลงเหมืองแล้ว ช่วงฤดูหนาวนายทำอะไรให้ตัวเองยุ่งบ้างล่ะ? เลี้ยงสัตว์นั่นก็ชัวร์อยู่แล้ว แต่มีอย่างอื่นอีกไหม? ตกปลาเหรอ? หรือว่านี่คือช่วงเวลาที่ใกล้เคียงกับคำว่าวันหยุดพักผ่อนที่สุดของนายแล้ว?$6",
  "Core.Mateo.Winter.EarlyHeart.10": "ขุดเจอเจ้านี่มาน่ะ @ มันเป็นของนายแล้ว เอ้อ แล้วก็... ใจดีกับตัวเองหน่อยนะช่วงเวลานี้ของปี ตกลงไหม? [113 115 116]$16",
  "Core.Mateo.Winter.EarlyHeart.11": "นายไปแช่น้ำพุร้อนบนภูเขาบ่อยไหม? ฉันเคยขึ้นไปทางนั้นสองสามครั้ง ส่วนใหญ่ก็ตอนกลางคืนน่ะ มันดีต่อกล้ามเนื้อนะ นายออกแรงเยอะแยะไปหมด อย่าลืมดูแลตัวเองซะบ้างล่ะ$32",
  "Core.Mateo.Winter.EarlyHeart.12": "รู้ไหม เราไม่เคยค้นพบร่องรอยทางกายภาพของพวกเอลฟ์เลยนะ แต่นั่นไม่ได้หมายความว่าพวกเขาสูญพันธุ์ไปแล้วหรอกนะ - การหลบซ่อนตัวถือว่าฉลาดมากนะ ท่ามกลางความขัดแย้งที่เกิดขึ้นทั้งหมดนี้$37#$b#แต่เครื่องประดับของพวกเขาสวยมากเลยนะ เห็นได้ชัดเลยว่าพวกเขาส่วนใหญ่เป็นช่างฝีมือที่มีพรสวรรค์มากๆ$35",
  "Core.Mateo.Winter.EarlyHeart.13": "สิ่งที่ฉันอยากทำที่สุดตอนนี้คือนอนหลับ นอนให้เหมือนหมีไปเลย การจำศีลควรเป็นหนึ่งในตัวเลือกสิ ฉันจะไปยื่นเรื่องร้องเรียนอย่างเป็นทางการเลยคอยดู$16#$b#แต่มันก็ค่อนข้างลำบากนะ การอยู่เต็นท์ช่วงเวลานี้ของปีมันอึดอัดมากเลยล่ะ$17",
  "Core.Mateo.Winter.EarlyHeart.14": "วันก่อนฉันโดนพวกโครงกระดูกฟันเข้าที่ไหล่ซะลึกเลย พวกมันเอากระดูกของพวกพ้องที่ล้มไปแล้วมาขว้างใส่ศัตรูเหรอ? ต้องใช่แน่ๆ โคตรน่าสยดสยองเลย$11",
  "Core.Mateo.Winter.EarlyHeart.15": "ฉันยอมทำทุกอย่างเลยนะเพื่อให้ได้เป็นแค่ Pepper Rex ธรรมดาๆ ตัวนึง ได้อยู่ในระบบถ้ำยุคก่อนประวัติศาสตร์ที่อบอุ่นและปลอดภัย โดยไม่ต้องมานั่งแบกรับภาระทางอารมณ์และหนี้กู้ยืมเพื่อการศึกษาเนี่ย$16",
  "Core.Mateo.Winter.EarlyHeart.16": "ฉันเจอเจ้านี่ตอนไปสำรวจมา ฝากเอาไปให้กุนเธอร์แทนฉันทีได้ไหม? [96 97 98 99 100 101 103]$15",
  // SEASONAL LATE HEART
  // SPRING
  "Core.Mateo.Spring.LateHeart.1": "ตอนที่ฉันยังเรียนอยู่ ฤดูใบไม้ผลิเป็นช่วงเวลาที่เครียดมากเสมอ การเริ่มต้นเทอมใหม่ทำให้ฉันอยากจะทำทุกอย่างให้ดีที่สุด ฉันดีใจนะที่มันจบลงแล้ว ตับของฉันก็คงจะรู้สึกขอบคุณที่เรียนจบพอๆ กับฉันนั่นแหละ$9",
  "Core.Mateo.Spring.LateHeart.2": "นายรู้ไหมว่าพวกโครงกระดูกใช้เวทมนตร์ได้ด้วย? ฉันก็ไม่รู้เหมือนกัน จนกระทั่งมีตัวนึงเสกน้ำแข็งแช่เท้าฉันติดกับพื้นน่ะ$7#$b#แถมมันยังใส่ผ้าคลุมด้วยนะ ผ้าคลุมพริ้วสะบัดอย่างกับในหนังเลยตอนที่มันพุ่งเข้ามาหาฉันน่ะ$9#$b#มันแสดงให้เห็นว่าการเข้าไปในเหมืองด้วยความระมัดระวังนั้นคุ้มค่าเสมอ ปลอดภัยไว้ก่อนนะ @$24",
  "Core.Mateo.Spring.LateHeart.3": "เราไม่ค่อยรู้เรื่องการเคลื่อนไหวของมัมมี่มากนักหรอก เพราะวิธีเดียวที่จะจัดการพวกมันได้คือใช้ระเบิด ซึ่งนั่นมันก็ไม่เหลือซากอะไรให้ศึกษาเท่าไหร่เลย$9#$b#การจับมัมมี่เป็นๆ ดูจะโหดร้ายเกินความจำเป็น โชคร้ายหน่อยที่สิ่งที่ดีที่สุดที่เราทำได้ก็คือการศึกษาพวกสุสานแปลกๆ ที่พวกมันมักจะเดินเตร่ไปมาหลังจากที่จัดการมันได้แล้ว$8#$b#ใจจริงฉันก็อยากจะศึกษาให้ลึกกว่านั้นนะ แต่ฉันไม่อยากโดนคำสาปน่ะสิ$34",
  "Core.Mateo.Spring.LateHeart.4": "ไง @...ฉันเจอเจ้านี่ในกล่องน่าขนลุกใบเล็กๆ ในถ้ำกะโหลกน่ะ บางทีกุนเธอร์อาจจะรู้ว่าต้องทำยังไงกับมัน [126 127]$23",
  "Core.Mateo.Spring.LateHeart.5": "วันนี้มีงานที่ต้องทำเพียบเลย แต่ฉันยินดีมากๆ ที่จะหาเวลาว่างให้ตายน ถ้านายต้องการอะไรก็บอกฉันได้เลยนะ เข้าใจไหม? ฉันอยู่ตรงนี้แหละ$1",
  "Core.Mateo.Spring.LateHeart.6": "นายเคยเห็นพวกหุ่นยนต์เฝ้ายามของคนแคระ (Dwarvish Sentry) ในภูเขาไฟบนเกาะจินเจอร์ไหม? ถึงพวกมันจะเคลื่อนไหวช้า แต่ก็พุ่งเข้าหานายแบบไม่คิดชีวิตเลยนะ$3#$b#เห็นได้ชัดเลยว่าพวกคนแคระต้องมีอะไรบางอย่างที่อยากจะปกป้องไว้ในนั้นแน่ๆ มันก็เลยคุ้มค่าที่จะสำรวจ แต่...$34#$b#ระมัดระวังตัวตอนนำทางในนั้นด้วยนะ @ ฉันไม่อยากได้ยินข่าวลือว่ามีอะไรเกิดขึ้นกับนายน่ะ$37",
  "Core.Mateo.Spring.LateHeart.7": "ในเหมืองมีแมลงเยอะเกินไปแล้วนะ ทั้งแมงมุมตัวเบ้ง แมลงกิ่งไม้ แล้วก็พวกแมลงวันถ้ำกับหนอนอีกตั้งหลายสายพันธุ์นับไม่ถ้วน - น่าขยะแขยงชะมัด$11#$b#ฉันเดาว่ามันก็เป็นเรื่องดีนะที่ส่วนใหญ่พวกมันจะอยู่แต่ข้างล่างนั่น ก็นะ นั่นต้องขอบคุณกิลด์นักผจญภัยเลยแหละ เนอะ?$0",
  "Core.Mateo.Spring.LateHeart.8": "ฉันสงสัยว่าน่าจะมีพวก Pepper Rex สายพันธุ์อื่นที่เรายังไม่เคยเห็นอยู่อีกนะ ยกตัวอย่างเช่น กระดูกหลายๆ ชิ้นที่เราพบในพื้นที่ยุคก่อนประวัติศาสตร์มันไม่ตรงกับสายพันธุ์ที่ยังมีชีวิตอยู่เลย แต่มันกลับมีอายุอยู่ในช่วงยี่สิบปีที่ผ่านมานี้เอง$35#$b#นี่แหละคือสิ่งที่จะเกิดขึ้นเมื่อ 'เด็กที่บ้าไดโนเสาร์' โตขึ้นมา @ ฉันเปลี่ยนความหลงใหลในวัยเด็กให้กลายเป็นงานประจำที่อันตรายสุดๆ เลยล่ะ$36",
  "Core.Mateo.Spring.LateHeart.9": "คุณหมอฮาร์วีย์คอยดูแลเรื่องสุขภาพของฉันเป็นอย่างดีเลยล่ะ ฉันมักจะสะบักสะบอมกลับมาจากเหมืองอยู่บ่อยๆ และทุกอย่างก็ดีขึ้นมากเลยตั้งแต่ฉันเริ่มไปหาเขา$15#$b#ไม่มีอีกแล้วการตื่นขึ้นมาแล้วกลิ้งตกเตียงพร้อมกับเสียงร้องประสานเสียงดังก๊อบแก๊บจากข้อต่อของตัวเองน่ะ$14",
  "Core.Mateo.Spring.LateHeart.10": "ไง @! ฉันมีเรื่องจะเคลียร์กับ- ล้อเล่นน่ะ เพิ่งเจอเจ้านี่ตอนลงไปข้างล่าง เผื่อนายจะต้องการมันสำหรับพิพิธภัณฑ์นะ [96 97 98 99]$0",
  "Core.Mateo.Spring.LateHeart.11": "นายรู้ไหมว่าครึ่งท่อนล่างของดั๊กกี้ (Duggy) รูปร่างหน้าตาเป็นยังไง? มันติดอยู่ในหัวฉันมาทั้งวันเลยนะ เท่าที่เรารู้ มันอาจจะมีรูปร่างเหมือนงูก็ได้ แล้วก็ไม่มีใครยอมเสียเวลาดึงมันขึ้นมาจากหลุมเพื่อเช็คดูเลย แล้ววงการวิชาการจะทำยังไงล่ะถ้าไม่มีคนอย่างพวกเราน่ะ @? $1",
  "Core.Mateo.Spring.LateHeart.12": "ไง @! ฉันมีเรื่องจะเคลียร์กับ- ล้อเล่นน่ะ เพิ่งเจอเจ้านี่ตอนลงไปข้างล่าง เผื่อนายจะต้องการมันสำหรับพิพิธภัณฑ์นะ [96 97 98 99]$0",
  "Core.Mateo.Spring.LateHeart.13": "ไง @! ฉันขุดเจอซากฟอสซิลล่ะ ลองดูสิ ฝากเอาไปให้กุนเธอร์แทนฉันทีนะ ฉันไม่ค่อยแน่ใจว่าเราเคยเจอชิ้นนี้หรือยัง [588 589]$14",
  "Core.Mateo.Spring.LateHeart.14": "ไง @! ฉันขุดเจอซากฟอสซิลล่ะ ลองดูสิ ฝากเอาไปให้กุนเธอร์แทนฉันทีนะ ฉันไม่ค่อยแน่ใจว่าเราเคยเจอชิ้นนี้หรือยัง [586 587]$14",
  "Core.Mateo.Spring.LateHeart.15": "ไง @! ฉันไปเจอพ่อค้าที่ทะเลทรายมา - ฉันมีแร่แปลกๆ ที่พวกเขากำลังตามหาอยู่พอดี เราก็เลยทำการแลกเปลี่ยนกันนิดหน่อย นี่เป็นชิ้นงานศึกษาที่ยอดเยี่ยมเลยนะ! [124]$14",
  "Core.Mateo.Spring.LateHeart.16": "บางทีเราสองคนอาจจะไปหาเบียร์ดื่มกันสักหน่อย ถ้านายรู้สึกอยากจะไปน่ะนะ มันดีนะที่จะได้ผ่อนคลายและพักผ่อนจากการทำงานบ้าง ไม่ว่าจะเป็นการผจญภัยหรือทำฟาร์มก็เถอะ$32",
  "Core.Mateo.Spring.LateHeart.17": "ฉันยังไม่ปักใจเชื่อหรอกนะ แต่ก็มีหลักฐานทางมานุษยวิทยาจำนวนมากที่สนับสนุนสมมติฐานที่ว่าก็อบลินและคนแคระเป็นญาติกัน$34#$b#ฉันคิดว่ามันน่าสนใจนะ แต่หลายๆ อย่างมันก็เป็นแค่พยานแวดล้อมน่ะ โดยส่วนตัวแล้ว ฉันเอนเอียงไปทางความคิดที่ว่าพวกเขาเคยอยู่ร่วมกันก่อนสงครามธาตุ มากกว่าที่จะสืบเชื้อสายมาจากบรรพบุรุษคนเดียวกันเป๊ะๆ มากกว่า$36#$b#แต่มันก็เป็นแค่ทฤษฎีน่ะนะ พูดถึงคนแคระ เอ้านี่ @! [122]$35",
  "Core.Mateo.Spring.LateHeart.18": "ฉันจะพยายามทำให้ตัวเองยุ่งๆ เข้าไว้ในวันนี้ - ออกไปข้างนอก ไปคุยกับผู้คน อะไรทำนองนั้นแหละ การเปลี่ยนแปลงก็แค่การสร้างทางเลือกเล็กๆ น้อยๆ ที่แตกต่างออกไปเป็นชุดๆ ดังนั้นถือซะว่าฉันกำลังพยายามก็แล้วกันนะ$1#$b#ขอบใจนะที่คอยอยู่เคียงข้างฉัน @ ฉันคงไม่แม้แต่จะพยายามทำมันด้วยซ้ำถ้าไม่มีนาย$4",
  // SUMMER
  "Core.Mateo.Summer.LateHeart.1": "ไง @ วันหลังเราไปกินไอศกรีมกันไหม? ฉันหมายถึง มันมีร้านรถเข็นอยู่ข้างๆ ห้องสมุดนั่นไง แล้วการใช้เวลายามบ่ายไปกับการกินและอ่านหนังสือมันก็ฟังดูวิเศษสุดๆ ไปเลยสำหรับฉันล่ะนะ$0#$b#ถึงแม้ว่าอาจจะทำพร้อมกันไม่ได้ก็เถอะ - ไม่ขืนมีหวังเราคงโดนคนทั้งเมืองถือคบเพลิงกับคราดไล่ออกจากเมืองแน่ๆ โทษฐานที่ทำหน้าหนังสือเหนียวเหนอะหนะน่ะ$1",
  "Core.Mateo.Summer.LateHeart.2": "ไง @ ฉันมีรอยแผลเป็นเยอะแยะเต็มไปหมด และพอมันเจอความร้อนมันก็คันยุบยิบไปหมดเลยล่ะ คงจะคล้ายๆ กับการใส่เฝือกล่ะมั้ง ฉันเดานะ แผลเป็นพวกนี้บางอันก็เก่ามากแล้ว ฉันก็ไม่แน่ใจเหมือนกันว่าทำไมมันถึงยังรู้สึกแบบนี้อยู่ แต่ฮาร์วีย์บอกว่ามันปกติดีแหละ$16",
  "Core.Mateo.Summer.LateHeart.3": "รู้สึกเหมือนแผลเป็นของฉันมันบวมเต่งเลยแฮะเวลาที่อากาศข้างนอกร้อนขนาดนี้ หรืออาจจะเป็นเพราะฉันคิดไปเองก็ได้นะ ฉันพยายามจะไม่ปล่อยให้มันทำให้ฉันอารมณ์เสีย มันก็แค่อึดอัดมากๆ เท่านั้นแหละ แต่ฉันก็ยอมทนนะ ดีกว่าต้องมาคอยกังวลกับสายตาคนอื่นล่ะนะ$37#$b#ฉันมักจะคิดว่าตัวเองดูเท่แบบดิบๆ เถื่อนๆ มาตลอดนะ แต่ 'มีแผลเป็นตั้งแต่ข้อเท้าจรดหน้าผาก' นี่ไม่ได้อยู่ในลิสต์ที่ฉันคิดไว้เลยจริงๆ$36",
  "Core.Mateo.Summer.LateHeart.4": "ฉันจินตนาการไม่ออกเลยว่าการเข้าไปในภูเขาไฟช่วงเวลานี้ของปีมันจะเป็นยังไง เมื่อเทียบกับสิ่งมีชีวิตแมกม่าต่างๆ และสไลม์เสือ (Tiger Slime) แล้ว ฉันขอเลือกที่จะไปสิงอยู่ตามจุดที่หนาวเย็นกว่าในเหมืองของเมืองเพลิแกนจะดีกว่า$9#$b#ส่วนที่ดีที่สุดของเกาะจินเจอร์ก็แค่การได้ไปนั่งเล่นที่ชายหาดนั่นแหละ มีอาจารย์เก่าของฉันคนนึงทำงานอยู่ที่นั่นด้วยนะ สงสัยจังว่าตอนนี้เขาเป็นยังไงบ้าง$37",
  "Core.Mateo.Summer.LateHeart.5": "สิ่งที่ฉันคิดออกในตอนนี้มีแค่อย่างเดียว คือการปูผ้านอนอาบแดด แล้วฟังเสียงคลื่นกระทบหน้าผาที่อ่าว บางทีอาจจะเล่นจานร่อนหรืออะไรสักอย่าง$0#$b#นายคิดว่าฉันจะชวนมาร์ลอนกับกุนเธอร์มาแจมด้วยได้ไหม? เอาจริงๆ นะ พวกเขาต้องการการพักผ่อนบ้าง พวกเขาทำงานหนักและบ่อยเกินไปแล้ว นายก็เหมือนกันนะ$32",
  "Core.Mateo.Summer.LateHeart.6": "นายรู้ไหมว่าครึ่งท่อนล่างของดั๊กกี้ (Duggy) รูปร่างหน้าตาเป็นยังไง? มันติดอยู่ในหัวฉันมาทั้งวันเลยนะ เท่าที่เรารู้ มันอาจจะมีรูปร่างเหมือนงูก็ได้ แล้วก็ไม่มีใครยอมเสียเวลาดึงมันขึ้นมาจากหลุมเพื่อเช็คดูเลย แล้ววงการวิชาการจะทำยังไงล่ะถ้าไม่มีคนอย่างพวกเราน่ะ @? $1",
  "Core.Mateo.Summer.LateHeart.7": "บางทีเราสองคนอาจจะไปหาเบียร์ดื่มกันสักหน่อย ถ้านายรู้สึกอยากจะไปน่ะนะ มันดีนะที่จะได้ผ่อนคลายและพักผ่อนจากการทำงานบ้าง ไม่ว่าจะเป็นการผจญภัยหรือทำฟาร์มก็เถอะ$32",
  "Core.Mateo.Summer.LateHeart.8": "ฉันอยากไปพิพิธภัณฑ์นะ แต่ฉันคิดว่าบัตรห้องสมุดของฉันมันน่าจะหมดอายุไปสักสิบปีได้แล้วล่ะ ฉันอาจจะต้องบิดแขนกุนเธอร์สักหน่อยเพื่อให้เขายอมออกบัตรใหม่ให้ แต่อย่างน้อยฉันก็ไม่ได้ค้างค่าปรับหนังสือเกินกำหนดหรอกนะ - เรื่องนั้นฉันคงไม่มีทางโน้มน้าวให้เขายกเว้นให้ได้แน่ๆ$8",
  "Core.Mateo.Summer.LateHeart.9": "คุณหมอฮาร์วีย์คอยดูแลเรื่องสุขภาพของฉันเป็นอย่างดีเลยล่ะ ฉันมักจะสะบักสะบอมกลับมาจากเหมืองอยู่บ่อยๆ และทุกอย่างก็ดีขึ้นมากเลยตั้งแต่ฉันเริ่มไปหาเขา$15#$b#ไม่มีอีกแล้วการตื่นขึ้นมาแล้วกลิ้งตกเตียงพร้อมกับเสียงร้องประสานเสียงดังก๊อบแก๊บจากข้อต่อของตัวเองน่ะ$14",
  "Core.Mateo.Summer.LateHeart.10": "ที่หมู่เกาะเฟิร์น เศษแก้วมักจะโผล่มาตามชายหาดบ่อยมากๆ พวกมันเกิดจากกระแสน้ำในมหาสมุทรที่พัดมาขัดเกลาก้อนหินให้เรียบเนียนในช่วงระยะเวลาหนึ่ง พวกมันถูกนำมาทำเป็นเครื่องประดับ และผลลัพธ์ที่ได้ก็มักจะดูคล้ายกับสิ่งที่เราหามาได้และเชื่อว่าเป็นของพวกเอลฟ์$36#$b#มันอาจจะเป็นแค่ความบังเอิญก็ได้ แต่ฉันคิดว่ามันก็สมเหตุสมผลดีนะที่จะสันนิษฐานว่าพวกเอลฟ์เคยอาศัยอยู่ในป่ารวมถึงตามเกาะแก่งต่างๆ ด้วย$32",
  "Core.Mateo.Summer.LateHeart.11": "ฉันยังไม่ปักใจเชื่อหรอกนะ แต่ก็มีหลักฐานทางมานุษยวิทยาจำนวนมากที่สนับสนุนสมมติฐานที่ว่าก็อบลินและคนแคระเป็นญาติกัน$34#$b#ฉันคิดว่ามันน่าสนใจนะ แต่หลายๆ อย่างมันก็เป็นแค่พยานแวดล้อมน่ะ โดยส่วนตัวแล้ว ฉันเอนเอียงไปทางความคิดที่ว่าพวกเขาเคยอยู่ร่วมกันก่อนสงครามธาตุ มากกว่าที่จะสืบเชื้อสายมาจากบรรพบุรุษคนเดียวกันเป๊ะๆ มากกว่า$36#$b#แต่มันก็เป็นแค่ทฤษฎีน่ะนะ พูดถึงคนแคระ เอ้านี่ @! [121]$35",
  "Core.Mateo.Summer.LateHeart.12": "สมัยเรียนมหาลัย เป็นเรื่องปกติมากที่จะทำกุญแจหายระหว่างทางกลับหอพัก หรือลืมทิ้งไว้ที่บาร์ตอนเมาๆ ฉันได้เพื่อนเยอะมากเลยนะเพียงแค่รู้วิธีสะเดาะกุญแจน่ะ$13",
  "Core.Mateo.Summer.LateHeart.13": "ไง @! ฉันไปเจอพ่อค้าที่ทะเลทรายมา - ฉันมีแร่แปลกๆ ที่พวกเขากำลังตามหาอยู่พอดี เราก็เลยทำการแลกเปลี่ยนกันนิดหน่อย นี่เป็นชิ้นงานศึกษาที่ยอดเยี่ยมเลยนะ! [125]$14",
  "Core.Mateo.Summer.LateHeart.14": "ไง @! ฉันเจอของแปลกๆ บนเกาะจินเจอร์น่ะ คิดว่ามันอาจจะมีประโยชน์กับนายไหม? [579 580 581 582 583 584 585]$0",
  "Core.Mateo.Summer.LateHeart.15": "ฉันอยากรู้จริงๆ ว่าหีบสมบัติมันไปอยู่ในบ่อปลาผี (Ghost Fish) ได้ยังไง บ่อน้ำพวกนั้นมนุษย์เป็นคนสร้างขึ้นนะ แล้วพวกมันไปเอามาจากไหนกัน? พวกมันออกไปล่าสมบัติไม่ได้สักหน่อย ปลาไม่มีนิ้วโป้งนะโว้ย$9#$b#ฉันคิดมากไปหรือเปล่าเนี่ย? ฉันอาจจะคิดมากไปจริงๆ นั่นแหละ$9",
  "Core.Mateo.Summer.LateHeart.16": "ไง @ ฉันเจอเจ้านี่ลึกเข้าไปในเหมืองน่ะ มันอาจจะเป็นของใครสักคนที่มาร์ลอนรู้จักก็ได้ แต่ฉันก็ไม่ค่อยแน่ใจหรอก แต่มันดูคุ้นตามากเลยนะ ช่วยเอาไปให้กุนเธอร์อย่างระมัดระวังด้วยล่ะ ตกลงไหม?[109]$8",
  "Core.Mateo.Summer.LateHeart.17": "ฉันใช้เวลาอยู่ที่บ้านมาร์นี่นิดหน่อย แค่ไปช่วยทำงานจิปาถะน่ะ มันเป็นงานที่เลอะเทอะนะ แต่อย่างน้อยมันก็ได้อยู่ข้างนอก และฉันก็ได้ลูบหัวพวกสัตว์เยอะเท่าที่ฉันต้องการเลย ฉันอาจจะลองถามเจคอบ (Jacob) ดูนะว่าเขาต้องการอาสาสมัครด้วยหรือเปล่า$32",
  "Core.Mateo.Summer.LateHeart.18": "ไง @ ฉันเจอเจ้านี่ในทรายลึกลงไปในเหมืองน่ะ - ฝากเอาไปให้กุนเธอร์แทนฉันทีได้ไหม?$0 [108]",
  // FALL
  "Core.Mateo.Fall.LateHeart.1": "ถึงช่วงเวลานี้ของปีอีกแล้วสิ เวลาที่ทุกสิ่งทุกอย่างเริ่มเปลี่ยนแปลง ให้ความเคารพต่อสิ่งรอบตัวนายด้วยนะ @ โดยเฉพาะฤดูกาลนี้ นายไม่มีทางรู้เลยว่าอาจจะมีหรือไม่มีวิญญาณตนไหนกำลังมองข้ามนายไหล่นายอยู่$15",
  "Core.Mateo.Fall.LateHeart.2": "อยากรู้จังว่าทุกคนจะทำอะไรกันบ้างในเทศกาล Spirit's Eve ฤดูกาลนี้ ฉันชินกับช่วงเวลาที่มันเป็นเรื่องใหญ่น่ะ ฉันมั่นใจเลยว่าต้องมีเด็กวัยรุ่นบางคนเตรียมแผนแกล้งคนไว้แน่ๆ... บางทีฉันอาจจะไปโชว์เหนือให้พวกนั้นดูสักหน่อย$36",
  "Core.Mateo.Fall.LateHeart.3": "นายดูหนาวๆ นะ @ อยากยืมเสื้อโค้ทของฉันไหม?$0#$b#ฉันค่อยเอาคืนตอนที่เราออกมาแฮงเอาท์กันครั้งหน้าก็ได้ ไม่ใช่เรื่องใหญ่อะไรหรอก นายต้องดูแลตัวเองนะ มีคนอีกตั้งหลายคนที่ต้องพึ่งพานายกับฟาร์มของนายน่ะ$32",
  "Core.Mateo.Fall.LateHeart.4": "ฉันรู้สึกเหมือนว่าสิ่งที่ฉันอยากทำในฤดูใบไม้ร่วงมีแค่เรื่องกินอย่างเดียวเลย ถ้าฉันไม่ได้ใช้เวลาส่วนใหญ่ตอนตื่นไปกับการกวัดแกว่งดาบไปมาล่ะก็ ป่านนี้ตัวฉันคงกลมเป็นฟักทองไปแล้วล่ะ$8",
  "Core.Mateo.Fall.LateHeart.5": "ฉันชอบเดินผ่านภูเขาช่วงเวลานี้ของปีนะ มันสวยมาก และมีบางอย่างแตกต่างออกไปทุกครั้งที่นายเดินผ่าน เหมืองน่ะไม่เคยเปลี่ยนเลย มันเลยทำให้รู้สึกเหมือนถูกขังอยู่ข้างล่างนั่นได้ง่ายมาก ถ้านายไม่รู้จักขึ้นมาสูดอากาศข้างบนบ้างเป็นครั้งคราวน่ะ$12#$b#ฉันกลายเป็นคนอ่อนไหวง่าย แล้วก็ถูกดึงออกจากกิจวัตรประจำวันเดิมๆ ไม่ได้จะบอกว่าฉันอู้งานหรอกนะ แต่ฤดูใบไม้ร่วงนี่ฉันไม่ได้ใช้เวลาในเหมืองเยอะเหมือนปกติหรอก$32",
  "Core.Mateo.Fall.LateHeart.6": "ฉันไม่รู้ว่านายรู้สึกยังไงนะ @ แต่ฉันรู้สึกพอใจกับชีวิตมากขึ้นเยอะเลยในฤดูใบไม้ร่วง บางทีอาจจะเป็นเพราะบรรยากาศ หรือบางทีอาจจะเป็นเพราะอาหารอร่อยๆ กับงานเทศกาลพวกนี้ก็ได้$32",
  "Core.Mateo.Fall.LateHeart.7": "ฉันเจอเจ้านี่สำหรับพิพิธภัณฑ์น่ะ @ ขอบใจนะที่รับฝากไปส่งต่อ! ช่วงนี้ฉันพยายามจะใช้เวลาในเหมืองให้น้อยลงน่ะ เพราะอากาศข้างนอกมันดีมากๆ เลย[104 105 106 113 115 116]$14",
  "Core.Mateo.Fall.LateHeart.8": "ภูเขาช่วงเวลานี้ของปีสวยมากๆ เลยนะ มันยากมากเลยที่จะหาเหตุผลให้ตัวเองต้องลงไปขลุกอยู่ในเหมืองเยอะๆ ในเมื่อสิ่งที่ฉันอยากทำทั้งหมดก็แค่การได้นอนเล่นบนผืนหญ้าข้างนอก...$4",
  "Core.Mateo.Fall.LateHeart.9": "ฉันรู้ว่ามันดูน้ำเน่ามากนะ แต่ฤดูกาลที่หมู่เกาะเฟิร์นมันไม่ได้เปลี่ยนแปลงให้เห็นชัดเจนขนาดนี้น่ะ ฉันเลยชอบมากๆ เวลาที่ใบไม้เปลี่ยนสี มันช่วยเตือนใจได้ดีเลยล่ะว่าเวลายังคงเดินต่อไปจริงๆ$4",
  "Core.Mateo.Fall.LateHeart.10": "การได้แต่งตัวมิดชิดด้วยเสื้อโค้ทแฟชั่น เป็นหนึ่งในสิ่งที่ฉันชอบที่สุดในฤดูใบไม้ร่วงเลยล่ะ และเป็นสิ่งเดียวที่ฉันชอบเกี่ยวกับฤดูหนาวด้วย$10#$b#ฉันไม่ใช่พวกนำแฟชั่นอะไรหรอกนะ แต่ก็พยายามแต่งตัวให้ดูดีที่สุดเท่าที่จะทำได้นั่นแหละ มันแค่ไม่ได้เกิดขึ้นบ่อยๆ ก็เท่านั้น - จะให้ฉันแต่งตัวหล่อๆ ไปให้ใครดูเล่า พวกมอนสเตอร์ในถ้ำงั้นเหรอ?$11",
  "Core.Mateo.Fall.LateHeart.11": "พวกเราใช้ฟักทองกันที่สาธารณรัฐเฟิร์นกิลล์นี่ แต่พวกพืชกินรากหลายๆ ชนิดก็สามารถเอามาแกะสลักเป็นตะเกียงฟักทอง (Jack o' Lantern) ได้เหมือนกันนะ อะไรก็ตามที่มีหน้าตา ก็สามารถขับไล่วิญญาณร้ายได้ทั้งนั้นแหละ!$1#$b#ถ้านายไม่มีผักล่ะก็ เอาน้ำสักถังมาใช้แก้ขัดไปก่อนก็ได้นะ$36",
  "Core.Mateo.Fall.LateHeart.12": "เอาจริงๆ นะ ฉันว่าฉันยอมแลกแขนแลกขาเพื่อให้ได้กินเมล็ดฟักทองคั่วแบบโฮมเมดเลยล่ะ เอาไปคลุกกับเครื่องเทศนะ แล้วนายก็จะได้ของว่างประจำฤดูกาลที่ยอดเยี่ยมที่สุดไปเลย$32#$b#ถึงฉันจะชอบพวกแยม เยลลี่ แล้วก็ไวน์มากแค่ไหน - แต่เมล็ดฟักทองนี่แหละชนะใจฉันสุดๆ$1",
  "Core.Mateo.Fall.LateHeart.13": "ไง @ เอาไข่ไก่หรือไข่เป็ดไปถูตามกรอบประตูบ้านไร่ของนายดูสิ เขาว่ากันว่ามันจะช่วยเสริมความโชคดีในช่วงเวลานี้ของปีน่ะ$1#$b#บางทีมันอาจจะช่วยไล่พวกมอนสเตอร์ได้ด้วยนะ ถ้านายมีปัญหาเรื่องพวกมันชอบมาเดินเตร่ในฟาร์มตอนกลางคืนน่ะ$32",
  "Core.Mateo.Fall.LateHeart.14": "มีหมอนั่นคนนึงในเมืองซูซู (ZuZu City) ชอบเล่นพิเรนทร์กับลูกอมในเทศกาล Spirit's Eve แล้วตอนนี้มันก็เลยกลายเป็นกฎที่รู้กันเองว่าต้องเช็คของทุกอย่างก่อนจะกิน...$11#$b#ฉันไม่ได้อยากจะมองคนในแง่ร้ายหรอกนะ แต่มันเป็นเรื่องเล่าที่ฉันโดนกรอกหูมาบ่อยมากตอนเด็กๆ จนตอนนี้โตแล้วก็ยังติดนิสัยต้องเช็คขนมอยู่เลย$16",
  "Core.Mateo.Fall.LateHeart.15": "กัสทำขนมหวานช่วงเวลานี้ของปีได้ยอดเยี่ยมมากเลยล่ะ พายแอปเปิ้ล พายพีแคน แล้วก็ไอศกรีมโฮมเมดที่กินคู่กันนะ...#$b#จริงๆ แล้วเขาเคยอบพายฟักทองให้ฉันทั้งถาดเลยนะ ตอนที่ฉันเริ่มเข้ามาในเมืองบ่อยขึ้นน่ะ ฉันปลื้มใจสุดๆ ไปเลย$1",
  "Core.Mateo.Fall.LateHeart.16": "นายจะเอาอะไรมาร่วมงานฉลอง Spirit's Eve ไหม @? ฉันไม่รู้หรอกนะว่าเขาทำกันไหมในหุบเขานี้ แต่ในพื้นที่ที่มีคนอยู่หนาแน่นกว่านี้ การแจกขนมถือเป็นส่วนสำคัญมากของงานเทศกาลนี้เลยล่ะ$32",
  "Core.Mateo.Fall.LateHeart.17": "อย่าเป่าตะเกียงฟักทองให้ดับก่อนเที่ยงคืนนะ @ มันมีไว้ไล่พวกสิ่งมีชีวิตแห่งรัตติกาลน่ะ ฉันคิดว่าตำนานนั้นมันมีที่มาย้อนไปตั้งแต่สมัยที่เรายังต้องต่อกรกับพวกมอนสเตอร์บนพื้นดินบ่อยกว่านี้ล่ะมั้ง$35#$b#มันเคยเป็นวิธีปฏิบัติเพื่อไล่พวกมันไป เพราะโดยธรรมชาติแล้วพวกเรามักจะกลัวสิ่งที่ไม่รู้จักน่ะ$36",
  "Core.Mateo.Fall.LateHeart.18": "ฉันไม่คิดว่าจะมีใครแก่เกินไปสำหรับเทศกาล Spirit's Eve หรอกนะ มันเป็นช่วงเวลาเดียวของปีที่นายสามารถแสดงความเป็นตัวเองผ่านชุดคอสตูมได้ และฉันคิดว่ามันดีต่อจิตใจนะ$1#$b#มันเป็นประเพณีที่มีอยู่ในรูปแบบใดรูปแบบหนึ่งมาเป็นพันกว่าปีแล้วนะ ข้ามผ่านวัฒนธรรมต่างๆ มากมาย ฉันสามารถพล่ามเรื่องนี้ได้เป็นวันๆ เลยล่ะ$32",
  // WINTER
  "Core.Mateo.Winter.LateHeart.1": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#ฤดูหนาวนี้ถ้านายไปใช้เวลาอยู่ในเหมืองล่ะก็ ระวังพวกพลซุ่มยิงเงา (Shadow Sniper) ให้ดีล่ะ ฉันก็ไม่รู้เหมือนกันว่าพวก Shadow Brute ไปเอาหน้าไม้มาจากไหน แต่ฉันเพิ่งโดนยิงเข้าที่สะโพกมา มันแย่สุดๆ ไปเลยล่ะ$37#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|อาจจะเป็นเพราะฉันใช้เวลาไปกับการขุดค้น หรือไม่ก็อยู่ในสภาพอากาศที่อบอุ่นเป็นพิเศษมาตลอด สภาพอากาศหนาวจัดแบบนี้มันเลยทำให้ฉันรู้สึกแย่มากๆ$8#$b#ช่วงเวลานี้ของปีที่อ่าวมันเหงามากเลยด้วย เหงากว่าปกติอีก มันค่อนข้างจะรับมือยากนิดหน่อยน่ะ ขอบใจนะที่ยังคอยอยู่ข้างๆ$0",
  "Core.Mateo.Winter.LateHeart.2": "ฤดูหนาวนี้ถ้านายไปใช้เวลาอยู่ในเหมืองล่ะก็ ระวังพวกพลซุ่มยิงเงา (Shadow Sniper) ให้ดีล่ะ ฉันก็ไม่รู้เหมือนกันว่าพวก Shadow Brute ไปเอาหน้าไม้มาจากไหน แต่ฉันเพิ่งโดนยิงเข้าที่สะโพกมา มันแย่สุดๆ ไปเลยล่ะ$37",
  "Core.Mateo.Winter.LateHeart.3": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#พวกใบมีดโลหะมักจะไม่เปราะบางจากความหนาวหรอกนะ แค่ต้องระวังวิธีเก็บรักษาอุปกรณ์ที่นายไม่ได้ใช้ในช่วงฤดูหนาวก็พอ$7#$b#ไม่มีอะไรจะแย่ไปกว่าการมีอะไรพังในช่วงที่มันวุ่นวายเกินกว่าจะซ่อมได้อีกแล้วล่ะ$10#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ฤดูหนาวมักจะกวนใจฉันเพราะมันดูอ้างว้างเหลือเกิน มันไม่มีสีสัน ทุกคนก็ดูจะอ่อนล้าทางอารมณ์ได้ง่ายขึ้น - ฉันไม่รู้สิ มันทำให้ฉันรู้สึกกระวนกระวายน่ะ$16#$b#การขลุกอยู่ในเหมืองตลอดเวลาอาจจะ... ไม่ได้ช่วยอะไรเรื่องนี้เลย อย่าหลงกลติดกับดักนี้นะ @ ทำใจให้ยุ่งเข้าไว้ แต่อย่าลืมดูแลร่างกายด้วยล่ะ นายมีอย่างละหนึ่งเดียวเท่านั้นนะ$8",
  "Core.Mateo.Winter.LateHeart.4": "พวกใบมีดโลหะมักจะไม่เปราะบางจากความหนาวหรอกนะ แค่ต้องระวังวิธีเก็บรักษาอุปกรณ์ที่นายไม่ได้ใช้ในช่วงฤดูหนาวก็พอ$7#$b#ไม่มีอะไรจะแย่ไปกว่าการมีอะไรพังในช่วงที่มันวุ่นวายเกินกว่าจะซ่อมได้อีกแล้วล่ะ$10",
  "Core.Mateo.Winter.LateHeart.5": "ครั้งสุดท้ายที่นายไปตรวจสุขภาพประจำปีกับคุณหมอคือเมื่อไหร่เนี่ย @? นายจะมาคอยเช็คฉันอยู่ฝ่ายเดียวโดยไม่คิดว่าฉันจะทำแบบเดียวกันกับนายไม่ได้หรอกนะ$37#$b#ดื่มน้ำเยอะๆ แต่งตัวให้อุ่น กินให้อิ่ม และอย่าทำร้ายตัวเองด้วยการฝืนทำงานในเหมืองนะ ฉันรู้ว่าตอนนี้นายน่าจะใช้เวลาอยู่ข้างล่างนั่นเยอะ เพราะนายไม่มีพืชผลให้ดูแล ฉันเข้าใจนะ แต่ก็ดูแลตัวเองด้วยล่ะ ตกลงไหม?$16",
  "Core.Mateo.Winter.LateHeart.6": "สิ่งที่ฉันอยากทำในวันนี้มีแค่นอนกลิ้งไปมาแล้วก็อ่านหนังสือแท้ๆ แต่สุดท้ายเราก็มาอยู่ตรงนี้ ในวันที่น่าเบื่ออีกวัน ทุกอย่างมันจะดีขึ้นเองแหละ แค่ต้องรอให้มันผ่านไปแล้วหาอะไรทำเพื่อไม่ให้ฟุ้งซ่านเท่านั้นแหละ$8",
  "Core.Mateo.Winter.LateHeart.7": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#ครั้งสุดท้ายที่นายไปตรวจสุขภาพประจำปีกับคุณหมอคือเมื่อไหร่เนี่ย @? นายจะมาคอยเช็คฉันอยู่ฝ่ายเดียวโดยไม่คิดว่าฉันจะทำแบบเดียวกันกับนายไม่ได้หรอกนะ$37#$b#ดื่มน้ำเยอะๆ แต่งตัวให้อุ่น กินให้อิ่ม และอย่าทำร้ายตัวเองด้วยการฝืนทำงานในเหมืองนะ ฉันรู้ว่าตอนนี้นายน่าจะใช้เวลาอยู่ข้างล่างนั่นเยอะ เพราะนายไม่มีพืชผลให้ดูแล ฉันเข้าใจนะ แต่ก็ดูแลตัวเองด้วยล่ะ ตกลงไหม?$16#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ไง @ โทษทีนะ รู้สึกเหมือนว่าอาทิตย์นี้ความหนาวมันเริ่มจะเล่นงานฉันซะแล้ว การลุกจากเตียงเมื่อเช้านี้มันเป็นความท้าทายที่ฉันยังไม่พร้อมรับมือเลย แต่ก็นะ นายก็แค่ต้องฝืนทนผ่านมันไปให้ได้ใช่ไหมล่ะ? บางวันมันก็ออกมาดีกว่าวันอื่น นั่นแหละปกติ$10",
  "Core.Mateo.Winter.LateHeart.8": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#สิ่งที่ฉันอยากทำในวันนี้มีแค่นอนกลิ้งไปมาแล้วก็อ่านหนังสือแท้ๆ แต่สุดท้ายเราก็มาอยู่ตรงนี้ ในวันที่น่าเบื่ออีกวัน ทุกอย่างมันจะดีขึ้นเองแหละ แค่ต้องรอให้มันผ่านไปแล้วหาอะไรทำเพื่อไม่ให้ฟุ้งซ่านเท่านั้นแหละ$8#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ขอบใจนะที่ยังอยู่ตรงนี้และคอยแวะมาดูฉันนะ @ ฉันรู้ว่าตัวเองอาจจะเข้าถึงยากขึ้นนิดหน่อยเวลาที่อากาศหนาวๆ แต่ฉันซาบซึ้งใจจริงๆ ที่นายพยายามดึงฉันไว้กับความจริง ฉันติดหนี้เลี้ยงมื้อค่ำนายสักมื้อในเร็วๆ นี้นะ ตกลงไหม? ตอนที่ฉันอารมณ์ไม่บูดเท่านี้แล้วน่ะ$21",
  "Core.Mateo.Winter.LateHeart.9": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#อากาศแบบนี้นะ พวกเยลลี่น้ำแข็ง (Frost Jelly) คงอยู่รอดบนพื้นดินได้สบายๆ แล้วก็ออกมาป่วนไปทั่วแน่ๆ เอาจริงๆ ฉันก็ชอบไอ้พวกตัวเล็กๆ นี่นะ แต่มันรับมือยากเวลาที่นายกำลังพยายามสำรวจแล้วพวกมันก็พยายามทุกวิถีทางเพื่อดึงให้นายช้าลงน่ะ$8#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ไง @ ยังยุ่งอยู่หรือเปล่า? ฉันรู้สึกเหมือนกำลังจะเป็นบ้าเลยล่ะ อารมณ์ฉันมักจะบูดสุดๆ เวลาที่ทุกอย่างกลายเป็นน้ำแข็งแบบนี้น่ะ$17#$b#เราน่าจะออกไปแฮงเอาต์กันเร็วๆ นี้นะ การมีนายอยู่ด้วยทำให้ฉันอารมณ์ดีขึ้นเสมอเลย ขอบใจนะที่แวะมาดู - ร่าเริงเข้าไว้ล่ะ ตกลงไหม?$0",
  "Core.Mateo.Winter.LateHeart.10": "อากาศแบบนี้นะ พวกเยลลี่น้ำแข็ง (Frost Jelly) คงอยู่รอดบนพื้นดินได้สบายๆ แล้วก็ออกมาป่วนไปทั่วแน่ๆ เอาจริงๆ ฉันก็ชอบไอ้พวกตัวเล็กๆ นี่นะ แต่มันรับมือยากเวลาที่นายกำลังพยายามสำรวจแล้วพวกมันก็พยายามทุกวิถีทางเพื่อดึงให้นายช้าลงน่ะ$8",
  "Core.Mateo.Winter.LateHeart.11": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#หนึ่งในสายพันธุ์ที่เรารู้จักน้อยซะยิ่งกว่าเอลฟ์ก็คือพวกภูต (Fae) - เงือก, นางฟ้า - อะไรพวกนั้น ฉันมักจะคิดว่าพวกนี้มีแนวโน้มที่จะโผล่มาให้เห็นในช่วงเวลานี้ของปีนะ$35#$b#สาบานได้เลยว่าฉันเพิ่งเห็นสัตว์ทะเลแถวๆ อ่าวเมื่อไม่นานมานี้เอง แต่อาจจะแค่ตาฝาดไปก็ได้นะ$34#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ไง @ ขอบใจนะที่คอยแวะมาดูฉันตลอดเลย ฉันซาบซึ้งใจมากเลยนะ และฉันหวังว่านายจะทำตัวให้ยุ่งๆ เข้าไว้นะ ฉันก็กำลังพยายามอยู่ แต่ก็นะ บางวันมันก็ยากกว่าวันอื่นน่ะ$16#$b#อย่าลืมทักมาล่ะถ้านายรู้สึกไม่ค่อยโอเค ตกลงไหม? มีคนตั้งหลายคนในเมืองนี้ที่เป็นห่วงนายนะ รวมถึงฉันด้วย$0",
  "Core.Mateo.Winter.LateHeart.12": "หนึ่งในสายพันธุ์ที่เรารู้จักน้อยซะยิ่งกว่าเอลฟ์ก็คือพวกภูต (Fae) - เงือก, นางฟ้า - อะไรพวกนั้น ฉันมักจะคิดว่าพวกนี้มีแนวโน้มที่จะโผล่มาให้เห็นในช่วงเวลานี้ของปีนะ$35#$b#สาบานได้เลยว่าฉันเพิ่งเห็นสัตว์ทะเลแถวๆ อ่าวเมื่อไม่นานมานี้เอง แต่อาจจะแค่ตาฝาดไปก็ได้นะ$34",
  "Core.Mateo.Winter.LateHeart.13": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#ช่วงนี้ฉันอ่านหนังสือดีๆ ไปเยอะมากเลย ตอนนี้ฉันกลับมาใช้เวลาในห้องสมุดเยอะขึ้นแล้วน่ะ ถ้ามีเวลาฉันก็พอจะแนะนำหนังสือให้นายได้นะ$0#$b#นายชอบอ่านแนวไหนล่ะ @? แอคชั่น, ไซไฟ, หรือผจญภัย?$1#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ช่วงเวลานี้ของปีฉันไปหาคุณหมอฮาร์วีย์บ่อยขึ้นเยอะเลย ไม่ใช่แค่เพราะบาดเจ็บหรอกนะ แต่... เพื่อรับมือกับอาการซึมเศร้าตามฤดูกาลน่ะ$8#$b#ขอบใจนะที่ยังใจเย็นกับฉัน ฉันรู้ว่ามันรับมือไม่ง่ายหรอก แต่ฉันซาบซึ้งใจนะที่นายอยู่เคียงข้างฉันมานานขนาดนี้$21",
  "Core.Mateo.Winter.LateHeart.14": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#ฉันอยากไปพิพิธภัณฑ์นะ แต่ฉันคิดว่าบัตรห้องสมุดของฉันมันน่าจะหมดอายุไปสักสิบปีได้แล้วล่ะ ฉันอาจจะต้องบิดแขนกุนเธอร์สักหน่อยเพื่อให้เขายอมออกบัตรใหม่ให้ แต่อย่างน้อยฉันก็ไม่ได้ค้างค่าปรับหนังสือเกินกำหนดหรอกนะ - เรื่องนั้นฉันคงไม่มีทางโน้มน้าวให้เขายกเว้นให้ได้แน่ๆ$8#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|ฉันกำลังพยายามซึมซับความสวยงามของฤดูหนาวให้เหมือนกับที่ฉันทำในฤดูใบไม้ร่วงนะ แต่มันไม่ได้ผลเลย แต่ฉันก็ยังพยายามจะมองหาความงามในความหดหู่ให้ได้นะ$8#$b#ขอโทษด้วยนะถ้าฉันดูหงุดหงิดไปบ้าง ฉันไม่ได้ตั้งใจจะทำเย็นชาใส่นายหรอกนะ$16",
  "Core.Mateo.Winter.LateHeart.15": "ช่วงนี้ฉันอ่านหนังสือดีๆ ไปเยอะมากเลย ตอนนี้ฉันกลับมาใช้เวลาในห้องสมุดเยอะขึ้นแล้วน่ะ ถ้ามีเวลาฉันก็พอจะแนะนำหนังสือให้นายได้นะ$0#$b#นายชอบอ่านแนวไหนล่ะ @? แอคชั่น, ไซไฟ, หรือผจญภัย?$1",
  "Core.Mateo.Winter.LateHeart.16": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#สมัยเรียนมหาลัย เป็นเรื่องปกติมากที่จะทำกุญแจหายระหว่างทางกลับหอพัก หรือลืมทิ้งไว้ที่บาร์ตอนเมาๆ ฉันได้เพื่อนเยอะมากเลยนะเพียงแค่รู้วิธีสะเดาะกุญแจน่ะ$13#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|กลายเป็นว่าคุณหมอฮาร์วีย์คิดว่าฉันขาดวิตามินดีล่ะ เพราะฉันใช้เวลาอยู่ในเหมืองเยอะเกินไปแล้วก็ไม่ได้โดนแดดเพียงพอน่ะ มันยิ่งแย่ลงไปอีกในฤดูหนาวเพราะแสงแดดธรรมชาติน้อยกว่าปกติอยู่แล้ว$16#$b#มันทำให้ฉันอารมณ์บูดง่ายมาก เขาเลยแนะนำอาหารเสริมให้ แล้วก็ให้ออกไปข้างนอกแล้วก็พบปะผู้คนให้มากขึ้น... ฉันคิดว่าตอนนี้น่าจะรับมือได้แล้วล่ะ$4",
  "Core.Mateo.Winter.LateHeart.16.Filtered": "$query PLAYER_HEARTS Current Mateo 10, PLAYER_HAS_MAIL Current Mateo_SpecialOrders_BuildGuildMail Any#สมัยเรียนมหาลัย เป็นเรื่องปกติมากที่จะทำกุญแจหายระหว่างทางกลับหอพัก หรือลืมทิ้งไว้ที่บาร์ตอนเมาๆ ฉันได้เพื่อนเยอะมากเลยนะเพียงแค่รู้วิธีสะเดาะกุญแจน่ะ$13#$action AddMail Current SnS_M_Mateo_OverrideSeenToday received|กลายเป็นว่าคุณหมอฮาร์วีย์คิดว่าฉันขาดวิตามินดีล่ะ เพราะฉันใช้เวลาอยู่ในเหมืองเยอะเกินไปแล้วก็ไม่ได้โดนแดดเพียงพอน่ะ มันยิ่งแย่ลงไปอีกในฤดูหนาวเพราะแสงแดดธรรมชาติน้อยกว่าปกติอยู่แล้ว$16#$b#มันทำให้ฉันอารมณ์แย่ง่ายมาก เขาเลยแนะนำอาหารเสริมให้ แล้วก็ให้ออกไปข้างนอกแล้วก็พบปะผู้คนให้มากขึ้น... ฉันคิดว่าตอนนี้น่าจะรับมือได้แล้วล่ะ$4",
  "Core.Mateo.Winter.LateHeart.17": "ฉันอยากไปพิพิธภัณฑ์นะ แต่ฉันคิดว่าบัตรห้องสมุดของฉันมันน่าจะหมดอายุไปสักสิบปีได้แล้วล่ะ ฉันอาจจะต้องบิดแขนกุนเธอร์สักหน่อยเพื่อให้เขายอมออกบัตรใหม่ให้ แต่อย่างน้อยฉันก็ไม่ได้ค้างค่าปรับหนังสือเกินกำหนดหรอกนะ - เรื่องนั้นฉันคงไม่มีทางโน้มน้าวให้เขายกเว้นให้ได้แน่ๆ$8",
  "Core.Mateo.Winter.LateHeart.18": "สมัยเรียนมหาลัย เป็นเรื่องปกติมากที่จะทำกุญแจหายระหว่างทางกลับหอพัก หรือลืมทิ้งไว้ที่บาร์ตอนเมาๆ ฉันได้เพื่อนเยอะมากเลยนะเพียงแค่รู้วิธีสะเดาะกุญแจน่ะ$13",
  // 10 HEARTS PLATONIC - SPRING 
  "Core.Mateo.Spring.Relationship.Platonic.1": "ห้องสมุดจิ๋วในกิลด์นี่เป็นสิ่งที่ฉันฝันอยากจะมีมาตั้งแต่เด็กเลยนะ เหมือนในหนังเลยล่ะ$80#$b#คือมันก็เป็นหนังสือเรียน, นิยาย, แล้วก็คู่มือบอร์ดเกมรวมๆ กันนั่นแหละ แต่หนังสือก็คือหนังสือนี่นะ ไม่สำคัญหรอกว่าจะอ่านอะไร ขอแค่นายสนุกกับมันก็พอแล้วล่ะ$32",
  "Core.Mateo.Spring.Relationship.Platonic.2": "เอเมริทัสชอบคาบถุงเท้าฉันไปฝังทรายข้างนอกประจำเลย แถมตอนกลางคืนยังชอบหนีออกจากคอกมานอนที่ปลายเตียงฉันอีกนะ$9#$b#น้ำหนักปาเข้าไปร้อยกว่าโลแต่คิดว่าตัวเองหนักแค่กระติ๊ดเดียว ไม่ใช่ว่าฉันจะรังเกียจที่จะมีไดโนเสาร์ขี้อ้อนไว้กอดหรอกนะ$76",
  "Core.Mateo.Spring.Relationship.Platonic.3": "วันก่อนฉันลงดันเจี้ยนภูเขาไฟน่ะ แล้วก็เจอเจ้านี่ตอนสำรวจพื้นที่ บางทีนายอาจจะหาวิธีใช้ประโยชน์จากมันได้นะ? [820 821 822 823 824]$14",
  "Core.Mateo.Spring.Relationship.Platonic.4": "มันมีข้อความที่แปลกยากมากๆ อยู่บนกำแพงของถ้ำกะโหลกด้วยนะ นายเคยสังเกตไหม @?$34#$b#เกี่ยวกับพวกฮีโร่อะไรสักอย่าง บางทีเราอาจจะลองไปด้วยกันแล้วไปดูกัน ฉันมั่นใจว่าน่าจะมีเรื่องน่าสนใจให้ค้นพบที่นั่นแน่ๆ$32",
  "Core.Mateo.Spring.Relationship.Platonic.5": "ฉันไม่ค่อยได้ตกแต่งอะไรเท่าไหร่หรอกในฤดูใบไม้ผลิกับฤดูร้อน แต่ฉันเตรียมตัวพร้อมมากเวลาฤดูใบไม้ร่วงมาเยือน โดยเฉพาะอย่างยิ่งตอนที่ฉันไม่ต้อง 'ยืม' ไฟเพื่อนบ้านใช้แล้วเนี่ย$13",
  "Core.Mateo.Spring.Relationship.Platonic.6": "@! คนที่ฉันอยากเจอพอดีเลย นี่ ฉันให้กัสทำเจ้านี่มาให้นายล่ะ [205 207 231 236 237 238 239 243]$1#$b#ปลอดภัยไว้ก่อนนะเวลาลงดันเจี้ยนน่ะ ดูแลเรื่องน้ำกับอาหารให้ดีๆ ด้วยล่ะ$78",
  "Core.Mateo.Spring.Relationship.Platonic.7": "ฉันกำลังจะจัดบอร์ดเกม (Tabletop) ที่กิลด์ให้พวกเด็กเนิร์ดในเมืองเล่นกันน่ะ ถ้านายว่าง เราก็มาสร้างตัวละครให้นายกันได้นะ$1#$b#นายอยากเล่นตัวละครแบบไหนล่ะ @? นายเป็นคนจิตใจดีนะ คงจะเป็นพาลาดินที่เก่งกาจได้แน่ๆ$76",
  // 10 HEARTS PLATONIC - SUMMER
  "Core.Mateo.Summer.Relationship.Platonic.1": "เอเมริทัสมักจะขี้เกียจเป็นพิเศษเลยเวลาอากาศร้อนน่ะ ปกติถ้าแดดออก มันจะชอบเดินเตาะแตะไปตามชายหาดเพื่อหาปูกิน$13#$b#แต่พออากาศร้อนอบอ้าวแบบนี้ มันจะนอนแหมะบนพื้นไม้แทน สงสัยจะเย็นกว่าล่ะมั้ง มันเป็นแค่หมาร่างยักษ์ในคราบไดโนเสาร์ชัดๆ$32",
  "Core.Mateo.Summer.Relationship.Platonic.2": "ฉันไปค้นคว้าเรื่องพวกเผ่าเงา (Shadow Folk) มาน่ะ ยิ่งอ่านก็ยิ่งรู้สึกว่าข้อมูลที่เรามีมันไม่ถูกต้องเลย$34#$b#หลายๆ เรื่องดูเหมือนจะเขียนขึ้นจากมุมมองที่เต็มไปด้วยความหวาดกลัวมากกว่ามุมมองทางวิชาการนะ ซึ่งฉันก็พอเข้าใจแหละ แต่มันไม่ได้ทำให้ข้อมูลนั้นถูกต้อง แม่นยำ หรือยุติธรรมเลยนะ$37",
  "Core.Mateo.Summer.Relationship.Platonic.3": "ฤดูร้อนในหุบเขานี้ไม่เหมือนฤดูร้อนที่พอร์ตออฟเพลนตี้ (Port of Plenty) เลย ขอบคุณพระเจ้า ที่หมู่เกาะนั่นพออากาศร้อนจัด มันก็จะชื้นมากๆ ด้วย - จนรู้สึกเหมือนกำลังเดินแหวกซุปอยู่เลยล่ะ$9#$b#เอาจริงๆ ฉันเกลียดมันเลยล่ะ พวกเราอยู่ติดทะเล ฉันก็เลยนึกว่าอากาศมันจะแย่พอๆ กัน แต่บางทีอาจจะเป็นเพราะมีภูเขาอยู่ใกล้ๆ ก็ได้นะ$0",
  "Core.Mateo.Summer.Relationship.Platonic.4": "ฉันไม่เคยเห็นฟอสซิลงูรูปร่างแบบนี้มาก่อนเลยนะ @ นายพอจะรู้จักใครที่รู้เรื่องนี้เยอะกว่านี้บ้างไหม? [825 826]$14",
  "Core.Mateo.Summer.Relationship.Platonic.5": "เมื่อคืนฉันปีนผ่านช่องหลังคาขึ้นไปบนกิลด์แล้วก็นั่งดูพระอาทิตย์ตกน่ะ ในมือถือเบียร์ แล้วก็นั่งฟังเสียงคลื่นกระทบฝั่ง$1#$b#มันยอดเยี่ยมมากเลยนะ หุบเขานี้มันมีอะไรที่พิเศษมากๆ เลย @$78",
  "Core.Mateo.Summer.Relationship.Platonic.6": "ฉันโดนพวกมังกรบิน (Serpent) ในถ้ำกะโหลกกัดมาล่ะ ไอ้พวกนี้ดุร้ายชะมัดเลยเนอะ ว่าไหม?$22#$b#ฉันยอมรับมือกับฝูงโครงกระดูกเป็นร้อยยังจะดีกว่าอีก เอ้านี่ เผื่อนายจะเจอเรื่องแบบเดียวกันนะ [349]$10",
  "Core.Mateo.Summer.Relationship.Platonic.7": "การเป็นนักผจญภัยมา 20 กว่าปีมันทิ้งรอยแผลเป็นไว้เยอะเลยล่ะ ตอนแรกฉันก็เคยกังวลกับสายตาคนอื่นนะ แต่ตอนนี้มันกลายเป็นความภาคภูมิใจไปแล้วล่ะ$35#$b#แม้แต่แผลใหม่ๆ ก็ด้วย การบาดเจ็บต่อเนื่องครั้งนั้นมันผลักดันให้ฉันเดินบนเส้นทางที่ฉันไม่เคยคาดคิดมาก่อนเลย$76",
  // 10 HEARTS PLATONIC - FALL
  "Core.Mateo.Fall.Relationship.Platonic.1": "ฉันมีรายชื่อหนังที่ชอบดูช่วงเวลานี้ของปีอยู่ด้วยนะ ฉันชอบหนังแนวไล่เชือดสนุกๆ แต่หนังมอนสเตอร์คือที่สุดแล้วล่ะ ส่วนหนึ่งที่ทำให้ฤดูกาลนี้พิเศษก็คือความรู้สึกกลัวแบบปลอมๆ นี่แหละ$13",
  "Core.Mateo.Fall.Relationship.Platonic.2": "ตอนนี้ฉันมีประตูบ้านให้เคาะแล้ว ฉันหวังว่าพวกเด็กๆ จะแวะมาเอาขนมนะ แต่ก็แอบกังวลนิดหน่อยว่าชุดคอสตูมฉันมันจะน่ากลัวเกินไปสำหรับเด็กๆ น่ะสิ บางทีฉันอาจจะให้เอเมริทัสคาบถังลูกอมไว้ให้แทนก็ได้นะ$13",
  "Core.Mateo.Fall.Relationship.Platonic.3": "@! ฉันขุดเจอซากสิ่งมีชีวิตมัมมี่พวกนี้ที่เกาะจินเจอร์น่ะ ถ้าฉันไม่รู้ว่ามันคืออะไร ป่านนี้ฉันคงเอามันมาประดับตกแต่งงาน Spirit's Eve ไปแล้วล่ะ น่าขนลุกดี [827 828]$14",
  "Core.Mateo.Fall.Relationship.Platonic.4": "นายชอบปลูกอะไรเป็นพิเศษเหรอ @? นายเน้นปลูกของที่ทำกำไรเยอะๆ หรือว่านายมีแพลนจะเอาไปแปรรูปต่อเป็นสินค้าช่างฝีมือล่ะ?$35#$b#ทั้งดอกทานตะวัน แครนเบอร์รี่ และฟักทอง พอเอามาปลูกรวมๆ กันในไร่ของนายแล้วคงจะดูสวยงามมากแน่ๆ เลย$32",
  "Core.Mateo.Fall.Relationship.Platonic.5": "ชีวิตเริ่มต้นใหม่อีกครั้งเมื่อเข้าสู่ฤดูใบไม้ร่วง ฉันรู้สึกขอบคุณสำหรับทุกสิ่งทุกอย่างที่มีอยู่ตอนนี้ และสำหรับทุกสิ่งทุกอย่างที่จะเข้ามาในอนาคต ขอบใจนะที่เป็นส่วนหนึ่งในเรื่องพวกนั้นน่ะ @$76",
  "Core.Mateo.Fall.Relationship.Platonic.6": "@! คนที่ฉันอยากเจอพอดีเลย นี่ ฉันให้กัสทำเจ้านี่มาให้นายล่ะ [205 207 231 236 237 238 239 243]$1#$b#ปลอดภัยไว้ก่อนนะเวลาลงดันเจี้ยนน่ะ ดูแลเรื่องน้ำกับอาหารให้ดีๆ ด้วยล่ะ$32",
  "Core.Mateo.Fall.Relationship.Platonic.7": "บางทีฉันก็ไปเจอพวกอาวุธเก่าๆ ลึกลงไปในเหมืองน่ะ พวกดาบ ค้อน อะไรพวกนี้แหละ$34#$b#ฉันก็อดสงสัยไม่ได้นะว่าพวกผีที่สิงสู่อยู่แถวนั้นอาจจะแค่พยายามเตือนนักผจญภัยหน้าใหม่ๆ หรือเปล่า เหมือนไม่อยากให้พวกเขาต้องมามีจุดจบแบบเดียวกันน่ะ$37",
  // 10 HEARTS PLATONIC - WINTER 
  "Core.Mateo.Winter.Relationship.Platonic.1": "ช่วงนี้ฉันพยายามกินวิตามินให้ครบถ้วนอยู่น่ะ ร่างกายฉันขาดสารอาหารบางอย่างที่ส่งผลต่ออารมณ์ด้วย$7#$b#มันค่อนข้างยากนะที่จะจำให้ได้ว่าต้องกินทุกวัน แต่ฉันก็อยากจะจัดการกับอาการซึมเศร้าตามฤดูกาลของตัวเองให้เด็ดขาดไปเลย$80",
  "Core.Mateo.Winter.Relationship.Platonic.2": "อากาศค่อนข้างหนาวเลยนะ แต่ก็นะ มันอาจจะแย่กว่านี้ก็ได้ ถึงอย่างนั้น วันที่หิมะตกมันก็ไม่ได้แย่ขนาดนั้นหรอกนะ นายสามารถอยู่แต่ในบ้านแล้วก็อ่านหนังสือทั้งวันได้ โดยที่ไม่มีใครคาดหวังให้นายไปทำอย่างอื่นเลย$1",
  "Core.Mateo.Winter.Relationship.Platonic.3": "ตอนนี้ฉันมีห้องครัวแล้ว ฉันเลยพยายามจะทำอาหารให้มากขึ้นน่ะ เอ้านี่ @! ฉันใส่กระติกมาเต็มเลยนะ [236]$1#$b#กัสเป็นคนสอนฉันทำน่ะ แต่ฉันไม่คิดว่ามันจะอร่อยเท่าเขาหรอกนะ แต่มันจะช่วยทำให้นายอุ่นขึ้นได้นะ!$32",
  "Core.Mateo.Winter.Relationship.Platonic.4": "การได้นั่งดูหิมะตกผ่านหน้าต่างแทนที่จะต้องมองผ่านช่องเต็นท์ ถือเป็นโบนัสที่ไม่คาดคิดเลยนะจากการได้อยู่ในบ้านจริงๆ น่ะ สบายกว่ากันเยอะเลย ปกติฉันต้องทนหนาวอยู่ตลอดเวลาเลยล่ะ$1",
  "Core.Mateo.Winter.Relationship.Platonic.5": "ฮาร์วีย์ลงความเห็นแล้วว่ามันไม่ดีต่อสุขภาพฉันอีกต่อไปแล้วที่ฉันจะลงเหมืองในช่วงฤดูหนาวน่ะ$10#$b#แค่การขาดแสงแดดธรรมชาติมันก็ทำให้รับวิตามินดีได้ยากพออยู่แล้ว แต่การไปหมกตัวอยู่ข้างล่างทั้งวันมันยิ่งทำให้แย่ลงไปอีก$16#$b#เขาเลยอยากให้ฉันหันมาโฟกัสกับการทำวิจัยและออกไปแฮงเอาต์กับเพื่อนๆ แทนล่ะ$32",
  "Core.Mateo.Winter.Relationship.Platonic.6": "ช่วงเวลานี้ของปีทุกคนดูจะมีเรื่องให้ทำน้อยลงนะ พวกเราเลยได้เล่นบอร์ดเกมกันบ่อยขึ้นน่ะ$1#$b#มันดีมากเลยนะที่กลุ่มพวกเราได้มาอยู่รวมกันและทำในสิ่งที่รัก และฉันก็ชอบที่จะโฟกัสกับการเขียนเนื้อเรื่องเสริมให้พวกเขาด้วย$32",
  "Core.Mateo.Winter.Relationship.Platonic.7": "ฉันเหนื่อยจังเลยล่ะ @ แต่ก็ไม่เป็นไรหรอก พรุ่งนี้ก็วันใหม่แล้ว นายเป็นไงบ้าง?$76#$b#นอนหลับสบายดีไหม? กินอิ่มไหม? พักผ่อนให้เพียงพอล่ะ? เป็นช่วงเวลาของปีที่ยากลำบากนะ ใจดีกับตัวเองเข้าไว้ล่ะ$1",
  // 10 HEARTS ROMANTIC - SPRING 
  "Core.Mateo.Spring.Relationship.Romantic.1": "ไง ที่รัก ฉันรู้ว่านายเก่งมากนะ แต่ช่วยระวังตัวหน่อยเวลาอยู่ในเหมืองอันตราย (Dangerous Mines) พวกมอนสเตอร์ที่แข็งแกร่งกว่ามันทำให้ที่นั่นเสี่ยงมากขึ้น และข้างล่างนั่นก็มีสารกัมมันตภาพรังสีเยอะด้วย$29#$b#แค่ระวังตัวให้ดี ตกลงไหม? คงไม่ต้องบอกก็รู้ว่าฉันคงสติแตกแน่ๆ ถ้ามีอะไรเกิดขึ้นกับนายน่ะ$27",
  "Core.Mateo.Spring.Relationship.Romantic.2": "ฉันรู้ว่าฤดูใบไม้ผลิเป็นฤดูที่สำคัญสำหรับนาย เหมือนนายกำลังพยายามทำยอดให้ทันหลังจากฤดูหนาวที่ซบเซาผ่านไป แต่นั่นก็ไม่ได้หมายความว่านายควรจะฝืนร่างกายตัวเองขนาดนี้นะ$28#$b#ขอโทษด้วยนะที่ฉันไม่มีประโยชน์อะไรกับนายเลยนอกจากเป็นแค่ของประดับสวยๆ น่ะ$31",
  "Core.Mateo.Spring.Relationship.Romantic.3": "ช่วงนี้ฉันไปทะเลทรายบ่อยขึ้นน่ะ นอกจากถ้ำกะโหลกแล้ว มันยังมีอะไรให้ค้นคว้าอีกเยอะเลย$34#$b#ฉันสนใจโครงกระดูกยักษ์ที่ถูกขุดขึ้นมาได้แค่ครึ่งเดียวนั่นมากๆ นายเคยเห็นไหม? มันอลังการมากเลยนะ ถ้ามีเวลา บางทีเราน่าจะไปด้วยกันนะ$30",
  "Core.Mateo.Spring.Relationship.Romantic.4": "ที่รัก ถ้านายจะไปผจญภัยล่ะก็ พกเจ้านี่ติดตัวไปด้วยนะ [205 207 231 236 237 238 239 243]$27#$b#ฉันลองทำอาหารใหม่ๆ ที่ครัวของกิลด์ดูน่ะ เอาจริงๆ นายไม่รู้หรอกว่านายจะคิดถึงเตาอบมากแค่ไหน จนกว่านายจะไม่มีมันให้ใช้น่ะ$1",
  "Core.Mateo.Spring.Relationship.Romantic.5": "อยากลองดูไหมว่าต้นไม้ในฟาร์มของนายมันจะนั่งพิงสบายพอๆ กับความสวยของมันไหม? ฉันจะดันนายติดต้นไม้ แล้วนายค่อยบอกฉันละกันนะ$28",
  "Core.Mateo.Spring.Relationship.Romantic.6": "@ คืนนี้เราไปซาลูนหรือโรงเตี๊ยมกันดีไหม? ไปดื่มกันสักหน่อยแล้วก็ใช้เวลาทั้งคืนคุยกันเพื่ออัปเดตชีวิตว่าที่ผ่านมานายเป็นยังไงบ้าง$1#$b#บางทีหลังจากนั้น เราอาจจะไปจบคืนนี้กันที่กิลด์ เอเมริทัสคิดถึงนายแย่แล้ว$32",
  "Core.Mateo.Spring.Relationship.Romantic.7": "ฉันให้พวกปาร์ตี้ไปสู้กับสัตว์ประหลาดปูหินในเกมกระดานสำหรับมอนสเตอร์ประจำสัปดาห์นี้น่ะ พวกเขาสนุกกันใหญ่เลยล่ะ$1#$b#มันน่าพอใจมากในหลายๆ แง่มุมเลย แถมพวกเขายังได้รับความกล้าหาญเพิ่มขึ้นด้วยนะ$32",
  // 10 HEARTS ROMANTIC - SUMMER
  "Core.Mateo.Summer.Relationship.Romantic.1": "วันนี้อากาศร้อนเนอะ ที่รัก? นายอยากไปแฮงเอาท์ที่อ่าวกับฉันสักพักไหม?$31#$b#บางทีเราอาจจะไปซ้อมประลองกันสักหน่อย ยังไงซะนายก็เป็นคนโปรดที่ฉันอยากจะเสียเหงื่อด้วยที่สุดอยู่แล้วล่ะ$30",
  "Core.Mateo.Summer.Relationship.Romantic.2": "ฉันชอบเวลาไปทะเลกับคนอื่นๆ นะ เอาจริงๆ ฉันไม่ได้ผ่านการผ่าตัดหน้าอกให้แบนราบเพื่อที่จะไม่โชว์มันทุกครั้งที่มีโอกาสหรอกนะ$13#$b#รอยแผลเป็นอื่นๆ บางรอยมันก็ทำให้ฉันกังวลเหมือนกัน แต่ฉันลืมความรู้สึกนั้นไปสนิทเลยเวลามีมือของนายสัมผัสฉันอยู่น่ะ$28",
  "Core.Mateo.Summer.Relationship.Romantic.3": "ดีใจนะที่นายออกมาจากโจจ้าแล้วหาทางมาเจอกับหุบเขานี้ได้ ที่รัก บริษัทนั้นมักจะดึงเอาด้านที่แย่ที่สุดของคนออกมาเสมอแหละ$8#$b#ฉันภูมิใจในตัวนายนะที่กล้าตัดสินใจครั้งใหญ่ขนาดนั้น ฉันเข้าใจดีเลยว่ามันยากแค่ไหน โดยเฉพาะในตอนนี้น่ะ$4",
  "Core.Mateo.Summer.Relationship.Romantic.4": "ที่รัก? เอ่อ เอเมริทัสออกไข่ล่ะ [107]$3#$b#นายเอาไปให้กุนเธอร์ก็ได้นะถ้านายยังไม่เคยให้น่ะ แต่นายสามารถขยายพันธุ์พวกมันได้ทั้งเล้าเลยนะถ้านายเอามันใส่ในเครื่องฟักไข่น่ะ$35#$b#นายอาจจะเจอพวกมันมากขึ้นในชั้นก่อนประวัติศาสตร์ของถ้ำกะโหลก ถ้านายกำลังมองหาทางสร้างกองทัพไดโนเสาร์น่ะ หรือเอ่อ... อาณาจักรมายองเนสไดโนเสาร์น่ะ$36",
  "Core.Mateo.Summer.Relationship.Romantic.5": "วันก่อนฉันไปเยี่ยมโครบุส (Krobus) มา ดูเหมือนเขาจะสบายดีนะ! ยืมหนังสือจากกุนเธอร์ไปให้เขานิดหน่อยน่ะ$1#$b#บางที ในท้ายที่สุดแล้วเราอาจจะทำบัตรห้องสมุดให้เขาเป็นของตัวเองได้เลยก็ได้นะ$12",
  "Core.Mateo.Summer.Relationship.Romantic.6": "นายเคยเห็นฉันปามีดไหม ที่รัก? ฉันจะพิสูจน์ให้ดูว่าฉันไม่เคยพลาดเป้า บางทีคืนนี้มีดเย็นๆ อาจจะไม่ใช่สิ่งเดียวที่ถูกตรึงไว้กับเป้าปาเป้าก็ได้นะ$30",
  "Core.Mateo.Summer.Relationship.Romantic.7": "ทำไมถึงเรียก 'ที่รัก' (Sunshine-แสงตะวัน) น่ะเหรอ? อ้อ ก็เพราะในเหมืองมันมืดอยู่ตลอดเวลาไง @ นายคือสิ่งที่ทำให้การต่อสู้ดิ้นรนเพื่อกลับขึ้นมามันคุ้มค่าในทุกๆ ครั้ง อย่าลืมซะล่ะ ตกลงไหม? ฉันรักนายนะ$78",
  // 10 HEARTS ROMANTIC - FALL
  "Core.Mateo.Fall.Relationship.Romantic.1": "ไง ที่รัก! ฉันแกะสลักเจ้านี่มาให้นาย เผื่อว่านายยุ่งเกินกว่าจะทำเองน่ะ [746]$4#$b#แต่อย่าลืมทิ้งมันตอนหมดฤดูกาลด้วยล่ะ ไม่งั้นมันจะเน่าเอานะ$2",
  "Core.Mateo.Fall.Relationship.Romantic.2": "ในเหมืองมีผีเยอะขึ้นมากเลยช่วงเวลานี้ของปี สาบานได้เลย เหมือนพวกมันรู้ว่านี่คือฤดูกาลของพวกมันยังไงยังงั้น$6#$b#ระวังตัวด้วยนะถ้าจะไปสำรวจ ที่รัก บอกฉันได้เลยนะถ้าอยากให้ไปเป็นเพื่อน$76",
  "Core.Mateo.Fall.Relationship.Romantic.3": "รู้ไหม อากาศข้างนอกดีมากเลยนะ เย็นสบาย สดชื่น นายคิดยังไงกับการใช้เวลาร่วมกันสักหน่อยล่ะ?$28#$b#นาย, ฉัน, ชายหาด, แสงเทียน, ดื่มด่ำบรรยากาศของฤดูกาลนี้... และซึมซับกันและกัน$31",
  "Core.Mateo.Fall.Relationship.Romantic.4": "ฉันงมงายไหมเหรอ? บางทีนะ แต่ฉันคิดว่าความกลัวในปริมาณที่พอเหมาะมันดีต่อร่างกายนะ ยังไงซะมันก็เป็นจุดเริ่มต้นของความกล้าหาญนี่นะ$1#$b#แต่นายคือคนที่กล้าหาญที่สุดเท่าที่ฉันรู้จักเลยนะ นั่นหมายความว่านายกลัวหลายๆ สิ่ง หรือไม่ก็ไม่กลัวอะไรเลยหรือเปล่า?$36",
  "Core.Mateo.Fall.Relationship.Romantic.5": "เมื่อไม่นานมานี้ ฉันยังไม่เข้าใจเลยว่าความสุขมันหน้าตาเป็นยังไง ฉันใช้เวลาเยอะมากไปกับการดิ้นรนค้นหาว่าตัวเองต้องการอะไรจากชีวิต$8#$b#กลายเป็นว่ามันมีรูปร่างเหมือนชาวไร่แฮะ ขอบคุณสำหรับเรื่องนั้นนะ ที่รัก$27",
  "Core.Mateo.Fall.Relationship.Romantic.6": "สัปดาห์นี้ฉันกำลังจัดเซสชั่นที่หลอนเป็นพิเศษให้กับกลุ่มบอร์ดเกมของฉันน่ะ โดยตั้งเป้าไปที่ความรู้สึกหวาดกลัวจากการมีอยู่ของตัวตน โดยการขุดคุ้ยความกลัวที่ลึกที่สุดในใจของตัวละคร!$13#$b#มันต้องสนุกมากแน่ๆ ถึงแม้จะสร้างบาดแผลในใจให้กับคนเล่นไปบ้างก็เถอะ แต่ไม่เป็นไรหรอก มันเป็นส่วนหนึ่งของประสบการณ์น่ะ$32",
  "Core.Mateo.Fall.Relationship.Romantic.7": "นายคือคนที่ฉันอยากเจอพอดีเลย ที่รัก ฉันมีเรื่องที่ตั้งใจจะบอกนายอยู่พอดี$30#$b#จริงๆ แล้ว ฉันแสดงให้นายดูแทนดีกว่า ถ้านายไม่ได้ยุ่งอะไรทีหลังน่ะ? มันเป็นข้อความที่ส่งผ่านท่านอนได้ดีที่สุดเลยล่ะ$28",
  // 10 HEARTS ROMANTIC - WINTER 
  "Core.Mateo.Winter.Relationship.Romantic.1": "โอ้ ดูสิ แสงตะวันของฉันมาแล้ว! เป็นยังไงบ้าง ที่รัก? หวังว่าความหนาวจะไม่ทำให้เธอแย่ลงนะ$32#$b#นายยืมเสื้อโค้ทฉันไปใส่ก็ได้นะ ถ้านายต้องการ นายใส่แล้วดูดีนะ แถมยังช่วยให้อุ่นขึ้นเยอะเลยด้วย$31",
  "Core.Mateo.Winter.Relationship.Romantic.2": "หืม? โอ้ ใช่แล้วล่ะ ฉันจำได้ว่าต้องกินวิตามินนะ และก็รู้สึกค่อนข้างดีเลยล่ะ ขอบใจที่ถามนะ ที่รัก$4#$b#ฉันรักนายนะ อย่าหักโหมทำงานหนักเกินไปล่ะ - นี่เป็นคำสั่งจากกิลด์มาสเตอร์นะ$28",
  "Core.Mateo.Winter.Relationship.Romantic.3": "หมอฮาร์วีย์บอกให้หลีกเลี่ยงการลงเหมืองในช่วงฤดูหนาว ซึ่งก็สมเหตุสมผลดี เมื่อพิจารณาจากทุกๆ อย่างแล้ว แต่ฉันต้องรักษาหุ่นด้วยวิธีใดวิธีหนึ่งนะ$35#$b#บางทีเราอาจจะไปคาร์ดิโอกันเพิ่มเพื่อชดเชยเรื่องนั้นได้นะ ว่าไหม?$30",
  "Core.Mateo.Winter.Relationship.Romantic.4": "ไง ที่รัก! เราสองคนมาใช้ประโยชน์จากความหนาวนี่กันหน่อยไหม?$31#$b#เราจะมุดตัวอยู่ใต้ผ้าห่ม ดื่มด่ำไปกับหนัง... และอาจจะทำอย่างอื่นด้วยนิดหน่อยนะ$30",
  "Core.Mateo.Winter.Relationship.Romantic.5": "แวะมากิลด์บ้างสิ ที่รัก เอเมริทัสคิดถึงนายแย่แล้ว ฉันเองก็เหมือนกัน$76#$b#เดี๋ยวฉันชงกาแฟให้แล้วเราขึ้นไปซุกตัวกันบนห้องใต้หลังคาดีไหม? ฟังดูเป็นไงล่ะ?$4",
  "Core.Mateo.Winter.Relationship.Romantic.6": "ฉันมีมุกตลกลามกติดอยู่ที่ริมฝีปากน่ะ เกี่ยวกับการขาดวิตามินดี (Vitamin D)... บางทีถ้านายจูบฉัน นายอาจจะเจอมันก็ได้นะ$31",
  "Core.Mateo.Winter.Relationship.Romantic.7": "ฉันรู้สึกไม่หวั่นไหวกับสภาพอากาศเลย ซึ่งมันบ้ามาก ฤดูหนาวเคยเป็นสิ่งที่วนเวียนอยู่ในหัวฉันตลอดทั้งปีเลยนะ$12#$b#ตอนนี้ฉันสามารถชื่นชมมันในแบบที่มันเป็นได้แล้ว ว่าแต่ ที่รัก - ฉันทำเจ้านี่มาให้นายนะ มันจะคอยให้ความอบอุ่นนายแทนฉันเวลาที่ฉันทำไม่ได้ [236]$4",
  // EPILOGUE 
  "Core.Mateo.Epilogue.1": "ถ้านั่นเป็นครั้งสุดท้ายที่ฉันต้องนำปาร์ตี้ผจญภัยลงดันเจี้ยนเพื่อไปสู้กับสัตว์ประหลาดทำลายล้างเมืองล่ะก็ ฉันคงจะพอใจมากๆ เลยล่ะ$1",
  "Core.Mateo.Epilogue.2": "เป้าหมายของฉันต่อจากนี้ คือการทำให้แน่ใจว่าทุกคน - ไม่ว่าจะมาจากชีวิตแบบไหน มีอดีตที่แปดเปื้อนมาอย่างไร - สามารถหาบ้านอยู่ร่วมกับฉันได้หากพวกเขาต้องการ$76",
  "Core.Mateo.Epilogue.3": "ไวแอตต์ (Wyatt) เป็นคนที่น่าสนใจมากเลยตอนโต เรายังมีเรื่องต้องปรับจูนกันอีกเยอะ แต่อย่างน้อยฉันก็ยอมรับในมุมมองของเขาและสิ่งที่เขาพยายามทำเพื่อปกป้องฉันนะ$80",
  "Core.Mateo.Epilogue.4": "ฉันไปเยี่ยมโครบุสบ่อยเท่าที่จะทำได้ เขากับเอเมริทัสเข้ากันได้ดีเป็นปี่เป็นขลุ่ยเลยล่ะ$12",
  "Core.Mateo.Epilogue.5": "บางทีฉันก็ชอบให้รางวัลตัวเองด้วยการรินเบอร์เบินเข้มๆ สักแก้ว แล้วก็แค่จ้องมองเส้นขอบฟ้าจากบนหลังคาของกิลด์$15",
  "Core.Mateo.Epilogue.6": "มันเยี่ยมมากเลยนะที่ได้จดจ่ออยู่กับการสร้างสรรค์สิ่งต่างๆ เกราะ, อาวุธ, ลูกธนู... เอาจริงๆ ส่วนใหญ่ก็เป็นเกราะนั่นแหละ ฉันชอบความรู้สึกที่ได้มีส่วนร่วมในการปกป้องใครสักคน$80",
  "Core.Mateo.Epilogue.7": "ฉัน... ปลูกดอกกุหลาบ, ทดลองทำแม่พิมพ์ดาบแบบใหม่ๆ, แล้วก็... ใช้ชีวิตเหมือนได้ยกภูเขาออกจากอก$12",
  "Core.Mateo.Epilogue.8": "มันทำให้ฉันมีความสุขอย่างบอกไม่ถูกเลยที่ทุกคนได้พบความสงบสุขในแบบของตัวเอง เหมือนกับความสงบสุขที่นายเคยมอบให้ฉันเมื่อนานมาแล้วน่ะ @$78",
  "Core.Mateo.Epilogue.9": "มาร์ลอน (Marlon) บอกว่าเขาภูมิใจในตัวฉัน เอาจริงๆ นะ? ฟังแล้วไม่เคยเบื่อเลยล่ะ ฉันอยากจะรู้สึกว่าฉันทำสิ่งที่ถูกต้องเพื่อเขาและกุนเธอร์ (Gunther)$33",
  "Core.Mateo.Epilogue.10": "...นายเข้าใจฉันมากเท่าที่ฉันเคยอยากให้ใครสักคนเข้าใจ นายเชื่อในตัวฉัน เหมือนที่นายอยากจะเชื่อในตัวเองนั่นแหละ$80",
  /*
