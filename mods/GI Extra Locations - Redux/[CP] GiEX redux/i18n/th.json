    "Javi10h.GoodEnding.17.GINPCTweaks": "ต้นหนของฉันชื่อฮาวีเยร์ แต่เขาเป็นผู้ชายนะ...",
    //key n°18 is "dots"
    "Javi10h.GoodEnding.19": "นั่นแหละคือสิ่งที่เกิดขึ้น ฉันปลอมแปลงตัวตนซะใหม่#$b#คุณสมควรที่จะได้รับรู้ว่าเกิดอะไรขึ้นในคืนนั้น",
    "Javi10h.GoodEnding.20": "ฉันขอตัวก่อนนะ",
    "Javi10h.GoodEnding.21": "เดี๋ยวก่อน$2#$b#ฉันนึกว่าไม่มีใครรอดชีวิตมาได้ซะอีก...",
    "Javi10h.GoodEnding.22": "ทั้งหมดเป็นเพราะเขานั่นแหละ",
    "Javi10h.GoodEnding.22.GINPCTweaks": "ทั้งหมดเป็นเพราะคุณนั่นแหละ",
    "Javi10h.GoodEnding.23": "เขาอาจจะไม่อยู่ที่นี่แล้ว แต่...#$b#เขาจะอยู่ในความทรงจำของเรา ไม่มีใครสามารถพรากมันไปจากเราได้#$b#ฉันจะไม่มีวันลืมเขา",
    "Javi10h.GoodEnding.23.GINPCTweaks": "ลูกเรืออาจจะไม่อยู่ที่นี่แล้ว แต่...#$b#พวกเขาจะอยู่ในความทรงจำของเรา ไม่มีใครสามารถพรากมันไปจากเราได้#$b#ฉันจะไม่มีวันลืมพวกเขา",
    "Javi10h.GoodEnding.24": "บอกฉันทีสิ...#$b#เขาเป็นกัปตันแบบไหนกันหรอ?",
    "Javi10h.GoodEnding.24.GINPCTweaks": "บอกฉันทีสิ...#$b#คุณจำอะไรได้บ้าง?",
    "Javi10h.GoodEnding.25": "ไหนขอดูหน่อยสิ...",
    "Javi10h.GoodEnding.ConversationTopic": "ตอนแรกฉันก็ไม่แน่ใจว่าจะทำแบบนั้นดีไหม แต่คุณก็เป็นคนช่วยผลักดันฉันในตอนท้าย ขอบใจนะ @",

    //12
    "Javi12h.1": "@",
    "Javi12h.2": "ฉันแค่มาเยี่ยมเฉยๆ น่ะ",
    "Javi12h.3": "ไม่นึกเลยว่าเรือจะมาอับปางที่นี่...",
    "Javi12h.4": "เบอร์ดี้ยังคงประมวลผลทุกอย่างอยู่เลย",
    "Javi12h.5": "ฉันไม่รู้เหมือนกันว่าทำถูกไหมที่บอกความจริงกับเธอไปแบบนั้น",
    "Javi12h.6": "แต่ฉันติดค้างกัปตันอยู่นี่นา ถ้าฉันชดใช้ให้เขาไม่ได้ ฉันก็ควรจะช่วยปิดฉากเรื่องราวทั้งหมดให้กับภรรยาของเขา",
    "Javi12h.6.GINPCTweaks": "แต่ฉันติดค้างเธออยู่นี่นา ฉันควรจะช่วยให้เธอได้ปิดฉากเรื่องราวทั้งหมดซะที",
    "Javi12h.7": "รู้สึกเหมือนได้ยกภูเขาออกจากอกเลยล่ะ",
    "Javi12h.8": "ฉันยังโกรธคุณอยู่นะที่คุณแอบอ่านไดอารี่ลับหลังฉันน่ะ",
    "Javi12h.9": "แต่...เรื่องมันก็ลงเอยด้วยดีก็เพราะแบบนั้นล่ะนะ",
    "Javi12h.10": "ดูแลตัวเองด้วยล่ะ @",
    "Javi12h.end": "หลังจากนั้น โจรสลัดคนนั้นก็หายตัวไป#ชายที่มักพูดถึงฮาวี...#ดูเหมือนเขาจะอันตรธานหายไปเลย#วิญญาณก็เลิกปรากฏตัวบนเรือด้วยเช่นกัน",
    "Javi12h.end.cont": "นั่นมัน...?#คงไม่มีใครได้รู้ความจริงหรอก",

    //12h - bad ending continuation
    "Javi12h.BadEnding.0": "@ บังเอิญจังเลยนะ#$b#แล้วไม่นึกเลยว่าเรือจะมาจบลงที่นี่...",
    "Javi12h.BadEnding.1": "...",
    "Javi12h.BadEnding.2": "@ ฉันตัดสินใจแล้วล่ะ#$b#ฉันจะไปมอบตัวกับกองทัพเรือ",
    "Javi12h.BadEnding.3": "หลังจากที่เราคุยกัน ฉันก็มานั่งคิดทบทวนว่าอะไรคือสิ่งที่ถูกต้อง#$b#และ...#$b#ถ้าเขาไม่รอดชีวิต และฉันก็ช่วยภรรยาของเขาไม่ได้ด้วย...งั้นฉันก็ควรมอบตัวซะ#$b#นี่แหละคือบทลงโทษของฉัน#$b#อย่างน้อยตอนที่ฉันอยู่ในคุก ฉันก็คงรู้สึกว่าได้ทำอะไรที่ถูกต้องในชีวิตขึ้นมาบ้าง",
    "Javi12h.BadEnding.3.GINPCTweaks": "หลังจากที่เราคุยกัน ฉันก็มานั่งคิดทบทวนว่าอะไรคือสิ่งที่ถูกต้อง#$b#และ...#$b#ถ้าไม่มีใครรอดชีวิต และฉันก็ช่วยเธอไม่ได้ด้วย...งั้นฉันก็ควรมอบตัวซะ#$b#นี่แหละคือบทลงโทษของฉัน#$b#อย่างน้อยตอนที่ฉันอยู่ในคุก ฉันก็คงรู้สึกว่าได้ทำอะไรที่ถูกต้องในชีวิตขึ้นมาบ้าง",
    "Javi12h.BadEnding.4": "ใครจะรู้ ฉันอาจจะได้เห็นหน้าผู้ชายคนนั้นอีกครั้งก็ได้นะ#$b#ฉันหมายถึงตาแก่ของฉันน่ะ จำได้ไหม เขาอยู่ในกองทัพเรือ#$b#ส่วนฉัน... ฉันดันไปเข้าร่วมกับโจรสลัด$4#$b#แน่ล่ะ นี่คือบทลงโทษสำหรับทุกอย่างที่ฉันทำลงไป",
    "Javi12h.BadEnding.5": "ลาก่อนนะ @ นี่คงจะเป็นครั้งสุดท้ายที่เราได้เจอกัน",
    "Javi12h.BadEnding.6": "หลังจากนั้น ฉันก็ไม่เคยเจอฮาวีอีกเลย#ฉันยังคงเห็นวิญญาณโจรสลัดล่องลอยอยู่บนเรือ ทนทุกข์ทรมานไปชั่วนิรันดร์",
    "Javi12h.BadEnding.7": "...#แล้วถ้าเรื่องราวมันแตกต่างออกไปล่ะ? ถ้าเกิดว่า...?#เอาเถอะ มาสงสัยเอาตอนนี้มันก็ไม่มีประโยชน์อะไรหรอก",

