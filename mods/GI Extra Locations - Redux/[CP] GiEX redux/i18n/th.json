    //dialogue
    "Dialogue.Clearance": "อากาศแบบนี้ชักทนไม่ไหวแล้วสิ...ที่นี่เหมาะจะมานั่งพักผ่อนที่สุด#$b#มีร่มเงาดีซะด้วย",
    "Dialogue.GingerIsland": "เกาะนี้เป็นเหมือนสายล่อฟ้าที่ดึงดูดพวกโจรสลัดเลยแฮะ สงสัยจังว่าทำไม",
    "Dialogue.Trader": "สำหรับเกาะแล้วเนี่ย มีคนให้มาค้าขายด้วยไม่เยอะเท่าไหร่นะ",
    "Dialogue.HiddenBeach": "ไม่ค่อยมีคนรู้จักชายหาดนี้กันนักหรอก#$b#มาโผล่ที่นี่บ้างเป็นครั้งคราวก็ดีเหมือนกันนะ",
    "Dialogue.Rain": "ฝนตกงั้นหรอ...#$b#มันทำให้ฉันนึกถึงมหาสมุทรขึ้นมาเลย",
    "Dialogue.BlueDiscus": "คุณเคยลองกินปลาบลูดิสคัสบ้างไหม?#$b#ไม่หรอ?",
    "Dialogue.Dwarves": "อะไรนะ? คนแคระหรอ? นั่นมันก็นิทานหลอกเด็กทั้งนั้นแหละน่า",
    "Dialogue.Farm": "ชีวิตการทำฟาร์มเป็นไงบ้างล่ะ @?",
    "Dialogue.Crops": "พืชผลพวกนั้นเจริญงอกงามดีหรือเปล่าล่ะ?",
    "Dialogue.OtherIslands": "คุณเคยไปเที่ยวเกาะอื่นมาบ้างไหมล่ะ? ลองแวะไปบ้างสิ",
    "Dialogue.Fishing": "ฉันไม่มีทางเบื่อปลาหรอก คุณสามารถเอามาทำอาหารได้ตั้งหลายอย่างเลยนะ#$b#คุณจะทอดมันก็ได้ เอาไปต้มสตูว์ก็ได้...",
    //post-8h
    "Dialogue.Alone": "อยู่บนเกาะนี้เหงาบ้างไหมน่ะหรอ? ก็...#$b#ใช่นะ แต่ฉันชอบความเงียบสงบที่นี่",
    "Dialogue.Volcano": "ภูเขาไฟงั้นหรอ? ฉันไม่ค่อยรู้เรื่องหรอก#$b#ฉันชอบไปนั่งตกปลามากกว่า",
    "Dialogue.Volcano2": "บางครั้ง พวกมอนสเตอร์ก็หลุดออกมาจากภูเขาไฟ#$b#ฉันไม่ค่อยชอบใช้ดาบนั่นหรอกนะ แต่ถ้าจำเป็นมันก็ต้องทำล่ะ...$4#$e#ฉันเอาดาบมาจากไหนน่ะหรอ?#$b#อย่าไปใส่ใจมันเลยน่า",
    "Dialogue.Caldera": "มีแท่นหลอมอยู่บนยอดภูเขาไฟหรอ?#$b#แปลกพิลึกเลยแฮะ",
    "Dialogue.Leo": "ฉันรู้จักลีโอไหมน่ะหรอ? แน่นอนสิ#$b#เด็กนั่นเข้ากับพวกนกแก้วได้ดีนะ แต่พวกมันมักจะบินหนีฉันตลอดเลย",
    "Dialogue.Journal": "ไดอารี่เล่มนั้นไม่ได้มีไว้ให้ใครหน้าไหนมาเปิดอ่านหรอกนะ#$b#บางครั้ง ความคิดมันก็วนเวียนอยู่ในหัว...$2#$b#และการเขียนก็เป็นสิ่งที่ช่วยระบายมันได้",
    "Dialogue.Gender": "เบอร์ดี้สับสนน่ะ#$b#เธอจำต้นหนเรือได้ แต่คิดว่าเป็นผู้ชาย#$b#ใครๆ เขาก็คิดกันแบบนั้นแหละ$1#$e#ฉันไม่ได้เก็บมาใส่ใจหรอกนะ",
    "Dialogue.Softspot": "เคยมีข่าวลือบนเรือของเราว่า 'ต้นหนเรือน่ะแพ้ทางผู้หญิง'#$b#...#$b#มันก็จริงนั่นแหละนะ$7",
    "Dialogue.Haircut": "ทำไมตอนนี้ฉันถึงไม่ตัดผมน่ะหรอ?#$b#ฉันชอบที่มันเป็นแบบนี้น่ะสิ",
    "Dialogue.LeoGone1": "ฉันมักจะลืมไปเสมอเลยว่าลีโอไปอยู่ที่เมืองเพลิแกนแล้ว แล้วก็ชอบไปคอยสอดส่องดูเขาอยู่เรื่อยเลย",
    "Dialogue.LeoGone2": "เขาเป็นไงบ้างล่ะ @?",
    "Dialogue.LeoGone3": "ฉันคิดถึงเด็กนั่นนะ แต่แบบนี้ก็ดีต่อตัวเขาแล้วล่ะ",
    "Dialogue.Parrot": "เราเคยมีไก่อยู่บนเรือด้วยนะ#$b#ฉันสงสัยจังว่าเกิดอะไรขึ้นกับมัน",
    "Dialogue.Parrot2": "นอกจากไก่แล้ว เราก็เคยมีวัวด้วยครั้งหนึ่ง#$b#อะไรล่ะ? เราก็ต้องกินเพื่ออยู่รอดนะ$5",
    "Dialogue.Boredom": "บางครั้งเราก็ไม่เห็นเรือผ่านมาเป็นวันๆ เลย#$b#เราก็มีวิธีแก้เบื่อในแบบของเราเอง#$b#เล่นไพ่ ทอยลูกเต๋า แบ่งสมบัติกัน...$6",
    "Dialogue.Boredom2": "พอเราไม่มีอะไรให้ทำ บางคนก็เล่นดนตรีหรือร้องเพลง#$b#มีอยู่คนนึงที่ร้องเพลงได้ห่วยแตกมาก แต่ก็ร้องออกมาจากใจเลยล่ะ",
    "Dialogue.Quartermaster": "จำไว้นะ @ หน้าที่ของต้นหนคือคอยรับใช้ลูกเรือ ไม่ใช่กัปตัน",
    "Dialogue.HisFin": "ฉันไม่เคยเข้าใจเลยว่าทำไมกัปตันถึงรับฉันมาอยู่ใต้การดูแลของเขา#$b#ฉันยังเป็นแค่เด็กใหม่แท้ๆ#$b#พอมาคิดดูตอนนี้ เขาคงเห็นศักยภาพที่ซ่อนอยู่ในตัวฉันมั้ง",
    "Dialogue.Before": "ถ้าคุณมาถามฉันตอนเด็กๆ ฉันก็ไม่แน่ใจหรอกนะว่าจะพูดถึงพวกโจรสลัดยังไงดี#$b#พ่อสอนให้ฉันมองพวกมันเป็นภัยคุกคามน่ะสิ#$e#แต่ดูเอาสิว่าฉันมาลงเอยตรงไหน",
    "Dialogue.Sailor": "รู้ไหม ตอนเด็กๆ ฉันเคยใฝ่ฝันอยากจะเป็นกะลาสีเรือนะ#$b#ตลกดีเนอะที่เรื่องมันจบลงแบบนี้น่ะ",
    "Dialogue.Gender2": "ทำไมฉันถึงต้องปลอมแปลงเพศตอนเข้าร่วมกับกลุ่มโจรสลัดน่ะหรอ?#$b#ก็...มันใช้ชีวิตง่ายกว่าไง ผู้หญิงแทบจะไม่ได้รับอนุญาตให้ก้าวขึ้นเรือโจรสลัดหรอกนะ#$e#แต่ไม่ใช่ว่าฉันไม่สนุกกับการทำแบบนั้นหรอกนะ",
    "Dialogue.Crew": "บางวันฉันก็คิดถึงพวกลูกเรือนะ สงสัยจังว่ามีใครรอดชีวิตจากคืนนั้นมาได้อีกไหม",
    "Dialogue.Crew2": "ฉันไม่คิดว่าพวกลูกเรือจะพอใจหรอกที่กัปตันรับโจรสลัดเด็กมาสอนน่ะ#$b#แต่ฉันขอนอกเรื่องหน่อยนะ#$b#เรือส่วนใหญ่ก็คอยสอนงานเด็กใหม่กันทั้งนั้นแหละ ไม่ใช่ความผิดของฉันสักหน่อยที่เรายังไม่มีระบบแบบนั้นน่ะ",
    "Dialogue.Rumours": "คุณหมายความว่ายังไงที่ว่าฉันเป็น \"พวกสิบแปดมงกุฎหรืออดีตทหารเรือ\"?#$b#@ คุณไปเอาเรื่องพวกนี้มาจากไหนกันเนี่ย?$9",
    //post-12h
    "Dialogue.Mon_12h": "วัยเด็กของฉันหรอ?#$b#ฉันไม่ชอบพูดถึงชีวิตของตัวเองก่อนที่จะขึ้นเรือน่ะ",
    "Dialogue.Tue_12h": "ทำไมโจรสลัดถึง 'รุ่งเรือง' น่ะหรอ?#$b#ก็เพราะมันทำเงินได้เป็นกอบเป็นกำไงล่ะ แค่นั้นแหละ",
    "Dialogue.Wed_12h": "รู้ไหม คนส่วนใหญ่มองโจรสลัดผิดไปหมด#$b#มันแตกต่างจากที่คุณเคยได้ยินหรือเคยเห็นตามสื่อต่างๆ เยอะเลยนะ",
    "Dialogue.Thu_12h": "เฮ้ @ ชีวิตชาวไร่ชาวนามันเป็นไงบ้างล่ะ?",
    "Dialogue.Sat_12h": "อะไรนะ คุณอยากรู้ว่าทำไมผู้หญิงถึงไม่ค่อยได้รับอนุญาตให้อยู่บนเรือโจรสลัดงั้นหรอ?#$b#มันเกี่ยวกับการที่พวกเธอถูกมองว่าเป็นลางร้าย และความกลัวว่าพวกโจรสลัดจะทะเลาะกันเพื่อแย่งชิงเธอน่ะสิ",
    "Dialogue.Sun_12h": "พวกโจรสลัดเขามีกฎของเขานะ รู้หรือเปล่า#$b#มันถูกตั้งขึ้นมาเพื่อรักษาความสงบเรียบร้อยบนเรือ หลีกเลี่ยงความขัดแย้งหรือการก่อกบฏ และเพื่อรับประกันความจงรักภักดีของลูกเรือยังไงล่ะ",
    //gifting
    "Gift.tackle": "เยี่ยมเลย ฉันกำลังอยากได้อุปกรณ์ตกปลาอันใหม่อยู่พอดี",
    "Gift.gem": "คุณเอาของพวกนี้ไปใช้ทำอะไรได้บ้างเนี่ย?",
    "Gift.mineral": "เจ้านี่มีไว้ใช้ทำอะไรหรอ?",
    "Gift.fish": "เยี่ยมไปเลย ฉันจะเอามันไปทำมื้อค่ำนะ",
    "Gift.meat": "คุณไปเอามาจากไหนเนี่ย @? ของดีเลยนะ!",
    "Gift.curiosity_lure": "เหยื่อตกปลาประหลาดหรอ? ไม่เคยเห็นมาก่อนเลยนะเนี่ย",
    "Gift.truffle_oil": "น้ำมันเห็ดทรัฟเฟิลหรอ? หรูหราจังนะ",
    "Gift.honey": "นี่มาจากฟาร์มคุณหรอ? ขอบใจนะ @",
